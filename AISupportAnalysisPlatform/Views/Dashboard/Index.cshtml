@model AISupportAnalysisPlatform.Models.Common.DashboardViewModel

@{
    ViewData["Title"] = Loc.Get("Dashboard");

    var recentTicketsTable = new AISupportAnalysisPlatform.Models.Common.FeatureTableShellViewModel
    {
        Title = Loc.Get("RecentTickets"),
        Subtitle = Loc.Get("RecentTicketsSubtitle") ?? "Latest inbound and in-progress work items",
        ShowColumnSearchToggle = true,
        ColumnSearchLabel = Loc.Get("Filter"),
        TableSelector = "#dashboardRecentTicketsTable",
        ToolbarChipText = Loc.Get("InteractiveGrid") ?? "Interactive Grid",
        ToolbarChipIconClass = "bi bi-table",
        ToolbarChipStyle = "background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid rgba(59,130,246,0.22);",
        HeaderActionText = Loc.Get("OpenQueue") ?? "Open Queue",
        HeaderActionHref = Url.Action("Index", "Tickets"),
        HeaderActionCssClass = "btn btn-sm fw-bold px-3 py-2 rounded-pill",
        HeaderActionStyle = "background: var(--primary-color) !important; color: #000 !important;",
        TablePartialName = "~/Views/Dashboard/_RecentTicketsTable.cshtml",
        TableModel = Model.RecentTickets,
        ContainerCssClass = "feature-table-shell ops-card border-0 shadow-sm"
    };
}

<style>
    .ops-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 20px;
    }

    .ops-metric {
        position: relative;
        overflow: hidden;
    }

    .ops-metric::after {
        content: "";
        position: absolute;
        inset: @(Loc.IsRtl ? "auto auto -45% -20%" : "auto -20% -45% auto");
        width: 140px;
        height: 140px;
        border-radius: 50%;
        background: rgba(255,255,255,0.04);
    }

    .ops-kpi-label {
        font-size: 0.72rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 700;
        color: var(--text-muted);
    }

    .ops-mini-stat {
        background: var(--bg-main);
        border: 1px solid var(--border-color);
        border-radius: 16px;
    }
</style>

<div class="row mb-4 align-items-end">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-1" style="color: var(--text-main) !important;">
            @Loc.Get("Dashboard")
        </h2>
        <p class="text-muted mb-0" style="color: var(--text-muted) !important;">
            @Loc.Get("AppDescription")
        </p>
    </div>
    <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
        <a asp-controller="Tickets" asp-action="Create" class="btn fw-bold px-4 py-2 rounded-pill shadow-sm" style="background: var(--primary-color) !important; color: #000 !important;">
            <i class="bi bi-plus-lg @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("NewTicket")
        </a>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-xl-3 col-md-6">
        <div class="card ops-card ops-metric border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div class="d-flex align-items-center justify-content-center rounded-4" style="width: 50px; height: 50px; background: rgba(16,185,129,0.14); color: var(--primary-color);">
                        <i class="bi bi-ticket-detailed-fill fs-4"></i>
                    </div>
                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(16,185,129,0.1); color: var(--primary-color); border: 1px solid rgba(16,185,129,0.22);">
                        @Model.TicketsCreatedThisWeek @Loc.Get("ThisWeek")
                    </span>
                </div>
                <div class="ops-kpi-label mb-2">@Loc.Get("TotalTickets")</div>
                <div class="display-6 fw-bold mb-2" style="color: var(--text-main) !important;">@Model.TotalTickets</div>
                <div class="small" style="color: var(--text-muted) !important;">@Loc.Get("AcrossEntities")</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card ops-card ops-metric border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div class="d-flex align-items-center justify-content-center rounded-4" style="width: 50px; height: 50px; background: rgba(245,158,11,0.12); color: #f59e0b;">
                        <i class="bi bi-hourglass-split fs-4"></i>
                    </div>
                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(245,158,11,0.1); color: #f59e0b; border: 1px solid rgba(245,158,11,0.22);">
                        @Model.PendingTickets @Loc.Get("Pending")
                    </span>
                </div>
                <div class="ops-kpi-label mb-2">@Loc.Get("OpenWorkload")</div>
                <div class="display-6 fw-bold mb-2" style="color: var(--text-main) !important;">@Model.OpenTickets</div>
                <div class="small" style="color: var(--text-muted) !important;">@Loc.Get("ActiveTicketsSubtitle")</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card ops-card ops-metric border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div class="d-flex align-items-center justify-content-center rounded-4" style="width: 50px; height: 50px; background: rgba(59,130,246,0.12); color: #3b82f6;">
                        <i class="bi bi-check2-circle fs-4"></i>
                    </div>
                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid rgba(59,130,246,0.22);">
                        @Model.ResolutionRatePercent% @Loc.Get("Resolved")
                    </span>
                </div>
                <div class="ops-kpi-label mb-2">@Loc.Get("ResolvedClosed")</div>
                <div class="display-6 fw-bold mb-2" style="color: var(--text-main) !important;">@(Model.ResolvedTickets + Model.ClosedTickets)</div>
                <div class="small" style="color: var(--text-muted) !important;">@Loc.Get("WorkloadOutcomes")</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="card ops-card ops-metric border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-4">
                    <div class="d-flex align-items-center justify-content-center rounded-4" style="width: 50px; height: 50px; background: rgba(239,68,68,0.12); color: #ef4444;">
                        <i class="bi bi-exclamation-triangle-fill fs-4"></i>
                    </div>
                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.22);">
                        @Model.SlaRiskPercent% @Loc.Get("Risk")
                    </span>
                </div>
                <div class="ops-kpi-label mb-2">@Loc.Get("SlaBreaches")</div>
                <div class="display-6 fw-bold mb-2" style="color: var(--text-main) !important;">@Model.SlaBreachedTickets</div>
                <div class="small" style="color: var(--text-muted) !important;">@Loc.Get("SlaBreachSubtitle")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-8">
        <div class="card ops-card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 p-4 pb-0 d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="fw-bold mb-1" style="color: var(--text-main) !important;">@Loc.Get("IntakeTrend")</h5>
                    <p class="small mb-0" style="color: var(--text-muted) !important;">@Loc.Get("TrendSubtitle")</p>
                </div>
                <span class="badge rounded-pill px-3 py-2" style="background: rgba(255,255,255,0.05); color: var(--text-main); border: 1px solid var(--border-color);">
                    @Model.TicketsCreatedToday @Loc.Get("TodaySuffix")
                </span>
            </div>
            <div class="card-body p-4">
                <div style="height: 320px;">
                    <canvas id="weeklyVolumeChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card ops-card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 p-4 pb-0">
                <h5 class="fw-bold mb-1" style="color: var(--text-main) !important;">@Loc.Get("OperationalBalance")</h5>
                <p class="small mb-0" style="color: var(--text-muted) !important;">@Loc.Get("BalanceSubtitle")</p>
            </div>
            <div class="card-body p-4">
                <div style="height: 320px;">
                    <canvas id="statusBreakdownChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row g-4 mb-4">
    <div class="col-lg-4">
        <div class="card ops-card border-0 shadow-sm h-100">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <div class="ops-kpi-label mb-1">@Loc.Get("Escalations")</div>
                        <div class="fs-3 fw-bold" style="color: var(--text-main) !important;">@Model.EscalatedTickets</div>
                    </div>
                    <div class="d-flex align-items-center justify-content-center rounded-4" style="width: 48px; height: 48px; background: rgba(168,85,247,0.12); color: #a855f7;">
                        <i class="bi bi-diagram-3-fill fs-4"></i>
                    </div>
                </div>
                <div class="row g-3">
                    <div class="col-6">
                        <div class="ops-mini-stat p-3 h-100">
                            <div class="ops-kpi-label mb-2">@Loc.Get("HighPriority")</div>
                            <div class="fw-bold fs-4" style="color: var(--text-main) !important;">@Model.HighPriorityTickets</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="ops-mini-stat p-3 h-100">
                            <div class="ops-kpi-label mb-2">@Loc.Get("Closed")</div>
                            <div class="fw-bold fs-4" style="color: var(--text-main) !important;">@Model.ClosedTickets</div>
                        </div>
                    </div>
                </div>
                <div class="mt-4 small" style="color: var(--text-muted) !important;">
                    @Loc.Get("OperationalPressureNote")
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card ops-card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 p-4 pb-0">
                <h5 class="fw-bold mb-1" style="color: var(--text-main) !important;">@Loc.Get("TopProductAreas")</h5>
                <p class="small mb-0" style="color: var(--text-muted) !important;">@Loc.Get("ProductAreasSubtitle")</p>
            </div>
            <div class="card-body p-4">
                <div style="height: 280px;">
                    <canvas id="productAreaChart"></canvas>
                </div>
            </div>
        </div>
    </div>
    <div class="col-lg-4">
        <div class="card ops-card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent border-0 p-4 pb-0">
                <h5 class="fw-bold mb-1" style="color: var(--text-main) !important;">@Loc.Get("ChannelMix")</h5>
                <p class="small mb-0" style="color: var(--text-muted) !important;">@Loc.Get("ChannelMixSubtitle")</p>
            </div>
            <div class="card-body p-4">
                <div style="height: 280px;">
                    <canvas id="sourceBreakdownChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

<partial name="~/Views/Shared/Components/Tables/_FeatureTableShell.cshtml" model="recentTicketsTable" />

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const isRtl = @(Loc.IsRtl.ToString().ToLower());
        const statusData = @Html.Raw(Json.Serialize(Model.StatusBreakdown));
        const sourceData = @Html.Raw(Json.Serialize(Model.SourceBreakdown));
        const weeklyVolume = @Html.Raw(Json.Serialize(Model.WeeklyVolume));
        const productAreaData = @Html.Raw(Json.Serialize(Model.ProductAreas));

        const rootStyle = getComputedStyle(document.body);
        const primaryCol = rootStyle.getPropertyValue('--primary-color').trim();
        const mainText = rootStyle.getPropertyValue('--text-main').trim();
        const mutedText = rootStyle.getPropertyValue('--text-muted').trim();
        const borderCol = rootStyle.getPropertyValue('--border-color').trim();

        Chart.defaults.font.family = isRtl ? "'Noto Sans Arabic', sans-serif" : "'Outfit', sans-serif";
        Chart.defaults.color = mutedText;

        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            rtl: isRtl,
            plugins: {
                legend: {
                    rtl: isRtl,
                    labels: {
                        color: mainText,
                        usePointStyle: true,
                        padding: 18
                    }
                }
            },
            scales: {
                x: {
                    reverse: isRtl,
                    ticks: { color: mainText },
                    grid: { display: false }
                },
                y: {
                    position: isRtl ? 'right' : 'left',
                    beginAtZero: true,
                    ticks: { color: mutedText },
                    grid: { color: borderCol }
                }
            }
        };

        new Chart(document.getElementById('weeklyVolumeChart'), {
            type: 'line',
            data: {
                labels: weeklyVolume.map(item => item.label),
                datasets: [{
                    label: isRtl ? 'التذاكر المنشأة' : 'Tickets Created',
                    data: weeklyVolume.map(item => item.value),
                    borderColor: primaryCol,
                    backgroundColor: `${primaryCol}22`,
                    fill: true,
                    tension: 0.35,
                    pointBackgroundColor: primaryCol,
                    pointRadius: 4
                }]
            },
            options: commonOptions
        });

        new Chart(document.getElementById('statusBreakdownChart'), {
            type: 'doughnut',
            data: {
                labels: statusData.map(item => item.label),
                datasets: [{
                    data: statusData.map(item => item.value),
                    backgroundColor: [primaryCol, '#f59e0b', '#3b82f6', '#a855f7', '#10b981', '#71717a', '#ef4444'],
                    borderWidth: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                cutout: '72%',
                plugins: {
                    legend: {
                        position: 'bottom',
                        rtl: isRtl,
                        labels: {
                            color: mainText,
                            usePointStyle: true,
                            padding: 16
                        }
                    }
                }
            }
        });

        new Chart(document.getElementById('productAreaChart'), {
            type: 'bar',
            data: {
                labels: productAreaData.map(item => item.label),
                datasets: [{
                    label: isRtl ? 'التذاكر' : 'Tickets',
                    data: productAreaData.map(item => item.value),
                    backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#a855f7', '#ef4444'],
                    borderRadius: 10
                }]
            },
            options: {
                ...commonOptions,
                indexAxis: 'y'
            }
        });

        new Chart(document.getElementById('sourceBreakdownChart'), {
            type: 'polarArea',
            data: {
                labels: sourceData.map(item => item.label),
                datasets: [{
                    data: sourceData.map(item => item.value),
                    backgroundColor: ['#10b981', '#3b82f6', '#f59e0b', '#a855f7', '#ef4444']
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom',
                        rtl: isRtl,
                        labels: {
                            color: mainText,
                            usePointStyle: true,
                            padding: 16
                        }
                    }
                },
                scales: {
                    r: {
                        grid: { color: borderCol },
                        ticks: { display: false }
                    }
                }
            }
        });
    </script>
}
