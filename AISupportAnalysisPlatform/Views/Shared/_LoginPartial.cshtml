@using Microsoft.AspNetCore.Identity
@using AISupportAnalysisPlatform.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav d-flex flex-row align-items-center m-0 p-0 overflow-visible">
@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);
        <li class="nav-item d-flex align-items-center @(Loc.IsRtl ? "ms-3" : "me-3")">
            @if (User.IsInRole("Admin") || User.IsInRole("SupportAgent"))
            {
                <span class="badge bg-primary-subtle text-primary border border-primary-subtle px-3 py-2 rounded-pill small fw-bold @(Loc.IsRtl ? "ms-2" : "me-2")">
                    <i class="bi bi-shield-check @(Loc.IsRtl ? "ms-1" : "me-1")"></i>
                @if (User.IsInRole("Admin")) { <text>@Loc.Get("SuperAdmin")</text> }
                else if (User.IsInRole("SupportAgent")) { <text>@Loc.Get("TechnicalLead")</text> }
            </span>
        }
        <a class="nav-link text-decoration-none d-flex align-items-center p-2 rounded-3 hover-bg-light" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage Identity">
            <div class="avatar-sm bg-primary-subtle text-primary rounded-circle d-flex align-items-center justify-content-center fw-bold @(Loc.IsRtl ? "ms-2" : "me-2")" style="width: 32px; height: 32px; font-size: 0.8rem;">
                @(!string.IsNullOrEmpty(user?.FirstName) ? user.FirstName[0] : (!string.IsNullOrEmpty(User.Identity?.Name) ? User.Identity.Name[0] : 'U'))
            </div>
            <span class="small fw-bold text-nowrap">@Loc.Get("Hello") @(user?.FirstName ?? User.Identity?.Name)!</span>
        </a>
    </li>
    <li class="nav-item d-flex align-items-center @(Loc.IsRtl ? "me-2" : "ms-2")">
        <form class="form-inline m-0 p-0" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Dashboard", new { area = "" })">
            <button type="submit" class="btn btn-light-danger btn-sm rounded-pill px-3 shadow-none border-0 d-flex align-items-center text-nowrap">
                <i class="bi bi-power @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("Logout")
            </button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="btn btn-outline-primary btn-sm rounded-pill px-3 @(Loc.IsRtl ? "ms-2" : "me-2")" asp-area="Identity" asp-page="/Account/Register">
            <i class="bi bi-person-plus-fill @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("Register")
        </a>
    </li>
    <li class="nav-item">
        <a class="btn btn-primary btn-sm rounded-pill px-4 shadow-sm" asp-area="Identity" asp-page="/Account/Login">
            <i class="bi bi-box-arrow-in-right @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("Login")
        </a>
    </li>
}
</ul>
