@model IEnumerable<AISupportAnalysisPlatform.ViewComponents.BreadcrumbItem>
@inject AISupportAnalysisPlatform.Services.Infrastructure.ILocalizationService Loc

<nav aria-label="breadcrumb" class="px-4 py-1 d-none d-lg-block" style="background: transparent;">
    <ol class="breadcrumb mb-0">
        @foreach (var item in Model)
        {
            if (item.Url != null)
            {
                <li class="breadcrumb-item d-flex align-items-center">
                    @if (item.Icon != null)
                    {
                        <i class="bi @item.Icon @(Loc.IsRtl ? "ms-2" : "me-2") text-primary opacity-75"></i>
                    }
                    <a href="@item.Url" class="text-decoration-none text-muted small fw-bold hover-primary">@Loc.Get(item.Title)</a>
                </li>
            }
            else
            {
                <li class="breadcrumb-item active d-flex align-items-center small fw-bold text-main opacity-50" aria-current="page">@Loc.Get(item.Title)</li>
            }
        }
    </ol>
</nav>
