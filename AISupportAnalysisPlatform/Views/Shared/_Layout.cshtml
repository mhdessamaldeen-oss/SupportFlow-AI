@using Microsoft.AspNetCore.Identity
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject AISupportAnalysisPlatform.Data.ApplicationDbContext DbContext

@{
    var themeSetting = DbContext.SystemSettings.FirstOrDefault(s => s.Key == "DefaultTheme");
    int currentId = 1;
    if (int.TryParse(themeSetting?.Value, out int tid)) { currentId = tid; }

    var theme = DbContext.CustomThemes.FirstOrDefault(t => t.Id == currentId) 
                  ?? DbContext.CustomThemes.FirstOrDefault(t => t.IsSystemTheme)
                   ?? new CustomTheme(); 

    // Extract RGB components for transparency support
    string primaryRgb = "99, 102, 241"; // Default
    try {
        var c = System.Drawing.ColorTranslator.FromHtml(theme.PrimaryColor);
        primaryRgb = $"{c.R}, {c.G}, {c.B}";
    } catch {}

    var themeStyles = $@"
        --primary-color: {theme.PrimaryColor}; 
        --primary-color-rgb: {primaryRgb};
        --bg-main: {theme.BgMain}; 
        --bg-card: {theme.BgCard}; 
        --bg-sidebar: {theme.BgSidebar};
        --bg-header: {theme.BgHeader};
        --text-main: {theme.TextMain};
        --text-muted: {theme.TextMuted};
        --border-color: {theme.BorderColor};
        --primary-gradient: linear-gradient(135deg, {theme.PrimaryColor} 0%, {theme.PrimaryColor}CC 100%);";
}

<!DOCTYPE html>
<html lang="@Loc.CurrentLanguage" dir="@Loc.Direction">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - SupportFlow AI</title>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Noto+Sans+Arabic:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    @if (Loc.IsRtl)
    {
        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.rtl.min.css">
    }
    else
    {
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    }
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/platform-ui.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/status-badge-colors.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/theme-utilities.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <link rel="stylesheet" href="https://cdn.datatables.net/2.0.3/css/dataTables.bootstrap5.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/responsive/3.0.1/css/responsive.bootstrap5.css">
    <link rel="stylesheet" href="https://cdn.datatables.net/buttons/3.0.1/css/buttons.bootstrap5.css">
    
    <style>
        :root { @Html.Raw(themeStyles) }
        @if (Loc.IsRtl) { <text>body { font-family: 'Noto Sans Arabic', sans-serif !important; }</text> }
    </style>
    @await RenderSectionAsync("Styles", required: false)

</head>
<body class="sf-body @(Loc.IsRtl ? "rtl-mode" : "")">
    <nav class="sf-sidebar">
        <div class="sidebar-brand">
            <div class="icon-shape @(Loc.IsRtl ? "ms-3" : "me-3")" style="width: 36px; height: 36px; border-radius: 8px; background: var(--primary-color); display: flex; align-items: center; justify-content: center; box-shadow: 0 0 15px rgba(var(--primary-color-rgb), 0.2);">
                <i class="bi bi-terminal-fill fs-5 text-white"></i>
            </div>
            <span style="color: var(--text-main); letter-spacing: -1px; font-weight: 900;">Support<span style="color: var(--primary-color);">Flow</span></span>
        </div>
        <ul class="sidebar-menu">
            <li>
                <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")" asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-grid-1x2-fill @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("Dashboard")
                </a>
            </li>
            <li>
                <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Tickets" ? "active" : "")" asp-controller="Tickets" asp-action="Index">
                    <i class="bi bi-ticket-detailed-fill @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("Tickets")
                </a>
            </li>
            @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
            {
                <li>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AiAnalysis" && ViewContext.RouteData.Values["Action"]?.ToString() == "Hub" ? "active" : "")" asp-controller="AiAnalysis" asp-action="Hub">
                        <i class="bi bi-cpu-fill @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("AnalysisHub")
                    </a>
                </li>
                <li>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AiAnalysis" && ViewContext.RouteData.Values["Action"]?.ToString() == "Benchmark" ? "active" : "")" asp-controller="AiAnalysis" asp-action="Benchmark">
                        <i class="bi bi-speedometer2 @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("RetrievalBenchmark")
                    </a>
                </li>
                <li>
                    <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "AiInsights" ? "active" : "")" asp-controller="AiInsights" asp-action="Index">
                        <i class="bi bi-lightbulb-fill @(Loc.IsRtl ? "ms-3" : "me-3") text-warning"></i>@Loc.Get("Insights")
                    </a>
                </li>
            }
            <li>
                <a class="sidebar-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Reports" ? "active" : "")" asp-controller="Reports" asp-action="Index">
                    <i class="bi bi-bar-chart-fill @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("Reports")
                </a>
            </li>
            @if (SignInManager.IsSignedIn(User) && User.IsInRole("Admin"))
            {
                <li class="sidebar-heading mt-4 @(Loc.IsRtl ? "me-4" : "ms-4") text-uppercase text-muted small" style="font-weight: 800; letter-spacing: 1px;">@Loc.Get("Administration")</li>
                <li><a class="sidebar-link" asp-controller="Users" asp-action="Index"><i class="bi bi-people-fill @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("Users")</a></li>
                <li><a class="sidebar-link" asp-controller="Entities" asp-action="Index"><i class="bi bi-building-fill-gear @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("Entities")</a></li>
                <li><a class="sidebar-link" asp-controller="ReferenceData" asp-action="Index"><i class="bi bi-database-fill @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("ReferenceData")</a></li>
                <li><a class="sidebar-link" asp-controller="Settings" asp-action="Index"><i class="bi bi-gear-wide-connected @(Loc.IsRtl ? "ms-3" : "me-3")"></i>@Loc.Get("Settings")</a></li>
            }
        </ul>
    </nav>

    <div class="sf-wrapper">
        <header class="sf-header sticky-top">
            <div class="container-fluid px-3 h-100 d-flex align-items-center justify-content-between flex-nowrap">
                <div class="d-flex align-items-center gap-4 flex-nowrap">
                    <div class="header-titles text-nowrap">
                        <div class="d-flex align-items-center gap-2">
                             <span class="mb-0 fw-bold" style="color: var(--text-main); font-size: 0.95rem;">@ViewData["Title"]</span>
                             <span class="text-muted" style="opacity: 0.3;">|</span>
                             <span class="fw-semibold small" style="color: var(--primary-color);">@Loc.Get("WorkspaceTitle")</span>
                        </div>
                    </div>
                </div>

                <div class="d-flex align-items-center gap-3 flex-nowrap ms-auto">
                    <div class="dropdown">
                        <button class="btn btn-sm btn-lang-switcher rounded-pill px-3 py-1 dropdown-toggle shadow-none text-nowrap" type="button" data-bs-toggle="dropdown">
                            <i class="bi bi-translate @(Loc.IsRtl ? "ms-2" : "me-2")" style="color: var(--primary-color);"></i>@(Loc.IsRtl ? "AR" : "EN")
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0" style="background: var(--bg-card); min-width: 140px;">
                            <li><a class="dropdown-item text-main py-2" href="javascript:void(0)" onclick="changeLanguage('en')">English @(Loc.CurrentLanguage == "en" ? "✓" : "")</a></li>
                            <li><a class="dropdown-item text-main py-2" href="javascript:void(0)" onclick="changeLanguage('ar')">العربية @(Loc.CurrentLanguage == "ar" ? "✓" : "")</a></li>
                        </ul>
                    </div>
                    @if (SignInManager.IsSignedIn(User)) { @await Component.InvokeAsync("NotificationCount") }
                    <partial name="_LoginPartial" />
                </div>
            </div>
        </header>

        @if (ViewData["HideBreadcrumbs"] is not true)
        {
            @await Component.InvokeAsync("Breadcrumbs")
        }
        <main role="main">@RenderBody()</main>

        <footer class="footer text-muted py-4 mt-auto">
            <div class="container-fluid px-4 @(Loc.IsRtl ? "text-end" : "text-start")">
                <div class="row align-items-center justify-content-between">
                    <div class="col-auto">&copy; 2026 - <span class="fw-bold">SupportFlow AI</span></div>
                    <div class="col-auto small text-muted">v2.1.0-PREMIUM</div>
                </div>
            </div>
        </footer>
    </div>

    <form id="selectLanguage" asp-controller="Home" asp-action="SetLanguage" method="post" class="d-none">
        <input type="hidden" name="culture" id="lang-input" />
        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
    </form>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.js"></script>
    <script src="https://cdn.datatables.net/2.0.3/js/dataTables.bootstrap5.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/app-localization.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
