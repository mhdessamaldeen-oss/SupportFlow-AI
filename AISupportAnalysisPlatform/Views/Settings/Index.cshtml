    .theme-card:hover { transform: translateY(-3px); }
    .active-theme { border: 2px solid var(--primary-color) !important; filter: brightness(1.1); box-shadow: 0 0 15px rgba(var(--primary-color-rgb), 0.2) !important; }
    .theme-preview { transition: all 0.5s ease; }
    .form-control-color { height: 45px; cursor: pointer; padding: 4px; }
    .ls-1 { letter-spacing: 1.5px; }

    /* Settings Tab Buttons */
