@model List<AISupportAnalysisPlatform.Models.CustomTheme>
@{
    ViewData["Title"] = "Global Configuration";
    var currentThemeId = ViewBag.CurrentThemeId as string ?? "1";
    var activeTab = ViewBag.ActiveTab as string ?? "themes";
    var activeProvider = ViewBag.DbActiveProvider as AiProviderType? ?? AiProviderType.DockerLocal;
    var currentProviderLabel = activeProvider switch
    {
        AiProviderType.OpenAI => "OpenAI / ChatGPT",
        AiProviderType.Cloud => "Cloud AI",
        AiProviderType.Gemini => "Google Gemini",
        AiProviderType.LocalAI => "LocalAI",
        _ => "Docker Engine"
    };
    var sqlServerCandidates = ViewBag.SqlServerCandidates as List<AISupportAnalysisPlatform.Controllers.Admin.SettingsController.SqlServerCandidateInfo> ?? new();
    var sqlServerProbe = ViewBag.SqlServerProbe as AISupportAnalysisPlatform.Controllers.Admin.SettingsController.SqlServerProbeResult;
    var dbServerName = ViewBag.DbServerName as string ?? "";
    var dbDatabaseName = ViewBag.DbDatabaseName as string ?? "";
    var dbUserName = ViewBag.DbUserName as string ?? "";
    var useSqlAuthentication = ViewBag.DbUseSqlAuthentication is bool useSqlAuth && useSqlAuth;
    var trustServerCertificate = ViewBag.DbTrustServerCertificate is bool trustServerCert ? trustServerCert : true;
    var encryptConnection = ViewBag.DbEncryptConnection is bool encryptConn && encryptConn;
}

<div class="row mb-4 animate__animated animate__fadeIn">
    <div class="col-lg-8">
        <h2 class="fw-bold mb-1">Global Configuration</h2>
        <p class="text-muted small">Platform settings, AI provider management, and visual identity orchestration</p>
    </div>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show mb-4 animate__animated animate__fadeInDown" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["Success"]
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="@Loc.Get("Close")"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm alert-dismissible fade show mb-4 animate__animated animate__fadeInDown" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="@Loc.Get("Close")"></button>
    </div>
}

<!-- ═══════════════ PRIMARY TABS ═══════════════ -->
<ul class="nav nav-pills mb-4 gap-2" id="settingsTabs" role="tablist">
    <li class="nav-item" role="presentation">
        <button class="nav-link settings-tab-btn @(activeTab == "themes" ? "active" : "")" data-bs-toggle="pill" data-bs-target="#tab-themes" type="button" role="tab">
            <i class="bi bi-palette-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("ThemeEngine")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link settings-tab-btn @(activeTab == "ai" ? "active" : "")" data-bs-toggle="pill" data-bs-target="#tab-ai" type="button" role="tab">
            <i class="bi bi-cpu-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("AiProviderConfig")
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link settings-tab-btn @(activeTab == "chatbot" ? "active" : "")" data-bs-toggle="pill" data-bs-target="#tab-chatbot" type="button" role="tab">
            <i class="bi bi-robot @(Loc.IsRtl ? "ms-2" : "me-2")"></i>Chatbot AI
        </button>
    </li>
    <li class="nav-item" role="presentation">
        <button class="nav-link settings-tab-btn @(activeTab == "data" ? "active" : "")" data-bs-toggle="pill" data-bs-target="#tab-data" type="button" role="tab">
            <i class="bi bi-database-fill-gear @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("DataTab")
        </button>
    </li>
</ul>

<div class="tab-content" id="settingsTabContent">

<!-- ═══════════════ THEMES TAB ═══════════════ -->
<div class="tab-pane fade @(activeTab == "themes" ? "show active" : "")" id="tab-themes" role="tabpanel">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg mb-5">
                <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-uppercase small ls-1 text-muted">Identity Repository</h5>
                        <p class="text-muted small mb-0">Select or refine foundational visual signatures</p>
                    </div>
                    <button class="btn btn-primary btn-pill shadow-sm" onclick="openArchitect('new')">
                        <i class="bi bi-plus-lg me-2"></i>Create New Architecture
                    </button>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3">
                        @foreach (var theme in Model)
                        {
                            <div class="col-md-6 col-xl-4">
                                <div class="theme-card card h-100 border-0 shadow-sm transition-all @(currentThemeId == theme.Id.ToString() ? "active-theme" : "")" 
                                     style="background: @theme.BgCard !important; border: 1px solid @theme.BorderColor !important;">
                                    <div class="card-body p-3 text-center">
                                        <div class="theme-preview mb-3 rounded-3 shadow-md mx-auto" 
                                             style="background: @theme.BgMain; border: 2px solid @theme.PrimaryColor; width: 100px; height: 60px; position: relative; overflow: hidden;">
                                            <div style="position: absolute; top: 6px; inset-inline-start: 6px; width: 20px; height: 3px; background: @theme.PrimaryColor; border-radius: 1px;"></div>
                                            <div style="position: absolute; top: 12px; inset-inline-start: 6px; width: 10px; height: 3px; background: @theme.TextMuted; border-radius: 1px;"></div>
                                            <div style="position: absolute; bottom: 10px; inset-inline-end: 10px; width: 20px; height: 20px; background: @theme.PrimaryColor; border-radius: 4px; opacity: 0.2;"></div>
                                        </div>
                                        <h6 class="fw-bold mb-2" style="color: @theme.TextMain">@theme.Name</h6>
                                        <div class="d-flex gap-1 justify-content-center mb-3">
                                            <form asp-action="UpdateTheme" method="post">
                                                <input type="hidden" name="themeId" value="@theme.Id" />
                                                @if (currentThemeId == theme.Id.ToString())
                                                {
                                                    <button type="button" class="btn btn-success btn-sm fw-bold px-3 disabled">Active</button>
                                                }
                                                else
                                                {
                                                    <button type="submit" class="btn btn-outline-primary btn-sm fw-bold px-3" style="border-color: @theme.PrimaryColor; color: @theme.PrimaryColor">Apply</button>
                                                }
                                            </form>
                                            <button class="btn btn-outline-secondary btn-sm fw-bold px-2 refine-btn" 
                                                    data-theme-id="@theme.Id"
                                                    data-theme-name="@theme.Name"
                                                    data-theme-primary="@theme.PrimaryColor"
                                                    data-theme-bgmain="@theme.BgMain"
                                                    data-theme-bgcard="@theme.BgCard"
                                                    data-theme-bgsidebar="@theme.BgSidebar"
                                                    data-theme-bgheader="@theme.BgHeader"
                                                    data-theme-textmain="@theme.TextMain"
                                                    data-theme-textmuted="@theme.TextMuted"
                                                    data-theme-border="@theme.BorderColor"
                                                    data-theme-issystem="@theme.IsSystemTheme.ToString().ToLower()"
                                                    data-theme-sysid="@theme.SystemIdentifier"
                                                    onclick="openArchitect(this)">
                                                <i class="bi bi-pencil-square"></i>
                                            </button>
                                            @if (theme.IsSystemTheme)
                                            {
                                                <form asp-action="ResetTheme" method="post" class="d-inline">
                                                    <input type="hidden" name="id" value="@theme.Id" />
                                                    <button type="submit" class="btn btn-outline-warning btn-sm fw-bold px-2" title="Reset to Factory Directive">
                                                        <i class="bi bi-arrow-counterclockwise"></i>
                                                    </button>
                                                </form>
                                            }
                                            else
                                            {
                                                <form asp-action="DeleteTheme" method="post" class="d-inline" onsubmit="return confirm('Confirm categorical purge of this architecture?');">
                                                    <input type="hidden" name="id" value="@theme.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm fw-bold px-2" title="Purge Architecture">
                                                        <i class="bi bi-trash3-fill"></i>
                                                    </button>
                                                </form>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
        <!-- Architect Studio Panel -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg sticky-top" style="top: 100px;">
                <div class="card-header border-0 pt-4 px-4 bg-transparent">
                    <h5 class="fw-bold mb-0 text-uppercase small ls-1 text-muted" id="studio-title">Architect Studio</h5>
                    <p class="text-muted small">Surgically refine platform identity tokens</p>
                </div>
                <div class="card-body p-4 pt-0">
                    <form id="architectForm" asp-action="SaveTheme" method="post">
                        <input type="hidden" id="theme-id" name="Id" value="0" />
                        <input type="hidden" name="IsSystemTheme" id="theme-issystem" value="false" />
                        <input type="hidden" name="SystemIdentifier" id="theme-sysid" value="" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">Architecture Name</label>
                            <input type="text" class="form-control bg-transparent shadow-none" style="border-color: var(--border-color) !important; color: var(--text-main) !important;" id="theme-name" name="Name" required />
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Primary Accent</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-primary" name="PrimaryColor" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Main Background</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgmain" name="BgMain" />
                            </div>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Card Surface</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgcard" name="BgCard" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Sidebar Surface</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgsidebar" name="BgSidebar" />
                            </div>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Header Surface</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-bgheader" name="BgHeader" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Border Token</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-border" name="BorderColor" />
                            </div>
                        </div>
                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Primary Text</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-textmain" name="TextMain" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Muted Text</label>
                                <input type="color" class="form-control form-control-color w-100 bg-transparent" style="border-color: var(--border-color) !important;" id="theme-textmuted" name="TextMuted" />
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary w-100 shadow-sm">
                            <i class="bi bi-cpu-fill me-2"></i>Apply Architectural Change
                        </button>
                        <button type="button" class="btn btn-outline-secondary w-100 mt-2" onclick="openArchitect('new')">
                            Clear Editor
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════ AI PROVIDER TAB ═══════════════ -->
<div class="tab-pane fade @(activeTab == "ai" ? "show active" : "")" id="tab-ai" role="tabpanel">

    <div class="ai-config-shell">
        <div class="ai-config-hero card border-0 shadow-lg mb-4 overflow-hidden">
            <div class="card-body p-4 p-xl-5">
                <div class="row g-4 align-items-start">
                    <div class="col-xl-7">
                        <div class="d-inline-flex align-items-center gap-2 ai-config-eyebrow mb-3">
                            <span class="ai-config-dot"></span>
                            <span>AI Configuration Console</span>
                        </div>
                        <h4 class="fw-bold mb-2">Configure providers, models, and runtime behavior from one control surface.</h4>
                        <p class="text-muted mb-0">Connection details, model names, and advanced execution parameters are managed from the app UI and stored in the database instead of application setting files.</p>
                    </div>
                    <div class="col-xl-5">
                        <div class="ai-config-summary">
                            <div class="ai-summary-tile">
                                <div class="ai-summary-label">Active provider</div>
                                <div class="ai-summary-value">@currentProviderLabel</div>
                            </div>
                            <div class="ai-summary-tile">
                                <div class="ai-summary-label">Configuration source</div>
                                <div class="ai-summary-value">Database-backed</div>
                            </div>
                            <div class="ai-summary-tile">
                                <div class="ai-summary-label">Admin workflow</div>
                                <div class="ai-summary-value">Configure, validate, then activate</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="ai-provider-switch mt-4">
                    <div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-3">
                        <div>
                            <h5 class="fw-bold mb-1"><i class="bi bi-broadcast-pin me-2" style="color: var(--primary-color);"></i>Provider Workspace</h5>
                            <p class="text-muted small mb-0">Select the provider you want to configure, validate, or make active.</p>
                        </div>
                        <span class="ai-config-badge">
                            <i class="bi bi-shield-lock me-2"></i>Secrets are stored in system settings
                        </span>
                    </div>
                    <ul class="nav nav-pills gap-2 flex-wrap" id="providerTabs" role="tablist">
                        <li class="nav-item" role="presentation">
                            <button class="btn provider-selector-btn @(activeProvider == AiProviderType.DockerLocal ? "active" : "")" data-bs-toggle="tab" data-bs-target="#provider-docker" type="button" role="tab">
                                <i class="bi bi-hdd-network-fill me-2 fs-5"></i><span>Docker Engine</span>
                                @if (activeProvider == AiProviderType.DockerLocal) { <span class="badge bg-light text-dark ms-2 smaller">Active</span> }
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="btn provider-selector-btn @(activeProvider == AiProviderType.OpenAI ? "active" : "")" data-bs-toggle="tab" data-bs-target="#provider-openai" type="button" role="tab">
                                <i class="bi bi-cpu me-2 fs-5"></i><span>OpenAI / ChatGPT</span>
                                @if (activeProvider == AiProviderType.OpenAI) { <span class="badge bg-light text-dark ms-2 smaller">Active</span> }
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="btn provider-selector-btn @(activeProvider == AiProviderType.Cloud ? "active" : "")" data-bs-toggle="tab" data-bs-target="#provider-cloud" type="button" role="tab">
                                <i class="bi bi-cloud-check-fill me-2 fs-5"></i><span>Cloud AI</span>
                                @if (activeProvider == AiProviderType.Cloud) { <span class="badge bg-light text-dark ms-2 smaller">Active</span> }
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="btn provider-selector-btn @(activeProvider == AiProviderType.Gemini ? "active" : "")" data-bs-toggle="tab" data-bs-target="#provider-gemini" type="button" role="tab">
                                <i class="bi bi-stars me-2 fs-5"></i><span>Google Gemini</span>
                                @if (activeProvider == AiProviderType.Gemini) { <span class="badge bg-light text-dark ms-2 smaller">Active</span> }
                            </button>
                        </li>
                        <li class="nav-item" role="presentation">
                            <button class="btn provider-selector-btn @(activeProvider == AiProviderType.LocalAI ? "active" : "")" data-bs-toggle="tab" data-bs-target="#provider-localai" type="button" role="tab">
                                <i class="bi bi-diagram-2-fill me-2 fs-5"></i><span>LocalAI</span>
                                @if (activeProvider == AiProviderType.LocalAI) { <span class="badge bg-light text-dark ms-2 smaller">Active</span> }
                            </button>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="tab-content" id="providerTabContent">
        
        <!-- ──── DIRECT DOCKER ENGINE TAB ──── -->
        <div class="tab-pane fade @(activeProvider == AiProviderType.DockerLocal ? "show active" : "")" id="provider-docker" role="tabpanel">
            <div class="card border-0 shadow-lg border-top-0 rounded-top-0">
                <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-uppercase small ls-1 text-muted">Direct Docker Engine</h5>
                        <p class="text-muted small mb-0">Manage local standalone AI containers</p>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <span class="badge bg-success-soft text-success border border-success-subtle px-3 py-2 rounded-pill">
                            <i class="bi bi-broadcast me-2"></i>Docker Daemon
                        </span>
                        <button class="btn btn-outline-secondary btn-sm" onclick="validateProvider('DockerLocal', this)">
                            <i class="bi bi-wifi me-1"></i>Test
                        </button>
                        @if (activeProvider != AiProviderType.DockerLocal)
                        {
                            <form asp-action="SetActiveProvider" method="post" class="m-0">
                                <input type="hidden" name="providerType" value="DockerLocal" />
                                <button type="submit" class="btn btn-primary btn-sm shadow-sm">
                                    <i class="bi bi-check-circle me-1"></i>Set as Active
                                </button>
                            </form>
                        }
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="SaveDockerLocalConfig" method="post">
                        <div class="row g-4 mb-4">
                            <div class="col-lg-12">
                                <h6 class="fw-bold mb-3"><i class="bi bi-gear-fill me-2" style="color: var(--primary-color);"></i>Engine Parameters</h6>
                                <div class="row g-3">
                                    <div class="col-12">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Base URL</label>
                                        <input type="text" class="form-control bg-transparent shadow-none" name="baseUrl" value="@ViewBag.DbDockerBaseUrl" placeholder="DOCKER_NATIVE or custom URL" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-12">
                                        <div class="rounded-3 px-3 py-2 small" style="background: rgba(15, 23, 42, 0.03) !important; border: 1px solid rgba(148, 163, 184, 0.18) !important; color: var(--text-muted) !important;">
                                            <i class="bi bi-info-circle me-2"></i>Default model selection is managed below from <strong>Installed Models</strong>. The engine form only stores runtime parameters.
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Timeout (Sec)</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="timeoutSeconds" value="@ViewBag.DbDockerTimeoutSeconds" min="5" max="600" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Temperature</label>
                                        <input type="number" step="0.1" class="form-control bg-transparent shadow-none" name="temperature" value="@ViewBag.DbDockerTemperature" min="0" max="2" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Max Prompt Chars</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="maxPromptChars" value="@ViewBag.DbDockerMaxPromptChars" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Max Prompt Tokens</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="maxPromptTokens" value="@ViewBag.DbDockerMaxPromptTokens" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Ctx Size (NumCtx)</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="numCtx" value="@ViewBag.DbDockerNumCtx" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Num Predict</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="numPredict" value="@ViewBag.DbDockerNumPredict" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-end mt-3">
                                    <button type="submit" class="btn btn-primary shadow-sm">
                                        <i class="bi bi-save me-2"></i>Save Engine Configuration
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                    <hr style="border-color: var(--border-color) !important;" class="my-4">
                    <div class="row g-4 mb-4">
                        <div class="col-lg-8">
                            <div class="mb-3 d-flex justify-content-between align-items-center">
                                <div>
                                    <label class="form-label small fw-bold text-muted text-uppercase ls-1 mb-0">Installed Models</label>
                                    <div class="small mt-1" style="color: var(--text-muted) !important;">Choose one installed Docker Model as the runtime default. This list is read from Docker Models, not generic container images.</div>
                                </div>
                                <button class="btn btn-link btn-sm text-decoration-none shadow-none p-0" onclick="loadModels()">
                                    <i class="bi bi-arrow-clockwise me-1"></i>Refresh Repository
                                </button>
                            </div>
                            <div id="models-container" class="row g-3">
                                <div class="col-12 text-center py-5">
                                    <div class="spinner-border text-primary" role="status"><span class="visually-hidden">Loading...</span></div>
                                    <p class="text-muted small mt-2">Connecting to Docker Engine...</p>
                                </div>
                            </div>
                        </div>
                        <div class="col-lg-4 border-start" style="border-color: var(--border-color) !important;">
                            <label class="form-label small fw-bold text-uppercase ls-1" style="color: var(--text-muted) !important;">Provision New Model</label>
