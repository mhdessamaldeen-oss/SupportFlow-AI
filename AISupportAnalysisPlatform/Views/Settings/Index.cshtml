    .ai-config-eyebrow { font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.16em; color: var(--primary-color) !important; }
    .ai-config-dot { width: 10px; height: 10px; border-radius: 50%; background: linear-gradient(135deg, var(--primary-color), #22c55e); box-shadow: 0 0 0 6px rgba(var(--primary-color-rgb), 0.12); }
