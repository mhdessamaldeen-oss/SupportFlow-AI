    .ai-summary-value { font-size: 1rem; font-weight: 700; color: var(--text-main) !important; }
    .ai-provider-switch { border-top: 1px solid rgba(148, 163, 184, 0.14); padding-top: 24px; }
    .ai-config-badge { display: inline-flex; align-items: center; padding: 10px 14px; border-radius: 999px; border: 1px solid rgba(148, 163, 184, 0.2); background: rgba(255,255,255,0.7); color: var(--text-main) !important; font-size: 0.86rem; font-weight: 600; }

    #tab-ai #providerTabContent > .tab-pane > .card {
        border: 1px solid rgba(148, 163, 184, 0.18) !important;
