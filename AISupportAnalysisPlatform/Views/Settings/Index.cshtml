@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            loadModels();
        });

        function openToolEditor(obj) {
            const form = document.getElementById('toolEditorForm');
            const titleEl = document.getElementById('tool-editor-title');
            
            if (obj === 'new') {
                titleEl.innerText = 'Tool Architect';
                form.reset();
                document.getElementById('tool-id').value = '0';
                document.getElementById('tool-enabled').value = 'true';
                toggleUrlField('External');
            } else {
                titleEl.innerText = 'Refine Capability';
                const btn = obj;
                document.getElementById('tool-id').value = btn.getAttribute('data-tool-id');
                document.getElementById('tool-title').value = btn.getAttribute('data-tool-title');
                document.getElementById('tool-desc').value = btn.getAttribute('data-tool-desc');
                document.getElementById('tool-key').value = btn.getAttribute('data-tool-key');
                document.getElementById('tool-mode').value = btn.getAttribute('data-tool-mode');
                document.getElementById('tool-type').value = btn.getAttribute('data-tool-type');
                document.getElementById('tool-url').value = btn.getAttribute('data-tool-url');
                document.getElementById('tool-test-prompt').value = btn.getAttribute('data-tool-test-prompt') || '';
                document.getElementById('tool-enabled').value = btn.getAttribute('data-tool-enabled');
                toggleUrlField(btn.getAttribute('data-tool-type'));
            }
        }

        function toggleUrlField(type) {
            const container = document.getElementById('url-field-container');
            if (type === 'Internal') {
                container?.classList.add('d-none');
            } else {
                container?.classList.remove('d-none');
            }
        }

        function openArchitect(element) {
            const title = document.getElementById('studio-title');
            if (element === 'new') {
                title.innerText = 'Establish New Architecture';
                document.getElementById('theme-id').value = 0;
                document.getElementById('theme-name').value = 'Custom Identity';
                document.getElementById('theme-primary').value = '#10b981';
                document.getElementById('theme-bgmain').value = '#f1f5f9';
                document.getElementById('theme-bgcard').value = '#ffffff';
                document.getElementById('theme-bgsidebar').value = '#ffffff';
                document.getElementById('theme-bgheader').value = '#ffffff';
                document.getElementById('theme-textmain').value = '#1e293b';
                document.getElementById('theme-textmuted').value = '#64748b';
                document.getElementById('theme-border').value = '#e2e8f0';
                document.getElementById('theme-issystem').value = "false";
                document.getElementById('theme-sysid').value = "";
            } else {
                const theme = element.dataset;
                title.innerText = `Refine: ${theme.themeName}`;
                document.getElementById('theme-id').value = theme.themeId;
                document.getElementById('theme-name').value = theme.themeName;
                document.getElementById('theme-primary').value = theme.themePrimary;
                document.getElementById('theme-bgmain').value = theme.themeBgmain;
                document.getElementById('theme-bgcard').value = theme.themeBgcard;
                document.getElementById('theme-bgsidebar').value = theme.themeBgsidebar;
                document.getElementById('theme-bgheader').value = theme.themeBgheader;
                document.getElementById('theme-textmain').value = theme.themeTextmain;
                document.getElementById('theme-textmuted').value = theme.themeTextmuted;
                document.getElementById('theme-border').value = theme.themeBorder;
                document.getElementById('theme-issystem').value = theme.themeIssystem;
                document.getElementById('theme-sysid').value = theme.themeSysid || '';
                document.getElementById('theme-name').focus();
            }
        }

        function togglePassword(inputId, btn) {
            const input = document.getElementById(inputId);
            if (input.type === 'password') {
                input.type = 'text';
                btn.innerHTML = '<i class="bi bi-eye-slash"></i>';
            } else {
                input.type = 'password';
                btn.innerHTML = '<i class="bi bi-eye"></i>';
            }
        }

        function validateProvider(type, btn) {
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span>...';
            btn.disabled = true;
            fetch(`/Settings/ValidateProvider?providerType=${type}`)
                .then(r => r.json())
                .then(data => {
                    btn.innerHTML = data.success ? '<i class="bi bi-check-circle"></i>' : '<i class="bi bi-x-circle"></i>';
                    setTimeout(() => { btn.innerHTML = originalHtml; btn.disabled = false; }, 3000);
                });
        }

        function loadModels() {
            const container = document.getElementById('models-container');
            if (!container) return;
            fetch('/Settings/GetDockerModels').then(r => r.json()).then(data => {
                if (!data.success) { container.innerHTML = `<p class="text-muted small">${data.error}</p>`; return; }
                container.innerHTML = '';
                data.models.forEach(model => {
                    const isActive = model.name === data.activeModel;
                    container.innerHTML += `<div class="col-md-4 mb-3"><div class="card p-3 ${isActive?'border-primary':''}"><h6>${model.name}</h6><button onclick="setDockerDefaultModel('${model.name}')" class="btn btn-sm btn-primary" ${isActive?'disabled':''}>${isActive?'Active':'Set Default'}</button></div></div>`;
                });
            });
        }

        function setDockerDefaultModel(modelName) {
            fetch('/Settings/SetDockerDefaultModel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ modelName })
            }).then(r => r.json()).then(data => { if (data.success) loadModels(); });
        }

        function deleteModel(modelName) {
            if (!confirm('Delete?')) return;
            fetch('/Settings/DeleteDockerModel', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ modelName })
            }).then(r => r.json()).then(data => { if (data.success) loadModels(); });
        }

        function pullModel() {
            const modelName = document.getElementById('new-model-name').value;
            fetch('/Settings/PullDockerModel', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ modelName }) }).then(() => loadModels());
        }

        function setDatabaseServer(serverName) { document.getElementById('db-server-name').value = serverName; }
        function syncConnectionStringFromBuilder() {
            const server = document.getElementById('db-server-name').value;
            const db = document.getElementById('db-database-name').value;
            document.getElementById('db-connection-string').value = `Server=${server};Database=${db};Integrated Security=True;TrustServerCertificate=True;`;
        }
        function copyToClipboard(text) { navigator.clipboard.writeText(text).then(() => alert('Copied!')); }
    </script>
}
