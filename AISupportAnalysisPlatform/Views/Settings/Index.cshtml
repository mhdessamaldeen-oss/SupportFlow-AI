                                        <input type="text" class="form-control bg-transparent shadow-none" name="apiVersion" value="@ViewBag.DbCloudApiVersion" placeholder="2024-02-01" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Auth Header</label>
                                        <input type="text" class="form-control bg-transparent shadow-none" name="authHeaderName" value="@ViewBag.DbCloudAuthHeaderName" placeholder="api-key" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-12">
                                        <div class="form-check mt-2">
                                            <input class="form-check-input" type="checkbox" name="useBearerToken" value="true" id="cloud-use-bearer" @(ViewBag.DbCloudUseBearerToken == true ? "checked" : null)>
                                            <label class="form-check-label small" for="cloud-use-bearer">
                                                Send API key as Bearer token
                                            </label>
                                        </div>
                                    </div>
                                </div>
                                <div class="p-3 rounded-3" style="background: rgba(59, 130, 246, 0.05) !important; border: 1px solid rgba(59, 130, 246, 0.2) !important;">
                                    <h6 class="small fw-bold text-uppercase mb-2" style="color: #3b82f6;">
                                        <i class="bi bi-cloud-check me-2"></i>Supported Services
                                    </h6>
                                    <ul class="smaller ps-3 mb-0" style="color: var(--text-muted) !important;">
                                        <li>Azure OpenAI Service</li>
                                        <li>Self-hosted LLM endpoints</li>
                                        <li>Any OpenAI-compatible API</li>
                                        <li>Custom AI gateways</li>
                                    </ul>
                                </div>
                            </div>
                        </div>
                        <hr style="border-color: var(--border-color) !important;" class="my-4">
                        <div class="d-flex justify-content-end gap-2">
                            <button type="submit" class="btn btn-primary shadow-sm">
                                <i class="bi bi-save me-2"></i>Save Cloud Configuration
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ──── GOOGLE GEMINI TAB ──── -->
        <div class="tab-pane fade @(activeProvider == AiProviderType.Gemini ? "show active" : "")" id="provider-gemini" role="tabpanel">
            <div class="card border-0 shadow-lg border-top-0 rounded-top-0">
                <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-uppercase small ls-1 text-muted">Google Gemini Configuration</h5>
                        <p class="text-muted small mb-0">High-performance AI with native support for multi-modal analysis</p>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <button class="btn btn-outline-secondary btn-sm" onclick="validateProvider('Gemini', this)">
                            <i class="bi bi-wifi me-1"></i>Test Connection
                        </button>
                        @if (activeProvider != AiProviderType.Gemini)
                        {
                            <form asp-action="SetActiveProvider" method="post" class="m-0">
                                <input type="hidden" name="providerType" value="Gemini" />
                                <button type="submit" class="btn btn-primary btn-sm shadow-sm">
                                    <i class="bi bi-check-circle me-1"></i>Set as Active
                                </button>
                            </form>
                        }
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="SaveGeminiConfig" method="post">
                        <div class="row g-4">
                            <div class="col-lg-6">
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted text-uppercase ls-1">Model</label>
                                    <input type="text" class="form-control bg-transparent shadow-none" name="model"
                                           value="@ViewBag.DbGeminiModel" placeholder="gemini-1.5-flash"
                                           style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                </div>
                                <div class="row g-3 mb-4">
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Temperature</label>
                                        <input type="number" step="0.1" class="form-control bg-transparent shadow-none" name="temperature" value="@ViewBag.DbGeminiTemperature" min="0" max="2" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Max Tokens</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="maxTokens" value="@ViewBag.DbGeminiMaxTokens" min="1" max="32000" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted text-uppercase ls-1">API Key</label>
                                    <div class="input-group">
                                        <input type="password" id="gemini-apikey" class="form-control bg-transparent shadow-none" name="apiKey" autocomplete="off"
                                               value="@ViewBag.DbGeminiKey" placeholder="Your Gemini API key..."
                                               style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                        <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('gemini-apikey', this)">
                                            <i class="bi bi-eye"></i>
                                        </button>
                                    </div>
                                    <div class="form-text small" style="color: var(--text-muted) !important;">
                                        Get your key from <a href="https://aistudio.google.com/" target="_blank" class="text-info">Google AI Studio</a>
                                    </div>
                                </div>
                                <div class="d-flex justify-content-start">
                                    <button type="submit" class="btn btn-primary shadow-sm">
                                        <i class="bi bi-save me-2"></i>Save Gemini Configuration
                                    </button>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="p-4 rounded-3" style="background: rgba(var(--primary-color-rgb), 0.05) !important; border: 1px solid rgba(var(--primary-color-rgb), 0.2) !important;">
                                    <h6 class="small fw-bold text-uppercase mb-3" style="color: var(--primary-color);">
                                        <i class="bi bi-info-circle-fill me-2"></i>Gemini Advantages
                                    </h6>
                                    <ul class="span small mb-0 text-muted ps-3">
                                        <li class="mb-2"><strong>Massive Context:</strong> Up to 1M+ tokens for analyzing long ticket histories.</li>
                                        <li class="mb-2"><strong>Flash Speed:</strong> Sub-second response times for instant categorization.</li>
                                        <li><strong>Semantic Search:</strong> Native embedding support for finding related cases.</li>
                                    </ul>
                                </div>
                                <div class="alert alert-info border-0 mt-3 small">
                                    <i class="bi bi-info-circle me-1"></i> Gemini 1.5 Flash is highly recommended for high-volume support centers due to its balance of speed and cost.
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- ──── LOCALAI (BETTER ENGINE) TAB ──── -->
        <div class="tab-pane fade @(activeProvider == AiProviderType.LocalAI ? "show active" : "")" id="provider-localai" role="tabpanel">
            <div class="card border-0 shadow-lg border-top-0 rounded-top-0">
                <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-0 text-uppercase small ls-1 text-muted">LocalAI (OpenAI-Compatible Engine)</h5>
                        <p class="text-muted small mb-0">High-performance local alternative with full OpenAI API compatibility</p>
                    </div>
                    <div class="d-flex gap-2 align-items-center">
                        <button class="btn btn-outline-secondary btn-sm" onclick="validateProvider('LocalAI', this)">
                            <i class="bi bi-wifi me-1"></i>Test Connection
                        </button>
                        @if (activeProvider != AiProviderType.LocalAI)
                        {
                            <form asp-action="SetActiveProvider" method="post" class="m-0">
                                <input type="hidden" name="providerType" value="LocalAI" />
                                <button type="submit" class="btn btn-primary btn-sm shadow-sm">
                                    <i class="bi bi-check-circle me-1"></i>Set as Active
                                </button>
                            </form>
                        }
                    </div>
                </div>
                <div class="card-body p-4">
                    <form asp-action="SaveLocalAiConfig" method="post">
                        <div class="row g-4">
                            <div class="col-lg-6">
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted text-uppercase ls-1">LocalAI Base URL</label>
                                    <input type="text" class="form-control bg-transparent shadow-none" name="baseUrl"
                                           value="@ViewBag.DbLocalAiBaseUrl" placeholder="http://localhost:8080/v1"
                                           style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    <div class="form-text small" style="color: var(--text-muted) !important;">
                                        Default for LocalAI: http://localhost:8080/v1
                                    </div>
                                </div>
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted text-uppercase ls-1">Model</label>
                                    <input type="text" class="form-control bg-transparent shadow-none" name="model"
                                           value="@ViewBag.DbLocalAiModel" placeholder="your-local-model"
                                           style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                </div>
                                <div class="mb-4">
                                    <label class="form-label small fw-bold text-muted text-uppercase ls-1">API Key / Password</label>
                                    <input type="text" class="form-control bg-transparent shadow-none" name="apiKey"
                                           value="@ViewBag.DbLocalAiApiKey" placeholder="ignored or custom token"
                                           style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                </div>
                                <div class="row g-3 mb-4">
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Timeout</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="timeoutSeconds" value="@ViewBag.DbLocalAiTimeoutSeconds" min="5" max="600" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Temperature</label>
                                        <input type="number" step="0.1" class="form-control bg-transparent shadow-none" name="temperature" value="@ViewBag.DbLocalAiTemperature" min="0" max="2" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Max Prompt Chars</label>
                                        <input type="number" class="form-control bg-transparent shadow-none" name="maxPromptChars" value="@ViewBag.DbLocalAiMaxPromptChars" min="1000" max="100000" style="border-color: var(--border-color) !important; color: var(--text-main) !important;">
                                    </div>
                                </div>
                                <div class="d-flex justify-content-end">
                                    <button type="submit" class="btn btn-primary shadow-sm">
                                        <i class="bi bi-save me-2"></i>Save LocalAI Configuration
                                    </button>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="card border-info-subtle" style="background: rgba(13, 202, 240, 0.05) !important;">
                                    <div class="card-body">
                                        <h6 class="fw-bold text-info mb-3"><i class="bi bi-rocket-takeoff-fill me-2"></i>Why use LocalAI?</h6>
                                        <ul class="span small mb-0 text-muted">
                                            <li class="mb-2"><strong>Drop-in Replacement:</strong> Uses the exact same API as OpenAI, making integration seamless.</li>
                                            <li class="mb-2"><strong>Architecture Agnostic:</strong> Supports GGML, GGUF, and more.</li>
                                            <li><strong>Advanced Features:</strong> Supports images, audio, and function calling locally.</li>
                                        </ul>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
                <div class="card-footer bg-transparent border-top p-4" style="border-color: var(--border-color) !important;">
                    <div class="row align-items-center mb-3">
                        <div class="col-lg-8">
                            <h6 class="fw-bold mb-1"><i class="bi bi-terminal-fill me-2"></i>One-Click Setup (Docker)</h6>
                            <p class="text-muted small mb-0">Launch LocalAI immediately via Docker container.</p>
                        </div>
                    </div>
                    <div class="p-3 rounded-3" style="background: rgba(0,0,0,0.05) !important; border: 1px solid var(--border-color) !important;">
                        <code class="d-block p-2 mb-2 rounded bg-black text-info small">docker run -p 8080:8080 --name local-ai -ti localai/localai:latest --models-path /models --context-size 700 --threads 4</code>
                        <div class="d-flex justify-content-between align-items-center">
                            <span class="small text-muted"><i class="bi bi-info-circle me-1"></i>Default port: 8080</span>
                            <button class="btn btn-sm btn-outline-secondary" onclick="copyToClipboard('docker run -p 8080:8080 --name local-ai -ti localai/localai:latest --models-path /models --context-size 700 --threads 4')">Copy Command</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

    </div>

</div>

<!-- ═══════════════ CHATBOT AI TAB ═══════════════ -->
<div class="tab-pane fade @(activeTab == "chatbot" ? "show active" : "")" id="tab-chatbot" role="tabpanel">
    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card border-0 shadow-lg mb-4">
                <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex justify-content-between align-items-center">
                    <div>
                        <h5 class="fw-bold mb-1"><i class="bi bi-robot me-2" style="color: var(--primary-color);"></i>Copilot Tool Registry</h5>
                        <p class="text-muted small mb-0">Manage internal and external tools available to the AI Assistant at runtime.</p>
                    </div>
                    <button class="btn btn-primary btn-pill shadow-sm" onclick="openToolEditor('new')">
                        <i class="bi bi-plus-lg me-2"></i>Add Dynamic Tool
                    </button>
                </div>
                <div class="card-body p-4">
                    <div class="table-responsive">
                        <table class="table table-hover align-middle border-0">
                            <thead>
                                <tr class="text-muted small text-uppercase ls-1" style="border-bottom: 2px solid var(--border-color);">
                                    <th style="width: 50px;">Status</th>
                                    <th>Tool Identity</th>
                                    <th>Routing Context</th>
                                    <th>Test Prompt</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    var tools = ViewBag.CopilotTools as List<AISupportAnalysisPlatform.Models.AI.CopilotToolDefinition> ?? new();
                                }
                                @if (!tools.Any())
                                {
                                    <tr>
                                        <td colspan="5" class="text-center py-5">
                                            <div class="text-muted mb-2"><i class="bi bi-inbox-fill fs-1"></i></div>
                                            <p class="mb-0">No tools registered. Use "Add Dynamic Tool" to begin.</p>
                                        </td>
                                    </tr>
                                }
                                @foreach (var tool in tools)
                                {
                                    <tr>
                                        <td>
                                            <form asp-action="ToggleCopilotTool" method="post" class="m-0">
                                                <input type="hidden" name="id" value="@tool.Id" />
                                                <input type="hidden" name="isEnabled" value="@(tool.IsEnabled ? "false" : "true")" />
                                                <div class="form-check form-switch p-0 m-0 d-flex justify-content-center">
                                                    <input class="form-check-input ms-0 cursor-pointer" type="checkbox" role="switch" @(tool.IsEnabled ? "checked" : "") onchange="this.form.submit()">
                                                </div>
                                            </form>
                                        </td>
                                        <td>
                                            <div class="fw-bold text-main">@tool.Title</div>
                                            <div class="text-muted smaller text-truncate" style="max-width: 250px;">@tool.Description</div>
                                        </td>
                                        <td>
                                            <span class="badge rounded-pill bg-light text-dark border px-2 py-1 smaller">
                                                <i class="bi bi-hash me-1 text-primary"></i>@tool.ToolKey
                                            </span>
                                            <div class="mt-1 smaller text-muted opacity-75">Service: @tool.CopilotMode</div>
                                            @if (tool.ToolType != "Internal" && !string.IsNullOrWhiteSpace(tool.EndpointUrl))
                                            {
                                                <div class="mt-1 smaller text-primary text-truncate" style="max-width: 150px;">
                                                    <i class="bi bi-link-45deg"></i> @tool.EndpointUrl
                                                </div>
                                            }
                                        </td>

                                        <td>
                                            <div class="smaller text-muted italic">
                                                <i class="bi bi-chat-left-dots me-1"></i>@(string.IsNullOrWhiteSpace(tool.TestPrompt) ? "None" : tool.TestPrompt)
                                            </div>
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group">
                                                <button class="btn btn-outline-secondary btn-sm rounded-3 me-2" 
                                                        onclick="openToolEditor(this)"
                                                        data-tool-id="@tool.Id"
                                                        data-tool-title="@tool.Title"
                                                        data-tool-desc="@tool.Description"
                                                        data-tool-key="@tool.ToolKey"
                                                        data-tool-mode="@tool.CopilotMode"
                                                        data-tool-type="@tool.ToolType"
                                                        data-tool-url="@tool.EndpointUrl"
                                                        data-tool-enabled="@tool.IsEnabled.ToString().ToLower()">
                                                    <i class="bi bi-pencil-square"></i>
                                                </button>
                                                <form asp-action="DeleteCopilotTool" method="post" onsubmit="return confirm('Purge this tool from the registry?');" class="m-0">
                                                    <input type="hidden" name="id" value="@tool.Id" />
                                                    <button type="submit" class="btn btn-outline-danger btn-sm rounded-3">
                                                        <i class="bi bi-trash3-fill"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <!-- Tool Architect Panel -->
        <div class="col-lg-4">
            <div class="card border-0 shadow-lg sticky-top" style="top: 100px;">
                <div class="card-header border-0 pt-4 px-4 bg-transparent">
                    <h5 class="fw-bold mb-0 text-uppercase small ls-1 text-muted" id="tool-editor-title">Tool Architect</h5>
                    <p class="text-muted small">Design dynamic capabilities for the AI</p>
                </div>
                <div class="card-body p-4 pt-0">
                    <form id="toolEditorForm" asp-action="SaveCopilotTool" method="post">
                        <input type="hidden" id="tool-id" name="Id" value="0" />
                        <input type="hidden" id="tool-enabled" name="IsEnabled" value="true" />
                        
                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">Tool Title</label>
                            <input type="text" class="form-control bg-transparent shadow-none" id="tool-title" name="Title" required placeholder="e.g., Weather Hub" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">Description (Internal Prompt)</label>
                            <textarea class="form-control bg-transparent shadow-none" id="tool-desc" name="Description" rows="3" required placeholder="Explain to the AI when to use this tool..."></textarea>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Routing Key</label>
                                <input type="text" class="form-control bg-transparent shadow-none" id="tool-key" name="ToolKey" required placeholder="WEATHER" />
                            </div>
                            <div class="col-6">
                                <label class="form-label small fw-bold text-muted text-uppercase ls-1">Copilot Mode</label>
                                <select class="form-select bg-transparent shadow-none font-monospace" id="tool-mode" name="CopilotMode">
                                    <option value="ExternalUtility">ExternalUtility</option>
                                    <option value="TicketAnalysis">TicketAnalysis</option>
                                    <option value="KnowledgeBase">KnowledgeBase</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3 d-none">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">Implementation Type</label>
                            <select class="form-select bg-transparent shadow-none" id="tool-type" name="ToolType" onchange="toggleUrlField(this.value)">
                                <option value="External">External API (Dynamic Link)</option>
                                <option value="Internal">Internal Code (Handler-Backed)</option>
                            </select>
                        </div>

                        <div class="mb-4" id="url-field-container">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">Endpoint URL (Link)</label>
                            <input type="text" class="form-control bg-transparent shadow-none" id="tool-url" name="EndpointUrl" placeholder="https://api.service.com/data?q={query}" />
                            <div class="form-text smaller">Use <code>{query}</code> as a placeholder for LLM extraction.</div>
                        </div>

                        <div class="mb-4">
                            <label class="form-label small fw-bold text-muted text-uppercase ls-1">Test Prompt / Sample Question</label>
                            <textarea class="form-control bg-transparent shadow-none" id="tool-test-prompt" name="TestPrompt" rows="2" placeholder="e.g., What is the weather in London?"></textarea>
                            <div class="form-text smaller">Used for verification. Left blank? We'll auto-generate one for you.</div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100 shadow-sm">
                            <i class="bi bi-cpu-fill me-2"></i>Register Tool Capability
                        </button>
                        <button type="button" class="btn btn-outline-secondary w-100 mt-2" onclick="openToolEditor('new')">
                            Reset Architect
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ═══════════════ DATA TAB ═══════════════ -->
<div class="tab-pane fade @(activeTab == "data" ? "show active" : "")" id="tab-data" role="tabpanel">
    <div class="row g-4">
        <div class="col-lg-7">
            <div class="card border-0 shadow-lg mb-4">
                <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent">
                    <h5 class="fw-bold mb-1"><i class="bi bi-stack me-2"></i>Operational Data</h5>
                    <p class="text-muted small mb-0">Manage seeded ticket data manually from the UI. Startup no longer seeds tickets automatically.</p>
                </div>
                <div class="card-body p-4">
                    <div class="row g-3 mb-4">
                        <div class="col-md-6 col-xl-4">
                            <div class="p-3 rounded-3 border h-100">
                                <div class="small text-muted text-uppercase fw-bold">Tickets Count</div>
                                <div class="fs-4 fw-bold">@ViewBag.TicketCount</div>
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-4">
                            <div class="p-3 rounded-3 border h-100">
                                <div class="small text-muted text-uppercase fw-bold">Comments Count</div>
                                <div class="fs-4 fw-bold">@ViewBag.TicketCommentCount</div>
                            </div>
                        </div>
                        <div class="col-md-6 col-xl-4">
                            <div class="p-3 rounded-3 border h-100">
                                <div class="small text-muted text-uppercase fw-bold">Attachments Count</div>
                                <div class="fs-4 fw-bold">@ViewBag.TicketAttachmentCount</div>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex flex-wrap gap-2">
                        <form asp-action="SeedData" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-cloud-arrow-down-fill me-2"></i>Seed Data
                            </button>
                        </form>
                        <form asp-action="FlushData" method="post" class="m-0" onsubmit="return confirm('This will permanently delete ticket, AI, and notification data. Continue?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger">
                                <i class="bi bi-trash3-fill me-2"></i>Flush Data
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-lg overflow-hidden">
                <div class="card-header border-0 px-4 pt-4 pb-3 bg-transparent">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                        <div>
                            <h5 class="fw-bold mb-1"><i class="bi bi-diagram-3-fill me-2"></i>Database Setup And Migration</h5>
                            <p class="text-muted small mb-0">Choose the SQL Server target, inspect the engine, pick the database, then save or migrate in one flow.</p>
                        </div>
                    </div>
                </div>
                <div class="card-body p-4">
                    <div class="row g-4">
                        <div class="col-xl-4">
                            <div class="p-4 rounded-4 h-100 border" style="background: rgba(99, 102, 241, 0.04) !important;">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <span class="badge rounded-pill text-bg-dark">1</span>
                                    <h6 class="fw-bold mb-0">Target Server</h6>
                                </div>
                                <p class="text-muted small mb-3">Scan this machine for common SQL Server instances or type the server name directly.</p>
                                <form asp-action="DiscoverSqlServers" method="post" class="mb-3">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-primary w-100">
                                        <i class="bi bi-pc-display-horizontal me-2"></i>Scan This PC
                                    </button>
                                </form>
                                @if (sqlServerCandidates.Any())
                                {
                                    <div class="small text-muted text-uppercase fw-bold mb-2">Detected</div>
                                    <div class="d-flex flex-wrap gap-2">
                                        @foreach (var candidate in sqlServerCandidates)
                                        {
                                            <button type="button"
                                                    class="btn btn-outline-secondary btn-sm"
                                                    onclick="setDatabaseServer('@candidate.ServerName')">
                                                @candidate.ServerName
                                            </button>
                                        }
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-xl-4">
                            <div class="p-4 rounded-4 h-100 border">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <span class="badge rounded-pill text-bg-dark">2</span>
                                    <h6 class="fw-bold mb-0">Inspect Engine</h6>
                                </div>
                                <form asp-action="InspectSqlServer" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Server Name</label>
                                        <input type="text"
                                               id="db-server-name"
                                               name="serverName"
                                               value="@dbServerName"
                                               class="form-control bg-transparent shadow-none"
                                               placeholder="localhost">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Database Name</label>
                                        <input type="text"
                                               id="db-database-name"
                                               value="@dbDatabaseName"
                                               class="form-control bg-transparent shadow-none"
                                               placeholder="AISupportAnalysisPlatform">
                                    </div>
                                    <div class="d-grid">
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-search me-2"></i>Check Engine
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <div class="col-xl-4">
                            <div class="p-4 rounded-4 h-100 border" style="background: rgba(var(--primary-color-rgb), 0.04) !important;">
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <span class="badge rounded-pill text-bg-dark">3</span>
                                    <h6 class="fw-bold mb-0">Apply Target</h6>
                                </div>
                                <form asp-action="ActivateRuntimeDatabaseTarget" method="post">
                                    @Html.AntiForgeryToken()
                                    <div class="mb-3">
                                        <label class="form-label small fw-bold text-muted text-uppercase ls-1">Generated Connection</label>
                                        <textarea id="db-connection-string" name="connectionString" rows="6" class="form-control bg-transparent shadow-none">@ViewBag.CurrentConnectionString</textarea>
                                    </div>
                                    <div class="d-grid gap-2">
                                        <button type="button" class="btn btn-outline-secondary" onclick="syncConnectionStringFromBuilder()">
                                            <i class="bi bi-magic me-2"></i>Generate
                                        </button>
                                        <button type="submit" class="btn btn-primary">
                                            <i class="bi bi-arrow-repeat me-2"></i>Apply Runtime Target
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

</div> <!-- end settingsTabContent -->

<style>
