    #tab-ai #providerTabContent .card-body { padding: 2rem !important; }
    #tab-ai #providerTabContent .card-footer { padding: 1.5rem 2rem 2rem 2rem !important; background: linear-gradient(180deg, rgba(248, 250, 252, 0.5), rgba(255,255,255,0.95)) !important; }
    #tab-ai .form-label { margin-bottom: 0.45rem; }
    #tab-ai .form-control, #tab-ai .form-select, #tab-ai textarea { min-height: 48px; border-radius: 14px !important; background: rgba(255,255,255,0.82) !important; border-color: rgba(148, 163, 184, 0.24) !important; box-shadow: inset 0 1px 0 rgba(255,255,255,0.5); }
    #tab-ai textarea { min-height: auto; }
