                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-6">
                                <div class="p-4 rounded-3 mb-4" style="background: rgba(99, 102, 241, 0.05) !important; border: 1px solid rgba(99, 102, 241, 0.2) !important;">
                                    <h6 class="small fw-bold text-uppercase mb-3" style="color: var(--primary-color) !important;">
                                        <i class="bi bi-lightbulb-fill me-2"></i>Runtime Notes
                                    </h6>
