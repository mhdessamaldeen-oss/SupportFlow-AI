@using AISupportAnalysisPlatform.Models.DTOs
@{
    ViewData["Title"] = "Operations Intelligence";

    var isAdmin = ViewBag.IsAdmin == true;
    var statusMetrics = (ViewBag.ByStatus as IEnumerable<ReportMetricDto>)?.ToList() ?? new List<ReportMetricDto>();
    var priorityMetrics = (ViewBag.ByPriority as IEnumerable<ReportMetricDto>)?.ToList() ?? new List<ReportMetricDto>();
    var categoryMetrics = (ViewBag.ByCategory as IEnumerable<ReportMetricDto>)?.ToList() ?? new List<ReportMetricDto>();
    var entityMetrics = (ViewBag.ByEntity as IEnumerable<ReportMetricDto>)?.ToList() ?? new List<ReportMetricDto>();
    var sourceMetrics = (ViewBag.BySource as IEnumerable<ReportMetricDto>)?.ToList() ?? new List<ReportMetricDto>();
    var monthlyMetrics = (ViewBag.MonthlyData as IEnumerable<ReportMetricDto>)?.ToList() ?? new List<ReportMetricDto>();

    var topStatus = statusMetrics.OrderByDescending(x => x.Count).FirstOrDefault();
    var topPriority = priorityMetrics.OrderByDescending(x => x.Count).FirstOrDefault();
    var topCategory = categoryMetrics.OrderByDescending(x => x.Count).FirstOrDefault();
    var topEntity = entityMetrics.OrderByDescending(x => x.Count).FirstOrDefault();
    var topSource = sourceMetrics.OrderByDescending(x => x.Count).FirstOrDefault();

    var startDate = ViewBag.StartDate as string;
    var endDate = ViewBag.EndDate as string;
    var totalTickets = ViewBag.TotalTickets as int? ?? 0;
    var slaBreachedTickets = ViewBag.SlaBreachedTickets as int? ?? 0;
    var escalatedTickets = ViewBag.EscalatedTickets as int? ?? 0;
    var highImpactTickets = ViewBag.HighImpactTickets as int? ?? 0;
    var dateWindowLabel = !string.IsNullOrWhiteSpace(startDate) && !string.IsNullOrWhiteSpace(endDate)
        ? $"{startDate} to {endDate}"
        : !string.IsNullOrWhiteSpace(startDate)
            ? $"From {startDate}"
            : !string.IsNullOrWhiteSpace(endDate)
                ? $"Until {endDate}"
                : "All recorded activity";
}

<link rel="stylesheet" href="~/css/reports.css" asp-append-version="true" />

<div class="reports-shell">
    <section class="reports-hero">
        <div class="reports-hero-copy">
            <span class="reports-eyebrow">Operations Intelligence</span>
            <h1 class="reports-title">Reports that explain pressure, not just counts.</h1>
            <p class="reports-subtitle">
                Review ticket volume, SLA pressure, escalation load, and channel mix in one operational story.
            </p>

            <div class="reports-hero-meta">
                <span class="reports-meta-pill">
                    <i class="bi bi-calendar3"></i>
                    @dateWindowLabel
                </span>
                <span class="reports-meta-pill">
                    <i class="bi bi-diagram-3"></i>
                    @(isAdmin ? "All entities in scope" : "Your entity scope")
                </span>
                <span class="reports-meta-pill reports-meta-pill-live">
                    <i class="bi bi-broadcast-pin"></i>
                    Live reporting surface
                </span>
            </div>
        </div>

        <div class="reports-hero-side">
            <div class="reports-brief-card">
                <div class="reports-brief-head">
                    <span class="reports-brief-kicker">Snapshot</span>
                    <a class="reports-copilot-link" asp-controller="Reports" asp-action="Copilot" asp-route-startDate="@startDate" asp-route-endDate="@endDate">
                        <i class="bi bi-chat-square-text"></i>
                        Open Copilot
                    </a>
                </div>

                <div class="reports-brief-grid">
                    <div class="reports-brief-item">
                        <span class="reports-brief-label">Dominant status</span>
                        <strong>@(topStatus?.Label ?? "No data")</strong>
                        <small>@(topStatus?.Count ?? 0) tickets</small>
                    </div>
                    <div class="reports-brief-item">
                        <span class="reports-brief-label">Pressure band</span>
                        <strong>@(topPriority?.Label ?? "No data")</strong>
                        <small>@(topPriority?.Count ?? 0) tickets</small>
                    </div>
                    <div class="reports-brief-item">
                        <span class="reports-brief-label">Top category</span>
                        <strong>@(topCategory?.Label ?? "No data")</strong>
                        <small>@(topCategory?.Count ?? 0) tickets</small>
                    </div>
                    <div class="reports-brief-item">
                        <span class="reports-brief-label">Primary source</span>
                        <strong>@(topSource?.Label ?? "No data")</strong>
                        <small>@(topSource?.Count ?? 0) tickets</small>
                    </div>
                </div>

                @if (isAdmin && topEntity != null)
                {
                    <div class="reports-brief-foot">
                        <span class="reports-brief-label">Busiest entity</span>
                        <strong>@topEntity!.Label</strong>
                        <small>@topEntity.Count tickets</small>
                    </div>
                }
            </div>
        </div>
    </section>

    <section class="reports-filter-bar">
        <form method="get" class="reports-filter-form">
            <div class="reports-filter-field">
                <label for="startDate">Start date</label>
                <input id="startDate" type="date" name="startDate" value="@startDate" />
            </div>
            <div class="reports-filter-field">
                <label for="endDate">End date</label>
                <input id="endDate" type="date" name="endDate" value="@endDate" />
            </div>
            <button type="submit" class="reports-filter-submit">
                <i class="bi bi-sliders"></i>
                Refresh report
            </button>
        </form>
    </section>

    <section class="reports-metrics-grid">
        <article class="reports-metric-card">
            <span class="reports-metric-label">Tickets in scope</span>
            <strong class="reports-metric-value">@totalTickets</strong>
            <span class="reports-metric-note">Active reporting window volume</span>
        </article>
        <article class="reports-metric-card reports-metric-card-danger">
            <span class="reports-metric-label">SLA breached</span>
            <strong class="reports-metric-value">@slaBreachedTickets</strong>
            <span class="reports-metric-note">Tickets that missed commitment</span>
        </article>
        <article class="reports-metric-card reports-metric-card-violet">
            <span class="reports-metric-label">Escalated</span>
            <strong class="reports-metric-value">@escalatedTickets</strong>
            <span class="reports-metric-note">Cases raised above normal flow</span>
        </article>
        <article class="reports-metric-card reports-metric-card-amber">
            <span class="reports-metric-label">High impact</span>
            <strong class="reports-metric-value">@highImpactTickets</strong>
            <span class="reports-metric-note">Cases affecting 20+ users</span>
        </article>
    </section>

    <section class="reports-layout">
        <div class="reports-main">
            <div class="reports-chart-grid reports-chart-grid-top">
                <article class="reports-panel">
                    <div class="reports-panel-head">
                        <div>
                            <span class="reports-panel-kicker">Flow</span>
                            <h2>Status distribution</h2>
                        </div>
                        <p>See where tickets are sitting right now.</p>
                    </div>
                    <div class="reports-chart-wrap reports-chart-wrap-doughnut">
                        <canvas id="statusChart"></canvas>
                    </div>
                </article>

                <article class="reports-panel">
                    <div class="reports-panel-head">
                        <div>
                            <span class="reports-panel-kicker">Pressure</span>
                            <h2>Priority load</h2>
                        </div>
                        <p>Track where severity is concentrated.</p>
                    </div>
                    <div class="reports-chart-wrap">
                        <canvas id="priorityChart"></canvas>
                    </div>
                </article>
            </div>

            <div class="reports-chart-grid reports-chart-grid-bottom">
                <article class="reports-panel">
                    <div class="reports-panel-head">
                        <div>
                            <span class="reports-panel-kicker">Classification</span>
                            <h2>Category spread</h2>
                        </div>
                        <p>Understand which work types dominate demand.</p>
                    </div>
                    <div class="reports-chart-wrap">
                        <canvas id="categoryChart"></canvas>
                    </div>
                </article>

                @if (isAdmin)
                {
                    <article class="reports-panel">
                        <div class="reports-panel-head">
                            <div>
                                <span class="reports-panel-kicker">Coverage</span>
                                <h2>Entity footprint</h2>
                            </div>
                            <p>Compare load distribution across entities.</p>
                        </div>
                        <div class="reports-chart-wrap">
                            <canvas id="entityChart"></canvas>
                        </div>
                    </article>
                }
            </div>

            <div class="reports-chart-grid reports-chart-grid-wide">
                <article class="reports-panel reports-panel-wide">
                    <div class="reports-panel-head">
                        <div>
                            <span class="reports-panel-kicker">Trend</span>
                            <h2>Incident ingestion over time</h2>
                        </div>
                        <p>Look at the six-month demand pattern.</p>
                    </div>
                    <div class="reports-chart-wrap reports-chart-wrap-tall">
                        <canvas id="trendChart"></canvas>
                    </div>
                </article>

                <article class="reports-panel">
                    <div class="reports-panel-head">
                        <div>
                            <span class="reports-panel-kicker">Channels</span>
                            <h2>Source mix</h2>
                        </div>
                        <p>Review where requests are coming from.</p>
                    </div>
                    <div class="reports-chart-wrap reports-chart-wrap-tall">
                        <canvas id="sourceChart"></canvas>
                    </div>
                </article>
            </div>
        </div>

        <aside class="reports-sidebar">
            <article class="reports-panel reports-panel-sidebar">
                <div class="reports-panel-head">
                    <div>
                        <span class="reports-panel-kicker">Summary</span>
                        <h2>Operational brief</h2>
                    </div>
                    <p>A fast narrative from the current slice.</p>
                </div>

                <div class="reports-brief-list">
                    <div class="reports-brief-line">
                        <span>Top status</span>
                        <strong>@(topStatus?.Label ?? "No data")</strong>
                    </div>
                    <div class="reports-brief-line">
                        <span>Top priority</span>
                        <strong>@(topPriority?.Label ?? "No data")</strong>
                    </div>
                    <div class="reports-brief-line">
                        <span>Top category</span>
                        <strong>@(topCategory?.Label ?? "No data")</strong>
                    </div>
                    <div class="reports-brief-line">
                        <span>Main source</span>
                        <strong>@(topSource?.Label ?? "No data")</strong>
                    </div>
                    @if (isAdmin)
                    {
                        <div class="reports-brief-line">
                            <span>Busiest entity</span>
                            <strong>@(topEntity?.Label ?? "No data")</strong>
                        </div>
                    }
                </div>
            </article>

            <article class="reports-panel reports-panel-sidebar reports-panel-accent">
                <div class="reports-panel-head">
                    <div>
                        <span class="reports-panel-kicker">Next move</span>
                        <h2>Ask the copilot</h2>
                    </div>
                    <p>Use the analytics copilot when you need comparisons, top-N slices, or follow-up questions.</p>
                </div>

                <div class="reports-chip-list">
                    <a asp-controller="Reports" asp-action="Copilot" asp-route-prompt="show top 5 entities by ticket count" asp-route-startDate="@startDate" asp-route-endDate="@endDate" class="reports-chip">
                        Show top 5 entities by ticket count
                    </a>
                    <a asp-controller="Reports" asp-action="Copilot" asp-route-prompt="compare agents by resolved tickets" asp-route-startDate="@startDate" asp-route-endDate="@endDate" class="reports-chip">
                        Compare agents by resolved tickets
                    </a>
                    <a asp-controller="Reports" asp-action="Copilot" asp-route-prompt="find highest SLA breach areas" asp-route-startDate="@startDate" asp-route-endDate="@endDate" class="reports-chip">
                        Find highest SLA breach areas
                    </a>
                </div>
            </article>
        </aside>
    </section>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const statusMetrics = @Html.Raw(Json.Serialize(statusMetrics.Select(x => new { label = x.Label, count = x.Count })));
        const priorityMetrics = @Html.Raw(Json.Serialize(priorityMetrics.Select(x => new { label = x.Label, count = x.Count })));
        const categoryMetrics = @Html.Raw(Json.Serialize(categoryMetrics.Select(x => new { label = x.Label, count = x.Count })));
        const sourceMetrics = @Html.Raw(Json.Serialize(sourceMetrics.Select(x => new { label = x.Label, count = x.Count })));
        const trendMetrics = @Html.Raw(Json.Serialize(monthlyMetrics.Select(x => new { label = x.Label, count = x.Count })));
        const entityMetrics = @Html.Raw(Json.Serialize(entityMetrics.Select(x => new { label = x.Label, count = x.Count })));

        function toSeries(metrics) {
            const safeMetrics = Array.isArray(metrics) ? metrics : [];
            return {
                labels: safeMetrics.map(item => item.label),
                values: safeMetrics.map(item => item.count)
            };
        }

        const rootStyle = getComputedStyle(document.documentElement);
        const primaryColor = rootStyle.getPropertyValue('--primary-color').trim();
        const textMain = rootStyle.getPropertyValue('--text-main').trim();
        const textMuted = rootStyle.getPropertyValue('--text-muted').trim();
        const borderColor = rootStyle.getPropertyValue('--border-color').trim();

        Chart.defaults.font.family = "'IBM Plex Sans', 'Segoe UI', sans-serif";
        Chart.defaults.color = textMuted;

        const commonOptions = {
            responsive: true,
            maintainAspectRatio: false,
            plugins: {
                legend: {
                    position: 'bottom',
                    labels: {
                        usePointStyle: true,
                        pointStyle: 'circle',
                        padding: 18,
                        color: textMain,
                        font: { size: 11, weight: '600' }
                    }
                },
                tooltip: {
                    backgroundColor: '#101828',
                    titleColor: '#f8fafc',
                    bodyColor: '#e2e8f0',
                    borderColor: '#1f2937',
                    borderWidth: 1,
                    cornerRadius: 12,
                    padding: 12
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { color: textMuted, precision: 0 },
                    grid: { color: borderColor, drawBorder: false }
                },
                x: {
                    ticks: { color: textMain },
                    grid: { display: false }
                }
            }
        };

        const doughnutOptions = {
            ...commonOptions,
            cutout: '68%',
            scales: { x: { display: false }, y: { display: false } }
        };

        const statusSeries = toSeries(statusMetrics);
        new Chart(document.getElementById('statusChart'), {
            type: 'doughnut',
            data: {
                labels: statusSeries.labels,
                datasets: [{
                    data: statusSeries.values,
                    backgroundColor: ['#1d4ed8', '#14b8a6', '#f59e0b', '#ef4444', '#8b5cf6', '#64748b'],
                    borderWidth: 0,
                    hoverOffset: 10
                }]
            },
            options: doughnutOptions
        });

        const prioritySeries = toSeries(priorityMetrics);
        new Chart(document.getElementById('priorityChart'), {
            type: 'bar',
            data: {
                labels: prioritySeries.labels,
                datasets: [{
                    label: 'Tickets',
                    data: prioritySeries.values,
                    backgroundColor: ['#0f766e', '#1d4ed8', '#f59e0b', '#dc2626', '#7c3aed'],
                    borderRadius: 10,
                    maxBarThickness: 42
                }]
            },
            options: commonOptions
        });

        const categorySeries = toSeries(categoryMetrics);
        new Chart(document.getElementById('categoryChart'), {
            type: 'bar',
            data: {
                labels: categorySeries.labels,
                datasets: [{
                    label: 'Tickets',
                    data: categorySeries.values,
                    backgroundColor: '#111827',
                    borderRadius: 10,
                    maxBarThickness: 28
                }]
            },
            options: { ...commonOptions, indexAxis: 'y' }
        });

        @if (isAdmin)
        {
            <text>
            const entitySeries = toSeries(entityMetrics);
            new Chart(document.getElementById('entityChart'), {
                type: 'polarArea',
                data: {
                    labels: entitySeries.labels,
                    datasets: [{
                        data: entitySeries.values,
                        backgroundColor: [
                            'rgba(29, 78, 216, 0.75)',
                            'rgba(20, 184, 166, 0.75)',
                            'rgba(245, 158, 11, 0.75)',
                            'rgba(124, 58, 237, 0.75)',
                            'rgba(71, 85, 105, 0.75)'
                        ],
                        borderWidth: 0
                    }]
                },
                options: {
                    ...doughnutOptions,
                    plugins: {
                        ...doughnutOptions.plugins,
                        legend: { ...doughnutOptions.plugins.legend, position: 'bottom' }
                    }
                }
            });
            </text>
        }

        const trendSeries = toSeries(trendMetrics);
        new Chart(document.getElementById('trendChart'), {
            type: 'line',
            data: {
                labels: trendSeries.labels,
                datasets: [{
                    label: 'Tickets',
                    data: trendSeries.values,
                    borderColor: primaryColor,
                    backgroundColor: 'rgba(29, 78, 216, 0.10)',
                    fill: true,
                    tension: 0.35,
                    pointRadius: 4,
                    pointHoverRadius: 6,
                    pointBackgroundColor: '#ffffff',
                    pointBorderColor: primaryColor,
                    pointBorderWidth: 2
                }]
            },
            options: commonOptions
        });

        const sourceSeries = toSeries(sourceMetrics);
        new Chart(document.getElementById('sourceChart'), {
            type: 'polarArea',
            data: {
                labels: sourceSeries.labels,
                datasets: [{
                    data: sourceSeries.values,
                    backgroundColor: ['#0f766e', '#1d4ed8', '#f59e0b', '#dc2626', '#6b7280'],
                    borderWidth: 0
                }]
            },
            options: {
                ...doughnutOptions,
                plugins: {
                    ...doughnutOptions.plugins,
                    legend: { ...doughnutOptions.plugins.legend, position: 'bottom' }
                }
            }
        });
    </script>
}
