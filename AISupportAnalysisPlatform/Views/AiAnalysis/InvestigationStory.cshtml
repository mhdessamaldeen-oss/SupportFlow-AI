@model AISupportAnalysisPlatform.Models.AI.CopilotTraceDetailPageViewModel
@{
    ViewData["Title"] = Loc.Get("ReasoningInvestigationStory");
}

@section Styles {
    <link rel="stylesheet" href="~/css/copilot.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/ai-history.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism-tomorrow.min.css" />
    <script>
        document.documentElement.classList.add('investigation-page-body');
    </script>
}

<div class="investigation-page-shell">
    <div class="ai-header-shell px-0 animate__animated animate__fadeIn d-flex flex-column flex-md-row justify-content-between align-items-md-center border-bottom" style="border-bottom-color: var(--border-color) !important;">
        <div class="d-flex align-items-center gap-3">
            <div class="ai-icon-box shadow-sm position-relative overflow-hidden">
                <i class="bi bi-diagram-3-fill text-primary" style="position: relative; z-index: 2;"></i>
            </div>
            <div>
                <nav aria-label="breadcrumb" class="mb-0">
                    <ol class="breadcrumb mb-0 p-0 bg-transparent" style="font-size: 0.7rem; letter-spacing: 0.03em; font-weight: 700; text-transform: uppercase;">
                        <li class="breadcrumb-item"><a asp-controller="AiAnalysis" asp-action="Hub" class="text-muted text-decoration-none hover-primary">@Loc.Get("AnalysisHub")</a></li>
                        <li class="breadcrumb-item"><a asp-controller="AiAnalysis" asp-action="InvestigationHistory" class="text-muted text-decoration-none hover-primary">@Loc.Get("InvestigationArchive")</a></li>
                        <li class="breadcrumb-item active text-primary" aria-current="page">@Loc.Get("InvestigationStory")</li>
                    </ol>
                </nav>
                <p class="mb-0 text-main fw-bold" style="font-size: 0.95rem; line-height: 1.2;">@Loc.Get("TraceContextSummary")</p>
            </div>
        </div>
        <div class="text-end d-flex align-items-center gap-4">
            <div class="d-flex align-items-center gap-3 d-none d-lg-flex">
                <div class="text-end">
                    <div class="small text-muted text-uppercase fw-bold mb-0" style="letter-spacing: 0.05em; font-size: 0.65rem;">@Loc.Get("StoryId")</div>
                    <div class="fw-bold text-primary" style="font-size: 0.95rem;">#@Model.Trace.Id</div>
                </div>
                <div class="text-end border-start ps-3" style="border-color: var(--border-color) !important;">
                    <div class="small text-muted text-uppercase fw-bold mb-0" style="letter-spacing: 0.05em; font-size: 0.65rem;">@Loc.Get("ArchiveSize")</div>
                    <div class="fw-bold text-main" style="font-size: 0.95rem;">@Model.ArchiveCount <span class="text-muted fw-normal small">@Loc.Get("Samples")</span></div>
                </div>
            </div>
            <div class="d-flex gap-2">
                <a href="@Url.Action("Copilot", "AiAnalysis")" class="btn btn-primary btn-sm rounded-pill px-3 shadow-sm fw-bold">
                    <i class="bi bi-chat-dots @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("BackToChat")
                </a>
                <a href="@Url.Action("InvestigationHistory", "AiAnalysis")" class="btn btn-soft-secondary btn-sm rounded-pill px-3 fw-bold">
                    <i class="bi bi-archive @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("BackToArchive")
                </a>
                <a asp-controller="AiAnalysis" asp-action="Hub" class="btn btn-soft-secondary btn-sm rounded-pill px-4 fw-bold">
                    <i class="bi bi-grid @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("Hub")
                </a>
            </div>
        </div>
    </div>

<div class="glass-card position-relative mb-4 border-1 shadow-lg p-4" style="background: var(--bg-card);">
    <div class="row g-3 align-items-start">
        <div class="col-xl-8">
            <div class="small text-muted text-uppercase fw-bold mb-2" style="letter-spacing: 0.1em;">@Loc.Get("Question")</div>
            <div class="fw-bold text-main" style="font-size: 1.05rem;">@Model.Trace.Question</div>
        </div>
        <div class="col-xl-4">
            <div class="small text-muted text-uppercase fw-bold mb-2" style="letter-spacing: 0.1em;">@Loc.Get("TraceMeta")</div>
            <div class="d-flex flex-wrap gap-2">
                <span class="badge bg-soft-primary text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2">@Model.Trace.Intent</span>
                <span class="badge bg-soft-secondary text-muted border border-secondary border-opacity-25 rounded-pill px-3 py-2">@Model.Trace.ModelName</span>
                <span class="badge bg-soft-secondary text-muted border border-secondary border-opacity-25 rounded-pill px-3 py-2">@Model.Trace.TotalElapsedMs ms</span>
                <span class="badge bg-soft-secondary text-muted border border-secondary border-opacity-25 rounded-pill px-3 py-2">@Model.Trace.CreatedAt.ToString("MMM dd, yyyy • HH:mm")</span>
            </div>
        </div>
    </div>
</div>

@await Html.PartialAsync("_InvestigationTraceDetail", Model.ExecutionDetails, new ViewDataDictionary(ViewData)
{
    ["Trace"] = Model.Trace,
    ["DefaultTraceView"] = Model.DefaultTraceView
})
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-json.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-sql.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/svg-pan-zoom@3.6.1/dist/svg-pan-zoom.min.js"></script>
    <script src="~/js/copilot-trace-visuals.js" asp-append-version="true"></script>
}
