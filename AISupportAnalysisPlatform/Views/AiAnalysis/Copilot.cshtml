    function restoreCopilotState() {
        try {
            const storedHistory = localStorage.getItem(copilotStorageKey);

            if (storedHistory) {
                const parsed = JSON.parse(storedHistory);
                if (Array.isArray(parsed)) {
                    copilotHistory = parsed
                        .filter(item => item && typeof item.role === 'string' && typeof item.content === 'string')
                        .map(item => {
                            // Cleanse transient state flags on reload
                            item.isQueued = false;
                            item.isActive = false;
                            return item;
                        })
                        .slice(-20);
                }
            }
            renderConversation();
        } catch {
            copilotHistory = [];
            renderConversation();
        }
    }

    function formatPercent(value) {
        const numeric = Number(value || 0);
        const percentage = numeric <= 1 ? numeric * 100 : numeric;
        return `${percentage.toFixed(1)}%`;
    }

    function formatTemperature(value) {
        const numeric = Number(value);
        return Number.isFinite(numeric) ? `${numeric.toFixed(1)}°C` : 'n/a';
    }

    function formatSpeed(value) {
        const numeric = Number(value);
        return Number.isFinite(numeric) ? `${numeric.toFixed(1)} km/h` : 'n/a';
    }

    function formatMessageBody(value) {
        return renderMarkdownLite(value);
    }

    function renderMarkdownLite(value) {
        const lines = String(value || '').split('\n');
        const blocks = [];
        let paragraph = [];
        let table = [];

        const flushParagraph = () => {
            if (!paragraph.length) return;
            blocks.push(`<p class="mb-2">${formatInlineMarkdown(paragraph.join('<br>'))}</p>`);
            paragraph = [];
        };

        const flushTable = () => {
            if (!table.length) return;
            const rows = table
                .map(line => line.trim())
                .filter(line => line.startsWith('|') && line.endsWith('|'))
                .map(line => line.slice(1, -1).split('|').map(cell => formatInlineMarkdown(escapeHtml(cell.trim()))));

            if (rows.length >= 2) {
                const [header, ...bodyRows] = rows.filter((row, index) => index !== 1 || !row.every(cell => /^-+$/.test(cell.replace(/<[^>]+>/g, ''))));
                blocks.push(`
                    <div class="copilot-inline-table-wrap">
                        <table class="copilot-inline-table">
                            <thead><tr>${header.map(cell => `<th>${cell}</th>`).join('')}</tr></thead>
                            <tbody>${bodyRows.map(row => `<tr>${row.map(cell => `<td>${cell}</td>`).join('')}</tr>`).join('')}</tbody>
                        </table>
                    </div>
                `);
            } else {
                paragraph.push(...table.map(line => escapeHtml(line)));
                flushParagraph();
            }

            table = [];
        };

        for (const rawLine of lines) {
            const line = rawLine.trimEnd();
            const trimmed = line.trim();

            if (!trimmed) {
                flushParagraph();
                flushTable();
                continue;
            }

            if (trimmed.startsWith('|') && trimmed.endsWith('|')) {
                flushParagraph();
                table.push(trimmed);
                continue;
            }

            flushTable();
            paragraph.push(escapeHtml(line));
        }

        flushParagraph();
        flushTable();

        return blocks.join('') || '<p class="mb-0"></p>';
    }

    function formatInlineMarkdown(value) {
        return String(value || '')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>');
    }

    function summarizeDynamicPlan(plan) {
        const parts = [];
        if (plan.targetView) {
            parts.push(`view: ${plan.targetView}`);
        }
        if (plan.intent) {
            parts.push(`intent: ${plan.intent}`);
        }
        if (Array.isArray(plan.statusNames) && plan.statusNames.length) {
            parts.push(`status: ${plan.statusNames.join(', ')}`);
        }
        if (plan.entityName) {
            parts.push(`entity: ${plan.entityName}`);
        }
        if (plan.priorityName) {
            parts.push(`priority: ${plan.priorityName}`);
        }
        if (plan.relativeDateRange) {
            parts.push(`date: ${plan.relativeDateRange}`);
        }
        if (plan.textSearch) {
            parts.push(`text: ${plan.textSearch}`);
        }
        if (plan.maxResults) {
            parts.push(`limit: ${plan.maxResults}`);
        }
        if (plan.sortBy) {
            parts.push(`sort: ${plan.sortBy} ${plan.sortDirection || ''}`.trim());
        }
        if (Array.isArray(plan.selectedColumns) && plan.selectedColumns.length) {
            parts.push(`columns: ${plan.selectedColumns.join(', ')}`);
        }
        return parts.join(' • ');
    }

    function humanizeColumn(column) {
        const labels = {
            ticketNumber: 'Ticket',
            entityName: 'Entity',
            agentName: 'Agent',
            totalTickets: 'Ticket Count',
            openTickets: 'Open',
            resolvedTickets: 'Resolved',
            closedTickets: 'Closed',
            slaBreaches: 'SLA Breaches',
            slaBreachRate: 'SLA Breach %',
            avgResolutionHours: 'Avg Resolution (h)',
            avgFirstResponseHours: 'Avg First Response (h)',
            ticketsLast7Days: 'Last 7d',
            ticketsLast30Days: 'Last 30d',
            totalAssigned: 'Assigned',
            currentOpenAssigned: 'Open Assigned',
            totalResolved: 'Resolved',
            totalComments: 'Comments',
            assignedLast7Days: 'Assigned 7d',
            resolvedLast30Days: 'Resolved 30d',
            productArea: 'Product',
            requiresManagerReview: 'Manager Review',
            createdAtUtc: 'Created',
            resolvedAtUtc: 'Resolved'
        };

        const normalized = (column || '').charAt(0).toLowerCase() + (column || '').slice(1);
        return labels[normalized] || column;
    }

    function getStructuredCellValue(values, column) {
        if (!values) return '-';
        const camel = (column || '').charAt(0).toLowerCase() + (column || '').slice(1);
        return values[column] || values[camel] || '-';
    }
