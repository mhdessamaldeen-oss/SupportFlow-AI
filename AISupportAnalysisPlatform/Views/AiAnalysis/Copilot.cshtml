    function startThinkingSimulation() {
        if (!document.getElementById('copilot-thinking-steps')) {
            // If not rendered yet, retry in a moment
            setTimeout(startThinkingSimulation, 50);
            return;
        }

        let currentStep = 0;
        
        if (thinkingInterval) clearInterval(thinkingInterval);

        const addStep = () => {
            const activeHost = document.getElementById('copilot-thinking-steps');
            if (!activeHost) return; // Wait for DOM to be ready

            if (currentStep >= thinkingSteps.length) {
                clearInterval(thinkingInterval);
                return;
            }

            // Mark previous as completed
            const prev = activeHost.querySelector('.is-pending');
            if (prev) {
                prev.classList.remove('is-pending');
                prev.classList.add('is-completed');
                prev.querySelector('i').className = 'bi bi-check-circle-fill';
            }

            const step = thinkingSteps[currentStep];
            const li = document.createElement('li');
            li.className = 'copilot-thinking-step is-pending';
            li.innerHTML = `<i class="bi ${step.icon}"></i> <span>${step.label}</span>`;
            activeHost.appendChild(li);

            currentStep++;

            // Auto-scroll chat to show new step
            const thread = document.getElementById('copilot-thread');
            if (thread) thread.scrollTop = thread.scrollHeight;
        };

        // Clear it once initially
        const initialHost = document.getElementById('copilot-thinking-steps');
        if (initialHost) initialHost.innerHTML = '';
        
        addStep(); // Show first step immediately
        thinkingInterval = setInterval(addStep, 1500 + Math.random() * 1000);
    }

    function stopThinkingSimulation() {
        if (thinkingInterval) clearInterval(thinkingInterval);
        thinkingInterval = null;
    }

    function renderExecutionDetails(execution, dynamicPlan) {
        const wrap = document.getElementById('copilot-execution-wrap');
        const host = document.getElementById('copilot-execution');
        const steps = execution.steps || [];

        // Always show the trace panel if we have steps
        if (!steps.length && !execution.routeReason) {
            wrap.classList.add('d-none');
            host.innerHTML = '';
            return;
        }

        wrap.classList.remove('d-none');

        const statusIcon = (status) => {
            switch (status) {
                case 'ok':    return '<i class="bi bi-check-circle-fill text-success"></i>';
                case 'warn':  return '<i class="bi bi-exclamation-triangle-fill text-warning"></i>';
                case 'error': return '<i class="bi bi-x-circle-fill text-danger"></i>';
                case 'skip':  return '<i class="bi bi-dash-circle-fill text-muted"></i>';
                default:      return '<i class="bi bi-circle text-muted"></i>';
            }
        };

        const layerColor = (layer) => {
            switch (layer) {
                case 'Context':  return '#6366f1';
                case 'Router':   return '#f59e0b';
                case 'Executor': return getComputedStyle(document.documentElement).getPropertyValue('--primary-color').trim();
                case 'Complete': return '#3b82f6';
                default:         return '#6b7280';
            }
        };

        let stepsHtml = steps.map((step, i) => `
            <div class="copilot-story-step ${i === steps.length - 1 ? 'copilot-story-step-last' : ''}" style="--step-color: ${layerColor(step.layer)}">
                <div class="copilot-story-dot">${statusIcon(step.status)}</div>
                <div class="copilot-story-content">
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="copilot-story-layer" style="color: ${layerColor(step.layer)}">${escapeHtml(step.layer)}</span>
                        ${step.elapsedMs > 0 ? `<span class="copilot-story-time">${step.elapsedMs}ms</span>` : ''}
                    </div>
                    <div class="copilot-story-action">${escapeHtml(step.action)}</div>
                    <div class="copilot-story-detail">${escapeHtml(step.detail)}</div>
                </div>
            </div>
        `).join('');

        // Add total time footer
        if (execution.totalElapsedMs) {
            stepsHtml += `
                <div class="copilot-story-footer">
                    <i class="bi bi-stopwatch me-1"></i> Total: ${execution.totalElapsedMs}ms
                    ${execution.plannerConfidence ? ` • Confidence: ${execution.plannerConfidence}` : ''}
                </div>
            `;
        }

        // Add dynamic query plan summary if present
        if (dynamicPlan) {
            stepsHtml += `
                <div class="copilot-story-plan">
                    <div class="copilot-story-plan-title"><i class="bi bi-database me-1"></i> Query Plan</div>
                    <div class="copilot-story-plan-body">${summarizeDynamicPlan(dynamicPlan)}</div>
                </div>
            `;
        }

        host.innerHTML = `
            <div class="small fw-bold text-uppercase text-muted letter-spacing-1 mb-2">
                <i class="bi bi-journal-text me-1"></i> Execution Story
            </div>
            <div class="copilot-story-timeline">${stepsHtml}</div>
        `;
    }



    function renderDynamicResults(rows, structuredColumns, structuredRows, structuredQueryResults) {
        const wrap = document.getElementById('copilot-query-wrap');
        const host = document.getElementById('copilot-query-results');
        if (structuredQueryResults.length > 1) {
            wrap.classList.remove('d-none');
            host.innerHTML = structuredQueryResults.map(result => {
                const execution = result.execution || {};
                const columns = (execution.structuredColumns || []).length
                    ? execution.structuredColumns
                    : Object.keys((execution.structuredRows || [])[0]?.values || {});
                const rows = execution.structuredRows || [];

                return `
                    <div class="mb-3">
                        <div class="small fw-bold text-uppercase text-muted mb-2">${escapeHtml(result.label || 'Query')}</div>
                        <div class="small fw-semibold mb-2">${escapeHtml(result.queryText || '')}</div>
                        ${rows.length ? renderStructuredTableMarkup(columns, rows) : `<div class="small text-muted">${escapeHtml(execution.answer || '')}</div>`}
                    </div>
                `;
            }).join('');
            return;
        }

        if (structuredRows.length) {
            const columns = structuredColumns.length
                ? structuredColumns
                : Object.keys(structuredRows[0]?.values || {});

            wrap.classList.remove('d-none');
            host.innerHTML = renderStructuredTableMarkup(columns, structuredRows);
            return;
        }

        if (!rows.length) {
            wrap.classList.add('d-none');
            host.innerHTML = '';
            return;
        }

        wrap.classList.remove('d-none');
        host.innerHTML = rows.map(row => `
            <a href="@Url.Action("Details", "Tickets")/${row.ticketId}" class="text-decoration-none">
                <div class="copilot-dataset-card">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <strong>${escapeHtml(row.ticketNumber || '')}</strong>
                        <span class="copilot-score">${escapeHtml(row.status || '')}</span>
                    </div>
                    <div class="small fw-semibold mb-1">${escapeHtml(row.title || '')}</div>
                    <div class="small copilot-dataset-meta mb-1">
                        ${escapeHtml(row.priority || '')}${row.entityName ? ` • ${escapeHtml(row.entityName)}` : ''}${row.productArea ? ` • ${escapeHtml(row.productArea)}` : ''}
                    </div>
                    <div class="small copilot-dataset-meta">
                        ${escapeHtml(row.createdAtUtc || '')}${row.requiresManagerReview ? ' • Manager review' : ''}
                    </div>
                </div>
            </a>
        `).join('');
    }

    function renderStructuredTableMarkup(columns, rows) {
