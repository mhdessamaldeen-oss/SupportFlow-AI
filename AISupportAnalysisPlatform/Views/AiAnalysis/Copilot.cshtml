    function escapeHtml(value) {
        return String(value)
            .replaceAll('&', '&amp;')
            .replaceAll('<', '&lt;')
            .replaceAll('>', '&gt;')
            .replaceAll('"', '&quot;')
            .replaceAll("'", '&#39;');
    }

    function escapeJs(value) {
        return String(value)
            .replaceAll('\\', '\\\\')
            .replaceAll("'", "\\'");
    }

    function humanizeToolName(value) {
        return String(value || '')
            .replaceAll('_', ' ')
            .replace(/\b\w/g, char => char.toUpperCase());
    }

    let copilotRecognition;
    let copilotIsRecording = false;

    if ('webkitSpeechRecognition' in window) {
        copilotRecognition = new webkitSpeechRecognition();
        copilotRecognition.continuous = true;
        copilotRecognition.interimResults = true;
        // The language will automatically default to the browser's language setting.
        
        copilotRecognition.onstart = function() {
            copilotIsRecording = true;
            const btn = document.getElementById('copilot-mic-btn');
            if(btn) {
                btn.classList.add('recording');
                btn.innerHTML = '<i class="bi bi-mic-fill fs-5"></i>';
            }
            document.getElementById('copilot-question').placeholder = "Listening...";
        };

        copilotRecognition.onresult = function(event) {
            let finalTranscript = '';
            for (let i = event.resultIndex; i < event.results.length; ++i) {
                if (event.results[i].isFinal) {
                    finalTranscript += event.results[i][0].transcript;
                }
            }
            
            if (finalTranscript) {
                const input = document.getElementById('copilot-question');
                if (input.value && !input.value.endsWith(' ')) {
                    input.value += ' ' + finalTranscript;
                } else {
                    input.value += finalTranscript;
                }
                // Trigger auto resize
                input.dispatchEvent(new Event('input'));
            }
        };

        copilotRecognition.onerror = function(event) {
            console.error("Speech recognition error", event.error);
            stopCopilotRecording();
        };

        copilotRecognition.onend = function() {
            stopCopilotRecording();
            // Automatically submit if there is text? Keep it manual for them to check the text
        };
    }

    function toggleSpeechRecognition() {
        if (!copilotRecognition) {
            alert("Speech recognition is not supported in your browser. Please use Chrome or Edge.");
            return;
        }

        if (copilotIsRecording) {
            copilotRecognition.stop();
        } else {
            document.getElementById('copilot-question').focus();
            copilotRecognition.start();
        }
    }

    function stopCopilotRecording() {
        copilotIsRecording = false;
        const btn = document.getElementById('copilot-mic-btn');
        if(btn) {
            btn.classList.remove('recording');
            btn.innerHTML = '<i class="bi bi-mic fs-5"></i>';
        }
        const input = document.getElementById('copilot-question');
        if(input) input.placeholder = '@Loc.Get("CopilotQuestionHint")';
    }
</script>
