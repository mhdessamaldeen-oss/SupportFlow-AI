@model AISupportAnalysisPlatform.Models.AI.AdminCopilotExecutionDetails
@using AISupportAnalysisPlatform.Models.AI
@using System.Text.Json
@{
    string traceId = Convert.ToString(ViewBag.Trace?.Id) ?? "current";
    var storyToggleId = $"trace-story-{traceId}";
    var treeToggleId = $"trace-tree-{traceId}";
    var traceRootId = $"trace-detail-{traceId}";
    var traceGraphKey = "trace_" + new string(traceId.ToCharArray().Select(ch => char.IsLetterOrDigit(ch) ? ch : '_').ToArray());
    var defaultTraceView = string.Equals(Convert.ToString(ViewData["DefaultTraceView"] ?? ViewBag.DefaultTraceView), "tree", StringComparison.OrdinalIgnoreCase) ? "tree" : "story";


    List<CopilotExecutionStep> GetAllSteps(IEnumerable<CopilotExecutionStep> roots)
    {
        var all = new List<CopilotExecutionStep>();
        foreach (var root in roots)
        {
            all.Add(root);
            all.AddRange(GetAllSteps(root.SubSteps));
        }
        return all;
    }

    List<CopilotExecutionStep> GetLogicalRoots(IEnumerable<CopilotExecutionStep> roots, params CopilotExecutionLayer[] layers)
    {
        return roots.Where(r => layers.Contains(r.Layer) || GetAllSteps(r.SubSteps).Any(s => layers.Contains(s.Layer))).ToList();
    }

    var allTraceSteps = GetAllSteps(Model.Steps);
    var contextSteps = Model.Steps.Where(step => step.Layer == CopilotExecutionLayer.Context).ToList();
    var routerSteps = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.Router);
    var executorSteps = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.Executor);
    var completeSteps = Model.Steps.Where(step => step.Layer == CopilotExecutionLayer.Complete).ToList();

    var queryPlans = Model.QueryPlans.Any()
        ? Model.QueryPlans
        : Model.QueryPlan != null
            ? new List<AdminCopilotDynamicTicketQueryPlan> { Model.QueryPlan }
            : new List<AdminCopilotDynamicTicketQueryPlan>();

    string CleanActionLabel(string? action, string fallback)
    {
        if (string.IsNullOrWhiteSpace(action))
        {
            return fallback;
        }

        var cleaned = System.Text.RegularExpressions.Regex.Replace(action, @"\s*\[[^\]]+\]", string.Empty).Trim();
        return string.IsNullOrWhiteSpace(cleaned) ? fallback : cleaned;
    }

    string ResolveStructuredPlanName(AdminCopilotDynamicTicketQueryPlan plan)
        => !string.IsNullOrWhiteSpace(plan.TargetView)
            ? plan.TargetView
            : !string.IsNullOrWhiteSpace(plan.EntityName)
                ? $"{plan.EntityName} data"
                : "Structured data";

    string StepEvidence(CopilotExecutionStep step)
        => $"{step.Action} {step.Detail} {step.TechnicalData}".ToLowerInvariant();

    bool IsDecompositionStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("request decomposition")
            || evidence.Contains("subrequest")
            || evidence.Contains("subrequests");
    }

    bool IsCatalogDataPlanningStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("catalog data intent")
            || evidence.Contains("data intent")
            || evidence.Contains("primaryentity")
            || evidence.Contains("outputshape")
            || evidence.Contains("validationmessages");
    }

    bool IsCatalogDataExecutionStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("catalog query execution")
            || evidence.Contains("copilotdataqueryexecutorservice")
            || evidence.Contains("select ")
            || evidence.Contains(" from ");
    }

    var decompositionSteps = Model.Steps.Where(IsDecompositionStep).ToList();
    var dataPlanningSteps = allTraceSteps.Where(IsCatalogDataPlanningStep).ToList();
    var dataExecutionSteps = allTraceSteps.Where(IsCatalogDataExecutionStep).ToList();

    bool IsKnowledgeStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("knowledge") || evidence.Contains("similar") || evidence.Contains("evidence") || evidence.Contains("grounded");
    }

    bool IsExternalStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("tool") || evidence.Contains("api") || evidence.Contains("http");
    }

    bool IsActionStep(CopilotExecutionStep step)
    {
        var evidence = StepEvidence(step);
        return evidence.Contains("action") || evidence.Contains("assign") || evidence.Contains("update status") || evidence.Contains("comment");
    }

    var knowledgeSteps = allTraceSteps.Where(IsKnowledgeStep).ToList();
    var externalSteps = allTraceSteps.Where(IsExternalStep).ToList();
    var actionSteps = allTraceSteps.Where(IsActionStep).ToList();

    var knowledgeRootSteps = Model.Steps.Where(r => IsKnowledgeStep(r) || GetAllSteps(r.SubSteps).Any(IsKnowledgeStep)).ToList();
    var externalRootSteps = Model.Steps.Where(r => IsExternalStep(r) || GetAllSteps(r.SubSteps).Any(IsExternalStep)).ToList();
    var actionRootSteps = Model.Steps.Where(r => IsActionStep(r) || GetAllSteps(r.SubSteps).Any(IsActionStep)).ToList();

    var dataPlannerRootSteps = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.DataPlanning);
    if (!dataPlannerRootSteps.Any())
    {
        dataPlannerRootSteps = Model.Steps.Where(r => GetAllSteps(r.SubSteps).Any(IsCatalogDataPlanningStep)).ToList();
    }

    var routeEvidence = string.Join(" ", new[]
    {
        Model.DetectedIntent,
        Model.RouteReason,
        Model.Summary,
        Model.SearchQuery,
        string.Join(" ", allTraceSteps.Select(step => $"{step.Action} {step.Detail} {step.TechnicalData}"))
    }).ToLowerInvariant();

    bool dataRoute = queryPlans.Any()
        || dataPlanningSteps.Any()
        || dataExecutionSteps.Any()
        || routeEvidence.Contains("dataquery")
        || routeEvidence.Contains("catalog data intent")
        || routeEvidence.Contains("primaryentity")
        || routeEvidence.Contains("structured")
        || routeEvidence.Contains("outputshape")
        || routeEvidence.Contains("structuredrows")
        || routeEvidence.Contains("structuredcolumns")
        || routeEvidence.Contains("copilotdataqueryexecutorservice");

    bool externalRoute = routeEvidence.Contains("tool")
        || routeEvidence.Contains("external")
        || routeEvidence.Contains("api")
        || routeEvidence.Contains("http");

    bool knowledgeRoute = routeEvidence.Contains("knowledge")
        || routeEvidence.Contains("similar")
        || routeEvidence.Contains("evidence")
        || routeEvidence.Contains("grounded")
        || routeEvidence.Contains("retrieval");

    bool actionRoute = Model.ActionPlan != null
        || routeEvidence.Contains("action")
        || routeEvidence.Contains("assign")
        || routeEvidence.Contains("update status")
        || routeEvidence.Contains("comment");

    bool generalRoute = !dataRoute && !externalRoute && !knowledgeRoute && !actionRoute;

    var actualPath = new List<string> { "Question" };
    if (contextSteps.Any()) { actualPath.Add(CleanActionLabel(contextSteps.First().Action, "Input normalization")); }
    if (decompositionSteps.Any()) { actualPath.Add(CleanActionLabel(decompositionSteps.First().Action, "Request decomposition")); }
    if (routerSteps.Any()) { actualPath.Add(CleanActionLabel(routerSteps.First().Action, "Intent routing")); }
    if (dataRoute || knowledgeRoute || externalRoute || actionRoute || generalRoute) { actualPath.Add("Branch activation"); }
    if (dataRoute) { actualPath.Add("Structured data planning"); }
    if (knowledgeRoute) { actualPath.Add("Knowledge retrieval"); }
    if (externalRoute) { actualPath.Add("Tool invocation"); }
    if (actionRoute) { actualPath.Add("Action planning"); }
    if (dataRoute || knowledgeRoute || externalRoute || actionRoute || generalRoute) { actualPath.Add("Branch merge"); }
    if (executorSteps.Any()) { actualPath.Add(CleanActionLabel(executorSteps.First().Action, "Execution")); }
    if (executorSteps.Any()) { actualPath.Add("Output assembly"); }
    if (queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any()) { actualPath.Add("Structured result"); }
    if (Model.ActionPlan != null) { actualPath.Add("Action result"); }
    if (completeSteps.Any()) { actualPath.Add(CleanActionLabel(completeSteps.First().Action, "Verification")); }
    actualPath.Add("Response");

    string SummarizeSteps(IEnumerable<CopilotExecutionStep> steps)
    {
        var parts = steps
            .Select(step => CleanActionLabel(step.Action, string.Empty))
            .Where(action => !string.IsNullOrWhiteSpace(action))
            .Distinct()
            .Take(3)
            .ToList();

        return parts.Any() ? string.Join(" • ", parts) : "No recorded step details.";
    }

    string SummarizeQueryPlans()
    {
        if (dataPlanningSteps.Any())
        {
            return SummarizeSteps(dataPlanningSteps);
        }

        if (!queryPlans.Any())
        {
            return "No structured query plan was needed for this route.";
        }

        var planParts = queryPlans
            .Select(plan => $"{ResolveStructuredPlanName(plan)} / {plan.Intent}")
            .Distinct()
            .Take(3);

        return string.Join(" • ", planParts);
    }

    string AnswerPreview(string? answer)
    {
        var text = answer ?? string.Empty;
        return text.Length > 180 ? text[..180] + "..." : text;
    }

    string MermaidText(string? value)
    {
        return (value ?? string.Empty)
            .Replace("\\", "\\\\")
            .Replace("\"", "'")
            .Replace("\r", " ")
            .Replace("\n", " ")
            .Trim();
    }

    List<object> ToStepItems(IEnumerable<CopilotExecutionStep> steps)
    {
        return steps.Select(step => (object)new
        {
            layer = step.Layer.ToString(),
            action = step.Action,
            detail = step.Detail,
            status = step.Status.ToString(),
            elapsedMs = step.ElapsedMs,
            technicalData = step.TechnicalData ?? string.Empty,
            subSteps = ToStepItems(step.SubSteps)
        }).ToList();
    }

    List<string> ToTechnicalPayloads(IEnumerable<CopilotExecutionStep> steps)
    {
        var payloads = steps
            .Select(step => step.TechnicalData)
            .Where(value => !string.IsNullOrWhiteSpace(value))
            .Cast<string>()
            .ToList();

        foreach(var step in steps)
        {
            payloads.AddRange(ToTechnicalPayloads(step.SubSteps));
        }

        return payloads.Distinct().ToList();
    }

    List<object> ToLegacyQueryPlanItems(IEnumerable<AdminCopilotDynamicTicketQueryPlan> plans, bool selected)
    {
        return plans.Select(plan => (object)new
        {
            layer = "Plan",
            action = ResolveStructuredPlanName(plan),
            detail = $"{plan.Intent} • max {plan.MaxResults} • sort {plan.SortBy} {plan.SortDirection}",
            status = selected ? "Ok" : "Skip",
            elapsedMs = 0,
            technicalData = string.Empty,
            subSteps = new List<object>()
        }).ToList();
    }

    var dataPlannerStepItems = ToStepItems(dataPlannerRootSteps);
    dataPlannerStepItems.AddRange(ToLegacyQueryPlanItems(queryPlans, dataRoute));

    var queryStrategyRoots = GetLogicalRoots(Model.Steps, CopilotExecutionLayer.DataPlanning, CopilotExecutionLayer.DataExecution);
    if (!queryStrategyRoots.Any())
    {
        queryStrategyRoots = Model.Steps.Where(r => GetAllSteps(r.SubSteps).Any(s => IsCatalogDataPlanningStep(s) || IsCatalogDataExecutionStep(s))).ToList();
    }
    var queryStrategyStepItems = ToStepItems(queryStrategyRoots);
    queryStrategyStepItems.AddRange(ToLegacyQueryPlanItems(queryPlans, queryPlans.Any()));

    var dataPlannerPayloads = ToTechnicalPayloads(dataPlanningSteps);
    var queryStrategyPayloads = ToTechnicalPayloads(allTraceSteps.Where(s => IsCatalogDataPlanningStep(s) || IsCatalogDataExecutionStep(s)));

    var activeLinks = new List<int> { 0, 1, 2 };
    if (dataRoute) { activeLinks.AddRange(new[] { 3, 8 }); }
    if (knowledgeRoute) { activeLinks.AddRange(new[] { 4, 9 }); }
    if (externalRoute) { activeLinks.AddRange(new[] { 5, 10 }); }
    if (actionRoute) { activeLinks.AddRange(new[] { 6, 11 }); }
    if (generalRoute) { activeLinks.AddRange(new[] { 7, 12 }); }

    if (dataRoute || knowledgeRoute || externalRoute || actionRoute || generalRoute)
    {
        activeLinks.AddRange(new[] { 13, 14 });
    }

    if (queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any())
    {
        activeLinks.AddRange(new[] { 15, 18, 20 });
    }

    if (Model.ActionPlan != null)
    {
        activeLinks.AddRange(new[] { 16, 19, 20 });
    }

    if (!queryPlans.Any() && !dataPlanningSteps.Any() && !dataExecutionSteps.Any() && Model.ActionPlan == null)
    {
        activeLinks.Add(17);
    }

    activeLinks.Add(21);

    var activeLinkStyle = string.Join(",", activeLinks.Distinct().OrderBy(value => value));
    
    var activeNodesList = new List<string> { "Q", "PRE", "ROUTE", "FORK", "BRANCHJOIN", "RESULTGATE" };
    if (dataRoute) activeNodesList.Add("DATA");
    if (knowledgeRoute) activeNodesList.Add("KNOW");
    if (externalRoute) activeNodesList.Add("EXT");
    if (actionRoute) activeNodesList.Add("ACT");
    if (generalRoute) activeNodesList.Add("GEN");
    if (executorSteps.Any()) activeNodesList.Add("EXEC");
    if (queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any()) { activeNodesList.Add("PLAN"); activeNodesList.Add("RESULTJOIN"); }
    if (Model.ActionPlan != null) { activeNodesList.Add("ACTION"); activeNodesList.Add("RESULTJOIN"); }
    if (completeSteps.Any()) activeNodesList.Add("VERIFY");
    
    var activeNodesStr = string.Join(",", activeNodesList.Select(n => n + "__" + traceGraphKey));

    var mermaidDefinition = $@"
flowchart LR
    classDef inactive fill:__INACTIVE_FILL__,stroke:__INACTIVE_STROKE__,color:__INACTIVE_TEXT__,stroke-width:1px;
    classDef active fill:__ACTIVE_FILL__,stroke:__ACTIVE_STROKE__,color:__ACTIVE_TEXT__,stroke-width:2px;
    classDef final fill:__FINAL_FILL__,stroke:__FINAL_STROKE__,color:__FINAL_TEXT__,stroke-width:2px;
    classDef error fill:#fee2e2,stroke:#ef4444,color:#b91c1c,stroke-width:2px;

    Q__{traceGraphKey}[""{MermaidText(ViewBag.Trace.Question as string)}""]
    PRE__{traceGraphKey}[""Input normalization<br/>{MermaidText(SummarizeSteps(contextSteps))}""]
    ROUTE__{traceGraphKey}{{""Intent routing<br/>{MermaidText(Model.RouteReason)}""}}
    FORK__{traceGraphKey}{{""Branch activation<br/>Enable every selected path""}}
    DATA__{traceGraphKey}[""Structured data planning<br/>{MermaidText(SummarizeQueryPlans())}""]
    KNOW__{traceGraphKey}[""Knowledge retrieval<br/>Evidence and knowledge lookup""]
    EXT__{traceGraphKey}[""Tool invocation<br/>Tool resolution and API call""]
    ACT__{traceGraphKey}[""Action planning<br/>{MermaidText(Model.ActionPlan?.Intent.ToString() ?? "Not selected")}""]
    GEN__{traceGraphKey}[""General response<br/>Direct conversational path""]
    BRANCHJOIN__{traceGraphKey}((""Branch merge<br/>Merge selected branches""))
    EXEC__{traceGraphKey}[""Execution<br/>{MermaidText(SummarizeSteps(executorSteps))}""]
    RESULTGATE__{traceGraphKey}{{""Output assembly<br/>Choose output artifacts""}}
    PLAN__{traceGraphKey}[""Structured result<br/>{MermaidText(SummarizeQueryPlans())}""]
    ACTION__{traceGraphKey}[""Action result<br/>{MermaidText(Model.ActionPlan?.Summary ?? "No action result")}""]
    RESULTJOIN__{traceGraphKey}((""Artifact merge<br/>Merge result artifacts""))
    VERIFY__{traceGraphKey}[""Verification<br/>{MermaidText(SummarizeSteps(completeSteps))}""]
    RESP__{traceGraphKey}[""Response<br/>{MermaidText(AnswerPreview(ViewBag.Trace.Answer as string))}""]

    Q__{traceGraphKey} --> PRE__{traceGraphKey}
    PRE__{traceGraphKey} --> ROUTE__{traceGraphKey}
    ROUTE__{traceGraphKey} --> FORK__{traceGraphKey}
    FORK__{traceGraphKey} --> DATA__{traceGraphKey}
    FORK__{traceGraphKey} --> KNOW__{traceGraphKey}
    FORK__{traceGraphKey} --> EXT__{traceGraphKey}
    FORK__{traceGraphKey} --> ACT__{traceGraphKey}
    FORK__{traceGraphKey} --> GEN__{traceGraphKey}
    DATA__{traceGraphKey} --> BRANCHJOIN__{traceGraphKey}
    KNOW__{traceGraphKey} --> BRANCHJOIN__{traceGraphKey}
    EXT__{traceGraphKey} --> BRANCHJOIN__{traceGraphKey}
    ACT__{traceGraphKey} --> BRANCHJOIN__{traceGraphKey}
    GEN__{traceGraphKey} --> BRANCHJOIN__{traceGraphKey}
    BRANCHJOIN__{traceGraphKey} --> EXEC__{traceGraphKey}
    EXEC__{traceGraphKey} --> RESULTGATE__{traceGraphKey}
    RESULTGATE__{traceGraphKey} --> PLAN__{traceGraphKey}
    RESULTGATE__{traceGraphKey} --> ACTION__{traceGraphKey}
    RESULTGATE__{traceGraphKey} --> VERIFY__{traceGraphKey}
    PLAN__{traceGraphKey} --> RESULTJOIN__{traceGraphKey}
    ACTION__{traceGraphKey} --> RESULTJOIN__{traceGraphKey}
    RESULTJOIN__{traceGraphKey} --> VERIFY__{traceGraphKey}
    VERIFY__{traceGraphKey} --> RESP__{traceGraphKey}

    class Q__{traceGraphKey},PRE__{traceGraphKey},ROUTE__{traceGraphKey},FORK__{traceGraphKey},DATA__{traceGraphKey},KNOW__{traceGraphKey},EXT__{traceGraphKey},ACT__{traceGraphKey},GEN__{traceGraphKey},BRANCHJOIN__{traceGraphKey},EXEC__{traceGraphKey},RESULTGATE__{traceGraphKey},PLAN__{traceGraphKey},ACTION__{traceGraphKey},RESULTJOIN__{traceGraphKey},VERIFY__{traceGraphKey} inactive;
    class RESP__{traceGraphKey} inactive,final;
    class {activeNodesStr} active;
    class RESP__{traceGraphKey} final;

    {(executorSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class EXEC__{traceGraphKey} error;" : string.Empty)}
    {(completeSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class VERIFY__{traceGraphKey} error;" : string.Empty)}
    {(contextSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class PRE__{traceGraphKey} error;" : string.Empty)}
    {(routerSteps.Any(s => s.Status == CopilotStepStatus.Error) ? $"class ROUTE__{traceGraphKey} error;" : string.Empty)}

    click Q__{traceGraphKey} copilotTraceNodeClick ""Original question received by the copilot.""
    click PRE__{traceGraphKey} copilotTraceNodeClick ""Normalize wording, apply lexical cleanup, and extract routing signals before planning.""
    click ROUTE__{traceGraphKey} copilotTraceNodeClick ""Intent routing. Detected intent: {MermaidText(Model.DetectedIntent)}. Confidence: {Model.PlannerConfidence}. Route reason: {MermaidText(Model.RouteReason)}""
    click FORK__{traceGraphKey} copilotTraceNodeClick ""Branch activation gate. One question can activate data, knowledge, external tool, action, or general chat branches at the same time.""
    click DATA__{traceGraphKey} copilotTraceNodeClick ""Catalog-driven data planning for approved entities, fields, joins, filters, ordering, and output shaping.""
    click KNOW__{traceGraphKey} copilotTraceNodeClick ""Knowledge retrieval path for approved evidence lookup.""
    click EXT__{traceGraphKey} copilotTraceNodeClick ""Tool invocation path for enabled third-party or public API tools.""
    click ACT__{traceGraphKey} copilotTraceNodeClick ""Platform action planning path for assign, status update, escalation, or comment suggestions.""
    click GEN__{traceGraphKey} copilotTraceNodeClick ""Fallback conversational response path without structured retrieval or external tool usage.""
    click BRANCHJOIN__{traceGraphKey} copilotTraceNodeClick ""Branch merge gate. Selected branch outputs are merged into one execution context.""
    click EXEC__{traceGraphKey} copilotTraceNodeClick ""Recorded execution steps: {MermaidText(SummarizeSteps(executorSteps))}""
    click RESULTGATE__{traceGraphKey} copilotTraceNodeClick ""Output assembly gate. Execution output is routed to structured results, action results, or direct verification.""
    click PLAN__{traceGraphKey} copilotTraceNodeClick ""Structured result details: {MermaidText(SummarizeQueryPlans())}""
    click ACTION__{traceGraphKey} copilotTraceNodeClick ""Action result summary: {MermaidText(Model.ActionPlan?.Summary ?? "No action result was created for this trace.")}""
    click RESULTJOIN__{traceGraphKey} copilotTraceNodeClick ""Artifact merge gate. Structured results and action artifacts are merged before final verification.""
    click VERIFY__{traceGraphKey} copilotTraceNodeClick ""Recorded verification steps: {MermaidText(SummarizeSteps(completeSteps))}""
    click RESP__{traceGraphKey} copilotTraceNodeClick ""Final answer returned to the user.""

    linkStyle default stroke:__LINK_DEFAULT__,stroke-width:1.5px,color:__LINK_DEFAULT__,opacity:0.8;
    {(string.IsNullOrWhiteSpace(activeLinkStyle) ? string.Empty : $"linkStyle {activeLinkStyle} stroke:__LINK_ACTIVE__,stroke-width:3px,color:__LINK_ACTIVE__,opacity:1;")}
";
}

@{
    var nodeDetails = new Dictionary<string, object>
    {
        ["Q"] = new
        {
            title = "User question",
            used = true,
            status = "Actual path",
            summary = "The original request that entered the copilot pipeline.",
            beforeLabel = "Raw input",
            beforeValue = ViewBag.Trace.Question?.ToString() ?? string.Empty,
            afterLabel = "Handed to pipeline",
            afterValue = ViewBag.Trace.Question?.ToString() ?? string.Empty,
            steps = new List<object>(),
            payloads = new List<string>()
        },
        ["PRE"] = new
        {
            title = "Input normalization",
            used = contextSteps.Any(),
            status = contextSteps.Any() ? "Actual path" : "No recorded preprocessing step",
            summary = "Normalizes wording, applies lexical cleanup, and extracts cheap routing signals before planning.",
            beforeLabel = "Before",
            beforeValue = ViewBag.Trace.Question?.ToString() ?? string.Empty,
            afterLabel = "After",
            afterValue = !string.IsNullOrWhiteSpace(Model.SearchQuery) ? Model.SearchQuery : SummarizeSteps(contextSteps),
            steps = ToStepItems(contextSteps),
            payloads = ToTechnicalPayloads(contextSteps)
        },
        ["ROUTE"] = new
        {
            title = "Intelligence engine",
            used = routerSteps.Any(),
            status = routerSteps.Any() ? "Actual path" : "No recorded routing step",
            summary = "Splits multi-part requests, chooses the required copilot branches, and explains why each route was selected.",
            beforeLabel = "Before",
            beforeValue = !string.IsNullOrWhiteSpace(Model.SearchQuery) ? Model.SearchQuery : (ViewBag.Trace.Question?.ToString() ?? string.Empty),
            afterLabel = "After",
            afterValue = $"{(string.IsNullOrWhiteSpace(Model.DetectedIntent) ? "Intent not recorded" : Model.DetectedIntent)} • {Model.PlannerConfidence} confidence • {Model.RouteReason}",
            steps = ToStepItems(routerSteps.Concat(decompositionSteps).Distinct()),
            payloads = ToTechnicalPayloads(routerSteps.Concat(decompositionSteps).Distinct())
        },
        ["FORK"] = new
        {
            title = "Branch activation",
            used = dataRoute || knowledgeRoute || externalRoute || actionRoute || generalRoute,
            status = dataRoute || knowledgeRoute || externalRoute || actionRoute || generalRoute ? "Actual path" : "Available gate only",
            summary = "Splits one user question into every required route. A single question can run data, knowledge, external tool, action, and normal chat paths together.",
            beforeLabel = "Before",
            beforeValue = $"{(string.IsNullOrWhiteSpace(Model.DetectedIntent) ? "Intent not recorded" : Model.DetectedIntent)} • {Model.RouteReason}",
            afterLabel = "Selected branches",
            afterValue = string.Join(" • ", new[]
            {
                dataRoute ? "Catalog data" : null,
                knowledgeRoute ? "Knowledge" : null,
                externalRoute ? "External tool" : null,
                actionRoute ? "Action" : null,
                generalRoute ? "General chat" : null
            }.Where(value => !string.IsNullOrWhiteSpace(value))),
            steps = ToStepItems(routerSteps.Concat(decompositionSteps).Distinct()),
            payloads = ToTechnicalPayloads(routerSteps.Concat(decompositionSteps).Distinct())
        },
        ["DATA"] = new
        {
            title = "Structured data planning",
            used = dataRoute,
            status = dataRoute ? "Actual path" : "Available path only",
            summary = "AI-assisted data branch that maps the question to approved catalog entities, fields, filters, joins, grouping, ordering, and output shape.",
            beforeLabel = "Before",
            beforeValue = Model.RouteReason,
            afterLabel = "After",
            afterValue = SummarizeQueryPlans(),
            steps = dataPlannerStepItems,
            payloads = dataPlannerPayloads
        },
        ["KNOW"] = new
        {
            title = "Knowledge retrieval",
            used = knowledgeRoute || knowledgeSteps.Any(),
            status = knowledgeRoute || knowledgeSteps.Any() ? "Actual path" : "Available path only",
            summary = "Retrieval branch for approved knowledge evidence and contextual grounding.",
            beforeLabel = "Before",
            beforeValue = Model.RouteReason,
            afterLabel = "After",
            afterValue = knowledgeSteps.Any() ? SummarizeSteps(knowledgeSteps) : (knowledgeRoute ? "Knowledge evidence path selected for this trace." : "This path was available but not selected."),
            steps = ToStepItems(knowledgeRootSteps),
            payloads = ToTechnicalPayloads(knowledgeSteps)
        },
        ["EXT"] = new
        {
            title = "Tool invocation",
            used = externalRoute || externalSteps.Any(),
            status = externalRoute || externalSteps.Any() ? "Actual path" : "Available path only",
            summary = "Utility branch for enabled third-party or public API tools.",
            beforeLabel = "Before",
            beforeValue = Model.RouteReason,
            afterLabel = "After",
            afterValue = externalSteps.Any() ? SummarizeSteps(externalSteps) : (externalRoute ? "External tool execution selected for this trace." : "This path was available but not selected."),
            steps = ToStepItems(externalRootSteps),
            payloads = ToTechnicalPayloads(externalSteps)
        },
        ["ACT"] = new
        {
            title = "Action planning",
            used = actionRoute || actionSteps.Any(),
            status = actionRoute || actionSteps.Any() ? "Actual path" : "Available path only",
            summary = "Branch for platform action planning such as assign, update status, escalate, or add comment.",
            beforeLabel = "Before",
            beforeValue = Model.RouteReason,
            afterLabel = "After",
            afterValue = actionSteps.Any() ? SummarizeSteps(actionSteps) : (Model.ActionPlan?.Intent.ToString() ?? "No action intent selected."),
            steps = ToStepItems(actionRootSteps),
            payloads = ToTechnicalPayloads(actionSteps)
        },
        ["GEN"] = new
        {
            title = "General response path",
            used = generalRoute,
            status = generalRoute ? "Actual path" : "Available path only",
            summary = "Fallback conversational branch when stronger deterministic or retrieval paths are not needed.",
            beforeLabel = "Before",
            beforeValue = Model.RouteReason,
            afterLabel = "After",
            afterValue = generalRoute ? "General response branch selected." : "This path was available but not selected.",
            steps = new List<object>(),
            payloads = new List<string>()
        },
        ["BRANCHJOIN"] = new
        {
            title = "Branch merge",
            used = dataRoute || knowledgeRoute || externalRoute || actionRoute || generalRoute,
            status = dataRoute || knowledgeRoute || externalRoute || actionRoute || generalRoute ? "Actual path" : "Available gate only",
            summary = "Merges all selected branch outputs into one execution context before the executor runs.",
            beforeLabel = "Incoming branches",
            beforeValue = string.Join(" • ", new[]
            {
                dataRoute ? "Catalog data" : null,
                knowledgeRoute ? "Knowledge" : null,
                externalRoute ? "External tool" : null,
                actionRoute ? "Action" : null,
                generalRoute ? "General chat" : null
            }.Where(value => !string.IsNullOrWhiteSpace(value))),
            afterLabel = "After",
            afterValue = executorSteps.Any() ? "Merged execution context created." : "No recorded executor step.",
            steps = ToStepItems(executorSteps),
            payloads = ToTechnicalPayloads(executorSteps)
        },
        ["EXEC"] = new
        {
            title = "Execution engine",
            used = executorSteps.Any(),
            status = executorSteps.Any() ? "Actual path" : "No recorded execution step",
            summary = "Runs the selected branch and produces raw results before verification.",
            beforeLabel = "Before",
            beforeValue = string.Join(" → ", actualPath.Take(actualPath.IndexOf("Execution") >= 0 ? actualPath.IndexOf("Execution") : actualPath.Count)),
            afterLabel = "After",
            afterValue = SummarizeSteps(executorSteps),
            steps = ToStepItems(executorSteps),
            payloads = ToTechnicalPayloads(executorSteps)
        },
        ["RESULTGATE"] = new
        {
            title = "Result gate",
            used = executorSteps.Any(),
            status = executorSteps.Any() ? "Actual path" : "Available gate only",
            summary = "Decides how execution output should be assembled: structured result, action result, or direct verification.",
            beforeLabel = "Before",
            beforeValue = executorSteps.Any() ? SummarizeSteps(executorSteps) : "No execution output recorded.",
            afterLabel = "Selected outputs",
            afterValue = string.Join(" • ", new[]
            {
                queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any() ? "SQL/query strategy" : null,
                Model.ActionPlan != null ? "Action result" : null,
                completeSteps.Any() ? "Verification" : null
            }.Where(value => !string.IsNullOrWhiteSpace(value))),
            steps = queryStrategyStepItems,
            payloads = queryStrategyPayloads
        },
        ["PLAN"] = new
        {
            title = "Structured result",
            used = queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any(),
            status = queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any() ? "Actual path" : "Not used in this trace",
            summary = "Final validated data plan and SQL execution evidence for admin catalog queries.",
            beforeLabel = "Before",
            beforeValue = dataRoute ? "Selected data planner branch." : "Data planner branch not selected.",
            afterLabel = "After",
            afterValue = SummarizeQueryPlans(),
            steps = queryStrategyStepItems,
            payloads = queryStrategyPayloads
        },
        ["ACTION"] = new
        {
            title = "Action result",
            used = Model.ActionPlan != null,
            status = Model.ActionPlan != null ? "Actual path" : "Not used in this trace",
            summary = "Concrete action result that was produced after route execution.",
            beforeLabel = "Before",
            beforeValue = actionRoute ? "Action path selected." : "Action path not selected.",
            afterLabel = "After",
            afterValue = Model.ActionPlan?.Summary ?? "No action result created.",
            steps = Model.ActionPlan == null
                ? new List<object>()
                : new List<object>
                {
                    new
                    {
                        layer = "Action",
                        action = Model.ActionPlan.Intent.ToString(),
                        detail = Model.ActionPlan.Summary,
                        status = "Ok",
                        elapsedMs = 0,
                        technicalData = string.Empty,
                        subSteps = new List<object>()
                    }
                }.Cast<object>().ToList(),
            payloads = new List<string>()
        },
        ["RESULTJOIN"] = new
        {
            title = "Artifact merge",
            used = queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any() || Model.ActionPlan != null,
            status = queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any() || Model.ActionPlan != null ? "Actual path" : "Available gate only",
            summary = "Combines query results and action artifacts before the verification step finalizes the answer.",
            beforeLabel = "Incoming artifacts",
            beforeValue = string.Join(" • ", new[]
            {
                queryPlans.Any() || dataPlanningSteps.Any() || dataExecutionSteps.Any() ? "Data result" : null,
                Model.ActionPlan != null ? "Action plan" : null
            }.Where(value => !string.IsNullOrWhiteSpace(value))),
            afterLabel = "After",
            afterValue = completeSteps.Any() ? "Artifacts sent to verification." : "No recorded verification step.",
            steps = ToStepItems(completeSteps),
            payloads = ToTechnicalPayloads(completeSteps)
        },
        ["VERIFY"] = new
        {
            title = "Verification engine",
            used = completeSteps.Any(),
            status = completeSteps.Any() ? "Actual path" : "No recorded verification step",
            summary = "Final checks and answer packaging before the response is returned.",
            beforeLabel = "Before",
            beforeValue = executorSteps.Any() ? SummarizeSteps(executorSteps) : "No recorded execution summary.",
            afterLabel = "After",
            afterValue = SummarizeSteps(completeSteps),
            steps = ToStepItems(completeSteps),
            payloads = ToTechnicalPayloads(completeSteps)
        },
        ["RESP"] = new
        {
            title = "Final response",
            used = true,
            status = "Actual path",
            summary = "The answer that was finally returned to the user.",
            beforeLabel = "Before",
            beforeValue = completeSteps.Any() ? SummarizeSteps(completeSteps) : "Verification completed.",
            afterLabel = "After",
            afterValue = ViewBag.Trace.Answer?.ToString() ?? string.Empty,
            steps = new List<object>(),
            payloads = new List<string>()
        }
    };
}

<div id="@traceRootId" data-trace-graph-key="@traceGraphKey" data-default-trace-view="@defaultTraceView" class="glass-card mb-4 border-1 copilot-trace-detail-root" style="background: var(--bg-card); position: relative; overflow: visible;">
    <!-- Tech Background Pattern -->
    <div style="position: absolute; inset: 0; background-image: radial-gradient(rgba(var(--primary-color-rgb), 0.1) 1px, transparent 1px); background-size: 24px 24px; opacity: 0.4; pointer-events: none;"></div>
    
    <div class="glass-header d-flex justify-content-between align-items-center py-2 border-bottom position-relative z-1" style="background: rgba(var(--primary-color-rgb), 0.02); border-color: var(--border-color) !important;">
        <div class="d-flex align-items-center gap-3">
            <div class="rounded-pill bg-primary bg-opacity-10 border border-primary border-opacity-25 shadow-sm d-flex align-items-center justify-content-center" style="width: 40px; height: 40px;">
                <i class="bi bi-shield-check text-primary fs-5"></i>
            </div>
            <div>
                <h5 class="mb-0 fw-black text-main" style="letter-spacing: -0.02em; font-size: 1.1rem;">@Loc.Get("ExecutionStoryTrack")</h5>
                <div class="text-muted small fw-bold text-uppercase" style="letter-spacing: 0.1em; font-size: 0.6rem;">@Loc.Get("ForensicAnalysisTrace")</div>
            </div>
        </div>
        <div class="d-flex align-items-center gap-2 flex-wrap justify-content-end">
            <div class="badge bg-primary bg-opacity-10 border border-primary border-opacity-25 text-primary rounded-pill px-4 py-2 fs-6 fw-bold shadow-sm d-flex align-items-center gap-2">
                <i class="bi bi-stopwatch"></i>
                <span>@ViewBag.Trace.TotalElapsedMs <span class="opacity-75 fs-7">ms</span></span>
            </div>
        </div>
    </div>
    <div class="glass-body p-0 position-relative z-1">
        <div class="p-3 p-lg-4">
            <div class="d-flex justify-content-between align-items-center gap-3 flex-wrap mb-4">
                <div class="copilot-tree-legend">
                    <span class="copilot-tree-legend-item copilot-tree-legend-item-active"><span class="copilot-tree-legend-dot"></span>@Loc.Get("ActualPath")</span>
                    <span class="copilot-tree-legend-item"><span class="copilot-tree-legend-dot"></span>@Loc.Get("AvailablePath")</span>
                </div>
                <div class="copilot-trace-view-toggle" role="tablist" aria-label="Trace view mode">
                    <button type="button" id="@storyToggleId" class="copilot-trace-view-btn is-active" data-trace-view-target="story" aria-pressed="true">
                        <i class="bi bi-list-ul"></i> @Loc.Get("Story")
                    </button>
                    <button type="button" id="@treeToggleId" class="copilot-trace-view-btn" data-trace-view-target="tree" aria-pressed="false">
                        <i class="bi bi-diagram-3"></i> @Loc.Get("Tree")
                    </button>
                </div>
            </div>
            <div class="copilot-trace-view-shell">
                <div class="copilot-story-view">
                    <div class="copilot-story-timeline">
                
                        <!-- START NODE: THE QUESTION -->
                        <div class="copilot-story-step">
                            <div class="copilot-story-dot bg-primary bg-opacity-10 border border-primary border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                <i class="bi bi-person-fill text-primary" style="font-size: 1rem;"></i>
                            </div>
                            <div class="copilot-story-content shadow-sm border border-secondary border-opacity-10" style="background: var(--bg-card); border-radius: var(--radius-btn, 14px);">
                                <div class="small fw-bold text-uppercase text-muted mb-1" style="font-size: 0.65rem;">@Loc.Get("SystemInput")</div>
                                <div class="fw-bold mb-0" style="color: var(--text-main); font-size: 0.95rem;">@ViewBag.Trace.Question</div>
                            </div>
                        </div>

                        <!-- NEW: REASONING INTENT & PLAN -->
                        <div class="copilot-story-step">
                            <div class="copilot-story-dot bg-warning bg-opacity-10 border border-warning border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                <i class="bi bi-compass-fill text-warning" style="font-size: 1rem;"></i>
                            </div>
                            <div class="copilot-story-content shadow-sm border border-warning border-opacity-10" style="background: rgba(var(--secondary-color-rgb, 245, 158, 11), 0.02); border-radius: var(--radius-btn, 14px);">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <span class="small fw-bold text-uppercase text-warning" style="font-size: 0.65rem;">@Loc.Get("ReasoningIntentPlan")</span>
                                    <span class="badge rounded-pill @(Model.PlannerConfidence == RoutingConfidence.High ? "bg-success" : Model.PlannerConfidence == RoutingConfidence.Medium ? "bg-warning" : "bg-danger") px-2" style="font-size: 0.6rem;">@Model.PlannerConfidence Confidence</span>
                                </div>
                                <div class="fw-bold mb-1" style="color: var(--text-main); font-size: 0.85rem;">@Model.RouteReason</div>
                                @if (!string.IsNullOrEmpty(Model.SearchQuery))
                                {
                                    <div class="mt-2 text-muted xsmall" style="font-size: 0.75rem;">
                                        <i class="bi bi-search me-1"></i> <span class="opacity-75">@Loc.Get("InvestigationQuery"):</span> <span class="text-info">"@Model.SearchQuery"</span>
                                    </div>
                                }
                            </div>
                        </div>

                        <!-- MIDDLE NODES: THE REASONING STEPS -->
                        @{
                            void RenderStoryStep(CopilotExecutionStep step, int level = 0)
                            {
                                var stepId = $"step-{Guid.NewGuid():N}";
                                <div class="copilot-story-step @(level > 0 ? "is-sub-step" : "")" style="margin-left: @(level * 2)rem;">
                                    @if (level > 0)
                                    {
                                        <div class="copilot-story-connector" style="left: -1rem; width: 1rem;"></div>
                                    }
                                    <div class="copilot-story-dot" style="background: var(--bg-card); border-radius: 10px; width: @(level > 0 ? "26px" : "32px"); height: @(level > 0 ? "26px" : "32px"); z-index: 5;">
                                        @switch (step.Status)
                                        {
                                            case CopilotStepStatus.Ok:
                                                <i class="bi bi-check-circle-fill text-success" style="font-size: @(level > 0 ? "1rem" : "1.2rem");"></i>
                                                break;
                                            case CopilotStepStatus.Warn:
                                                <i class="bi bi-exclamation-circle-fill text-warning" style="font-size: @(level > 0 ? "1rem" : "1.2rem");"></i>
                                                break;
                                            case CopilotStepStatus.Error:
                                                <i class="bi bi-x-circle-fill text-danger" style="font-size: @(level > 0 ? "1rem" : "1.2rem");"></i>
                                                break;
                                            default:
                                                <i class="bi bi-circle text-muted"></i>
                                                break;
                                        }
                                    </div>
                                    <div class="copilot-story-content shadow-sm border border-secondary border-opacity-10" style="background: var(--bg-card); border-radius: 16px; transition: transform 0.2s ease;">
                                        <div class="d-flex justify-content-between align-items-center mb-1">
                                            <div class="d-flex align-items-center gap-2">
                                                <span class="badge bg-soft-primary text-primary fw-bold px-2 py-1" style="font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.05em;">@step.Layer</span>
                                                @if (level > 0)
                                                {
                                                    <span class="badge bg-soft-secondary text-muted px-2 py-1" style="font-size: 0.6rem; text-transform: uppercase;">Sub-process</span>
                                                }
                                            </div>
                                            <span class="copilot-story-time text-muted fw-bold" style="font-size: 0.7rem;">@step.ElapsedMs ms</span>
                                        </div>
                                        <div class="copilot-story-action fw-bold mb-1" style="color: var(--text-main); font-size: 0.9rem;">@step.Action</div>
                                        <div class="copilot-story-detail text-muted mb-2" style="line-height: 1.5; font-size: 0.85rem;">@step.Detail</div>
                                
                                        @if (!string.IsNullOrEmpty(step.TechnicalData))
                                        {
                                            <div class="mt-3">
                                                <button class="btn btn-soft-primary btn-xs rounded-pill px-3 fw-bold d-flex align-items-center gap-2" 
                                                        type="button" 
                                                        data-bs-toggle="collapse" 
                                                        data-bs-target="#@stepId" 
                                                        aria-expanded="false" 
                                                        style="font-size: 0.65rem;">
                                                    <i class="bi bi-code-slash"></i> @Loc.Get("InspectPayload")
                                                </button>
                                                <div class="collapse mt-2" id="@stepId">
                                                    <div class="copilot-story-payload-shell p-0 overflow-hidden" style="border-radius: 10px; border: 1px solid var(--border-color);">
                                                        <div class="bg-dark bg-opacity-5 px-3 py-2 border-bottom d-flex justify-content-between align-items-center" style="border-color: var(--border-color) !important;">
                                                            <span class="xsmall fw-bold text-muted text-uppercase" style="font-size: 0.6rem; letter-spacing: 0.1em;">@Loc.Get("TechnicalPayloads")</span>
                                                            <button class="btn btn-link btn-xs p-0 text-muted" onclick="copyToClipboard(this, '@Html.Raw(System.Web.HttpUtility.JavaScriptStringEncode(step.TechnicalData))')">
                                                                <i class="bi bi-clipboard"></i>
                                                            </button>
                                                        </div>
                                                        <textarea class="copilot-story-payload-source d-none">@step.TechnicalData</textarea>
                                                        <div class="copilot-story-payload-host">
                                                            <div class="copilot-code-block p-0 m-0">
                                                                <pre class="m-0 p-3" style="font-size: 0.75rem; line-height: 1.5; background: #1e1e1e;"><code class="language-json">@step.TechnicalData</code></pre>
                                                            </div>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                                
                                if (step.SubSteps.Any())
                                {
                                    <div class="copilot-substeps-container position-relative">
                                        <div class="copilot-substeps-vertical-line" style="position: absolute; left: calc(@(level * 2)rem + 1rem); top: 0; bottom: 1.5rem; width: 2px; background: var(--border-color); opacity: 0.5;"></div>
                                        @foreach (var sub in step.SubSteps)
                                        {
                                            RenderStoryStep(sub, level + 1);
                                        }
                                    </div>
                                }
                            }
                        }

                        @foreach (var step in Model.Steps)
                        {
                            RenderStoryStep(step);
                        }
                
                        @if (Model.QueryPlan != null && !dataPlanningSteps.Any())
                        {
                            <div class="copilot-story-step">
                                <div class="copilot-story-dot bg-info bg-opacity-10 border border-info border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                    <i class="bi bi-database-fill-gear text-info" style="font-size: 1rem;"></i>
                                </div>
                                <div class="copilot-story-content shadow-sm border border-info border-opacity-10" style="background: rgba(var(--primary-color-rgb), 0.02); border-radius: var(--radius-btn, 14px);">
                                    <div class="small fw-bold text-uppercase text-info mb-1" style="font-size: 0.65rem;">@Loc.Get("AnalyticalQueryStrategy")</div>
                                    <div class="fw-bold mb-2" style="font-size: 0.85rem; color: var(--text-main);">@Model.QueryPlan.Summary</div>
                            
                                    <div class="row g-2">
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">Target Catalog Area</div>
                                            <div class="small fw-bold">@ResolveStructuredPlanName(Model.QueryPlan)</div>
                                        </div>
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">Intent Mode</div>
                                            <div class="small fw-bold">@Model.QueryPlan.Intent</div>
                                        </div>
                                        @if (!string.IsNullOrEmpty(Model.QueryPlan.EntityName)) {
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">Entity Filter</div>
                                            <div class="small fw-bold">@Model.QueryPlan.EntityName</div>
                                        </div>
                                        }
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">Date Range</div>
                                            <div class="small fw-bold">@Model.QueryPlan.RelativeDateRange</div>
                                        </div>
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">Max Results</div>
                                            <div class="small fw-bold">@Model.QueryPlan.MaxResults</div>
                                        </div>
                                        <div class="col-6 col-md-4">
                                            <div class="xsmall text-muted text-uppercase mb-1" style="font-size: 0.6rem;">@Loc.Get("SortLogic")</div>
                                            <div class="small fw-bold">@Model.QueryPlan.SortBy (@Model.QueryPlan.SortDirection)</div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        @if (Model.ActionPlan != null)
                        {
                            <div class="copilot-story-step">
                                <div class="copilot-story-dot bg-success bg-opacity-10 border border-success border-opacity-25 shadow-sm" style="border-radius: 10px;">
                                    <i class="bi bi-lightning-charge-fill text-success" style="font-size: 1rem;"></i>
                                </div>
                            <div class="copilot-story-content shadow-sm border border-primary border-opacity-25" style="background: rgba(var(--primary-color-rgb), 0.02); border-radius: var(--radius-btn, 14px);">
                                    <div class="small fw-bold text-uppercase text-success mb-1" style="font-size: 0.65rem;">@Loc.Get("PlatformActionSuggestion")</div>
                                    <div class="fw-bold mb-1" style="font-size: 0.85rem; color: var(--text-main);">@Model.ActionPlan.Summary</div>
                                    <div class="small text-muted">@Loc.Get("ActionIntent"): @Model.ActionPlan.Intent</div>
                                </div>
                            </div>
                        }

                        <!-- END NODE: THE ANSWER -->
                        <div class="copilot-story-step copilot-story-step-last">
                            <div class="copilot-story-dot bg-premium-gradient border-0 shadow-sm" style="border-radius: 10px; background: linear-gradient(135deg, var(--primary-color) 0%, #a855f7 100%);">
                                <i class="bi bi-stars text-white" style="font-size: 1rem;"></i>
                            </div>
                            <div class="copilot-story-content shadow-sm border border-primary border-opacity-25" style="background: rgba(var(--primary-color-rgb), 0.05); border-radius: var(--radius-btn, 14px);">
                                <div class="small fw-bold text-uppercase text-primary mb-1" style="font-size: 0.65rem;">@Loc.Get("GeneratedResolution")</div>
                                <div class="mb-0" style="color: var(--text-main); font-size: 1rem; line-height: 1.6;">@ViewBag.Trace.Answer</div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="copilot-tree-view">
                    <div class="copilot-tree-intro">
                        <div class="copilot-tree-intro-title">@Loc.Get("FullRouteMap")</div>
                        <div class="copilot-tree-intro-text">@Loc.Get("MajorBranchesNote")</div>
                    </div>

                    <div class="copilot-tree-path-bar">
                        <div class="copilot-tree-path-bar-label">@Loc.Get("ActualPathTaken")</div>
                        <div class="copilot-tree-path-bar-value">@string.Join(" → ", actualPath)</div>
                    </div>
                    <div class="copilot-mermaid-shell">
                        <div class="copilot-mermaid-toolbar">
                            <div class="copilot-mermaid-toolbar-title">
                                <i class="bi bi-diagram-3"></i>
                                <span>@Loc.Get("WorkflowDiagram")</span>
                            </div>
                            <div class="copilot-mermaid-toolbar-actions" aria-label="@Loc.Get("WorkflowDiagram")">
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="zoom-out" title="@Loc.Get("ZoomOut")" aria-label="@Loc.Get("ZoomOut")">
                                    <i class="bi bi-dash-lg"></i>
                                </button>
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="zoom-in" title="@Loc.Get("ZoomIn")" aria-label="@Loc.Get("ZoomIn")">
                                    <i class="bi bi-plus-lg"></i>
                                </button>
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="reset" title="@Loc.Get("ResetView")" aria-label="@Loc.Get("ResetView")">
                                    <i class="bi bi-arrows-fullscreen"></i>
                                </button>
                                <button type="button" class="copilot-mermaid-control" data-copilot-diagram-action="download" title="@Loc.Get("DownloadImage")" aria-label="@Loc.Get("DownloadImage")">
                                    <i class="bi bi-download"></i>
                                </button>
                            </div>
                        </div>
                        <div class="copilot-mermaid-viewport">
                            <div class="copilot-mermaid-graph" data-trace-mermaid-id="trace-mermaid-@traceId"></div>
                        </div>
                        <pre class="copilot-mermaid-definition d-none">@mermaidDefinition</pre>
                    </div>
                    <div class="copilot-trace-node-panel d-none mt-4">
                        <div class="copilot-trace-node-panel-header">
                            <div>
                                <div class="copilot-trace-node-panel-label">@Loc.Get("StepInspector")</div>
                                <div class="copilot-trace-node-panel-title"></div>
                            </div>
                            <span class="copilot-trace-node-panel-status badge rounded-pill"></span>
                        </div>
                        <div class="copilot-trace-node-panel-summary"></div>
                        <div class="row g-3 mt-1">
                            <div class="col-12 col-lg-6">
                                <div class="copilot-trace-node-box">
                                    <div class="copilot-trace-node-box-label copilot-trace-node-before-label"></div>
                                    <div class="copilot-trace-node-box-value copilot-trace-node-before-value"></div>
                                </div>
                            </div>
                            <div class="col-12 col-lg-6">
                                <div class="copilot-trace-node-box">
                                    <div class="copilot-trace-node-box-label copilot-trace-node-after-label"></div>
                                    <div class="copilot-trace-node-box-value copilot-trace-node-after-value"></div>
                                </div>
                            </div>
                        </div>
                        <div class="copilot-trace-node-substeps mt-4 d-none">
                            <div class="copilot-trace-node-section-title">@Loc.Get("RecordedSubsteps")</div>
                            <div class="copilot-trace-node-substeps-list"></div>
                        </div>
                        <div class="copilot-trace-node-payloads mt-4 d-none">
                            <div class="copilot-trace-node-section-title d-flex align-items-center gap-2">
                                <i class="bi bi-box-seam"></i>
                                <span>@Loc.Get("TechnicalPayloads")</span>
                            </div>
                            <div class="copilot-trace-node-payloads-list mt-3"></div>
                        </div>
                    </div>
                    <script type="application/json" class="copilot-trace-node-data">@Html.Raw(Json.Serialize(nodeDetails))</script>
                </div>
            </div>
        </div>
        </div>
        
        <!-- Metadata Footer -->
        <div class="p-4 border-top border-secondary border-opacity-10 mt-4 position-relative z-1" style="background: rgba(var(--primary-color-rgb), 0.02);">
            <div class="row align-items-center text-center text-muted small fw-bold text-uppercase" style="font-size: 0.7rem; letter-spacing: 0.05em;">
                <div class="col-4 border-end border-secondary border-opacity-10">
                    <div class="mb-1" style="color: var(--primary-color);"><i class="bi bi-cpu-fill me-1"></i> @Loc.Get("Model")</div>
                    <span class="text-main">@ViewBag.Trace.ModelName</span>
                </div>
                <div class="col-4 border-end border-secondary border-opacity-10">
                    <div class="mb-1" style="color: var(--primary-color);"><i class="bi bi-calendar-event me-1"></i> @Loc.Get("Timestamp")</div>
                    <span class="text-main">@ViewBag.Trace.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</span>
                </div>
                <div class="col-4">
                    <div class="mb-1" style="color: var(--primary-color);"><i class="bi bi-hash me-1"></i> @Loc.Get("StoryId")</div>
                    <span class="text-main badge bg-dark text-white rounded-pill border border-secondary border-opacity-25 px-3 py-1 shadow-sm">@ViewBag.Trace.Id</span>
                </div>
            </div>
        </div>
    </div>
</div>
