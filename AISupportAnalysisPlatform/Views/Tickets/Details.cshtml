            @* 2. Intelligence Sidebar Block (Sticky Indicators) *@
            @if (ViewBag.IsAdmin == true)
            {
                <div id="ai-sidebar-indicators" class="card border-0 shadow-sm mb-4 d-none" style="background: var(--bg-card); border: 1px solid rgba(99,102,241,0.2) !important;">
