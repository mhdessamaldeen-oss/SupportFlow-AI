@model AISupportAnalysisPlatform.Models.Ticket

@{
    ViewData["Title"] = Loc.Get("TicketDetails");
}

@section Styles {
    <link rel="stylesheet" href="~/css/ticket-details.css" asp-append-version="true" />
}

@if (TempData["Success"] != null)
{
    <div class="alert alert-success border-0 shadow-sm alert-dismissible fade show mb-4 animate__animated animate__fadeInDown" role="alert">
        <i class="bi bi-check-circle-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i> @TempData["Success"]
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm alert-dismissible fade show mb-4 animate__animated animate__fadeInDown" role="alert">
        <i class="bi bi-exclamation-triangle-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i> @TempData["Error"]
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row align-items-start g-4">
    @* --- MAIN WORKSPACE AREA --- *@
    <div class="col-lg-8 order-2 order-lg-1">
        @* Ticket Header Title & Badges *@
        <div class="card card-premium mb-4 overflow-hidden animate__animated animate__fadeIn">
            <div class="card-body p-4">
                <div class="d-flex justify-content-between align-items-start mb-3">
                    <div>
                        <div class="d-flex align-items-center gap-2 mb-2">
                             <h2 class="fw-bold mb-0 text-main">#@Model.TicketNumber</h2>
                             <span class="badge bg-primary-subtle rounded-pill">@Loc.Get("SupportTicket")</span>
                        </div>
                        <h4 class="fw-bold mb-1 text-main">@Model.Title</h4>
                    </div>
                    <div class="d-flex gap-2">
                         <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-sm btn-outline-primary rounded-pill">
                            <i class="bi bi-pencil @(Loc.IsRtl ? "ms-1" : "me-1")"></i>@Loc.Get("Edit")
                         </a>
                         <div class="dropdown">
                            <button class="btn btn-icon btn-sm btn-soft-secondary shadow-none" type="button" data-bs-toggle="dropdown">
                                <i class="bi bi-three-dots"></i>
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 dropdown-premium">
                                <li>
                                    <form asp-action="Delete" asp-route-id="@Model.Id" method="post" onsubmit="return confirm('@Loc.Get("ArchiveConfirm")');">
                                        <button type="submit" class="dropdown-item text-danger d-flex align-items-center">
                                            <i class="bi bi-trash-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("ArchiveTicket")
                                        </button>
                                    </form>
                                </li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-action="Index">@Loc.Get("BackToGrid")</a></li>
                            </ul>
                         </div>
                    </div>
                </div>
                
                <div class="d-flex align-items-center text-muted small">
                    <div class="avatar-sm avatar-premium @(Loc.IsRtl ? "ms-2" : "me-2")" style="width: 24px; height: 24px; font-size: 0.7rem;">
                        @(!string.IsNullOrEmpty(Model.CreatedByUser?.FirstName) ? Model.CreatedByUser.FirstName[0] : (!string.IsNullOrEmpty(Model.CreatedByUser?.UserName) ? Model.CreatedByUser.UserName[0] : 'U'))
                    </div>
                    <span>@Loc.Get("ReportedBy") <span class="fw-bold text-main">@(Model.CreatedByUser?.FullName ?? Loc.Get("Unknown"))</span> @Loc.Get("From") <span class="badge" style="background: rgba(255,255,255,0.05) !important;">@(Model.Entity?.Name ?? Loc.Get("General"))</span> • @Model.CreatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                </div>
            </div>
        </div>

        @* Quick Intelligence Glance (If AI run exists) *@
        @if (ViewBag.IsAdmin == true)
        {
            <div id="ai-quick-glance" class="intelligence-glance d-none animate__animated animate__fadeIn">
                <div class="d-flex align-items-center gap-3">
                    <div class="flex-shrink-0">
                        <div class="rounded-circle d-flex align-items-center justify-content-center shadow-lg" style="width:42px;height:42px;background:linear-gradient(135deg,#6366f1,#818cf8);">
                            <i class="bi bi-stars text-white"></i>
                        </div>
                    </div>
                    <div class="flex-grow-1">
                        <h6 class="fw-bold mb-1" style="color:#818cf8;">@Loc.Get("IntelligenceAnalysisStatus")</h6>
                        <p id="ai-glance-summary" class="small mb-0 text-muted text-truncate" style="max-width: 500px;"></p>
                    </div>
                    <div class="d-flex gap-2">
                        <span id="glance-sentiment-badge" class="badge rounded-pill"></span>
                        <span id="glance-review-badge" class="badge rounded-pill d-none"></span>
                    </div>
                </div>
            </div>
        }
        @* ── Simple Tabbed Workspace ── *@
        <ul class="nav nav-pills ticket-tabset animate__animated animate__fadeIn" id="ticketTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active fw-bold px-4 rounded-pill shadow-sm" id="inquiry-tab" data-bs-toggle="tab" data-bs-target="#inquiry-content" type="button" role="tab">
                    <i class="bi bi-info-circle-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("Details")
                </button>
            </li>
            @if (ViewBag.IsAdmin == true)
            {
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 rounded-pill shadow-sm" id="related-tab" data-bs-toggle="tab" data-bs-target="#related-content" type="button" role="tab">
                        <i class="bi bi-diagram-3-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("RelatedCases")
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 rounded-pill shadow-sm d-flex align-items-center" id="ai-tab" data-bs-toggle="tab" data-bs-target="#ai-content" type="button" role="tab">
                        <i class="bi bi-cpu-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("TicketAnalysis")
                        <span id="ai-tab-badge" class="ms-2 badge rounded-pill bg-primary pulse-badge d-none" style="font-size: 0.6rem;">@Loc.Get("Ready")</span>
                    </button>
                </li>
            }
        </ul>

        <div class="tab-content ticket-tab-panel" id="ticketTabsContent">
            @* ── 1. Standard Profile Tab ── *@
            <div class="tab-pane fade show active" id="inquiry-content" role="tabpanel">
                <div class="card card-premium mb-4">
                    <div class="card-body p-4 pt-4">
                        <div class="p-4 rounded-4 card-inner-premium">
                            <h6 class="text-uppercase fw-bold small mb-3 text-muted-custom" style="letter-spacing: 1px;">@Loc.Get("TicketDescription")</h6>
                            <div class="text-main" style="line-height: 1.6; white-space: pre-wrap;">@Model.Description</div>
                        </div>
                        @if (Model.ParentTicketId.HasValue)
                        {
                            <div class="mt-4 p-4 rounded-4" style="background: var(--bg-main) !important; border: 1px solid var(--primary-color) !important;">
                                <h6 class="text-uppercase fw-bold small mb-3" style="letter-spacing: 1px; color: var(--primary-color) !important;"><i class="bi bi-link-45deg @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("ParentTicket")</h6>
                                <div>
                                    <a asp-action="Details" asp-route-id="@Model.ParentTicketId" class="text-decoration-none" style="color: var(--text-main) !important;">
                                        <strong>@Model.ParentTicket?.TicketNumber</strong> - @Model.ParentTicket?.Title
                                    </a>
                                </div>
                            </div>
                        }

                        @if (Model.ChildTickets != null && Model.ChildTickets.Any(t => !t.IsDeleted))
                        {
                            <div class="mt-4 p-4 rounded-4" style="background: var(--bg-main) !important; border: 1px solid var(--border-color) !important;">
                                <h6 class="text-uppercase fw-bold small mb-3" style="letter-spacing: 1px; color: var(--text-muted) !important;"><i class="bi bi-diagram-2 @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("ChildTickets") (@Loc.Get("ContinuingContext"))</h6>
                                <div class="list-group list-group-flush bg-transparent">
                                    @foreach (var child in Model.ChildTickets.Where(t => !t.IsDeleted))
                                    {
                                        <a asp-action="Details" asp-route-id="@child.Id" class="list-group-item list-group-item-action bg-transparent border-light py-2 px-0" style="color: var(--text-main) !important;">
                                            <strong>@child.TicketNumber</strong> - @child.Title
                                        </a>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>

                <div class="card card-premium mb-4">
                    <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent d-flex justify-content-between align-items-center">
                        <h5 class="fw-bold mb-0 text-main">@Loc.Get("Comments")</h5>
                        <span class="badge bg-light text-muted-custom fw-normal" style="background: rgba(255,255,255,0.05) !important; border: 1px solid var(--border-color) !important;">@Model.Comments.Count() @Loc.Get("Comments")</span>
                    </div>
                    <div class="card-body p-4">
                        <div class="comment-timeline mb-5">
                            @if (Model.Comments.Any())
                            {
                                @foreach(var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
                                {
                                    <div class="d-flex mb-4 pb-4 border-bottom border-light">
                                        <div class="avatar-sm bg-light-primary text-secondary rounded-circle d-flex align-items-center justify-content-center fw-bold @(Loc.IsRtl ? "ms-3" : "me-3") flex-shrink-0" style="width: 40px; height: 40px;">
                                            @(!string.IsNullOrEmpty(comment.CreatedByUser?.FirstName) ? comment.CreatedByUser.FirstName[0] : (!string.IsNullOrEmpty(comment.CreatedByUser?.UserName) ? comment.CreatedByUser.UserName[0] : 'U'))
                                        </div>
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="fw-bold text-dark">@(comment.CreatedByUser?.FullName ?? Loc.Get("User"))</span>
                                                <span class="text-muted small">@comment.CreatedAt.ToString("MMM dd, HH:mm")</span>
                                            </div>
                                            <div class="text-muted-custom" style="font-size: 0.95rem;">@comment.Content</div>
                                            @if (comment.Attachments != null && comment.Attachments.Any())
                                            {
                                                <div class="mt-3 d-flex flex-wrap gap-2">
                                                    @foreach (var att in comment.Attachments)
                                                    {
                                                        <a href="@att.FilePath" target="_blank" class="badge rounded-pill text-decoration-none px-3 py-2" style="background: rgba(99,102,241,0.1); color: #818cf8; border: 1px solid rgba(99,102,241,0.2);">
                                                            <i class="bi bi-paperclip @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @att.FileName
                                                        </a>
                                                    }
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-5">
                                    <i class="bi bi-chat-dots fs-1 opacity-25 d-block mb-3"></i>
                                    <p class="text-muted">@Loc.Get("NoCommunication")</p>
                                </div>
                            }
                        </div>

                        <div class="p-4 rounded-4 border shadow-sm" style="background: rgba(99,102,241,0.05); border-color: rgba(99,102,241,0.2) !important;">
                            <form asp-controller="Comments" asp-action="Add" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="ticketId" value="@Model.Id" />
                                <label class="form-label fw-bold small text-uppercase mb-2 text-main" style="opacity: 0.8;">@Loc.Get("AddComment")</label>
                                <textarea class="form-control border-0 shadow-none mb-3 input-premium" name="content" rows="3" placeholder="@Loc.Get("CommentPlaceholder")" required></textarea>
                                <div class="mb-3">
                                    <label class="form-label fw-bold small text-uppercase mb-2 text-main" style="opacity: 0.8;">@Loc.Get("SupplementalArtifacts")</label>
                                    <input type="file" name="files" class="form-control shadow-none input-premium" multiple />
                                </div>
                                <div class="text-end">
                                    <button type="submit" class="btn btn-primary px-4 fw-bold shadow-sm rounded-pill">
                                        <i class="bi bi-send-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("PostComment")
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>

            @if (ViewBag.IsAdmin == true)
            {
                <div class="tab-pane fade" id="related-content" role="tabpanel">
                    <div class="card card-premium overflow-hidden animate__animated animate__fadeIn">
                        <div class="card-header border-0 p-4 bg-transparent" style="background: linear-gradient(90deg, rgba(var(--primary-color-rgb),0.1), transparent) !important;">
                            <div class="d-flex justify-content-between align-items-center flex-wrap gap-3">
                                <div>
                                    <h5 class="fw-bold mb-1 text-main">@Loc.Get("RelatedSolutions")</h5>
                                    <p class="text-muted-custom small mb-0">@Loc.Get("SolutionSearchSubtitle")</p>
                                </div>
                                <div class="d-flex align-items-center gap-2 flex-wrap">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="dropdown">
                                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle px-3 py-2 rounded-pill shadow-none text-main border-premium" type="button" data-bs-toggle="dropdown" data-bs-auto-close="outside">
                                            <i class="bi bi-funnel @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("StatusFilters")
                                        </button>
                                        <div class="dropdown-menu filter-dropdown-menu border-0 shadow-lg">
                                            <h6 class="dropdown-header mb-2" style="color: var(--text-muted);">@Loc.Get("SelectOneStatus")</h6>
                                            <div id="semantic-status-checkboxes" class="px-2">
                                                @foreach (var option in (IEnumerable<SelectListItem>)(ViewBag.SemanticStatusOptions ?? Enumerable.Empty<SelectListItem>()))
                                                {
                                                    <div class="form-check filter-option-item">
                                                        <input class="form-check-input semantic-status-chk shadow-none" type="checkbox" value="@option.Value" id="chk-@option.Value" @(option.Selected ? "checked" : "")>
                                                        <label class="form-check-label ms-1 text-main" for="chk-@option.Value">
                                                            @option.Text
                                                        </label>
                                                    </div>
                                                }
                                            </div>
                                            <div class="dropdown-divider mt-3" style="border-color: var(--border-color);"></div>
                                            <div class="px-2 d-grid">
                                                <button class="btn btn-sm btn-primary py-2 rounded-3" onclick="bootstrap.Dropdown.getOrCreateInstance(this.closest('.dropdown').querySelector('.dropdown-toggle')).hide()">@Loc.Get("Confirm")</button>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="dropdown">
                                        <button id="btn-limit-label" class="btn btn-sm btn-outline-secondary dropdown-toggle px-3 py-2 rounded-pill shadow-none" type="button" data-bs-toggle="dropdown" style="color: var(--text-main); border-color: var(--border-color);">
                                            @Loc.Get("Top") 5
                                        </button>
                                        <ul class="dropdown-menu border-0 shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border-color) !important;">
                                            <li><a class="dropdown-item" href="javascript:void(0)" onclick="setSemanticLimit(5)">5 @Loc.Get("Results")</a></li>
                                            <li><a class="dropdown-item" href="javascript:void(0)" onclick="setSemanticLimit(10)">10 @Loc.Get("Results")</a></li>
                                            <li><a class="dropdown-item" href="javascript:void(0)" onclick="setSemanticLimit(20)">20 @Loc.Get("Results")</a></li>
                                        </ul>
                                        <input type="hidden" id="semantic-result-count" value="5" />
                                    </div>

                                    <button id="run-semantic-search" class="btn btn-primary fw-bold px-4 py-2 rounded-pill shadow-sm" onclick="runSemanticSearch()">
                                        <i class="bi bi-stars @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("RunSimilaritySearch")
                                    </button>
                                </div>
                                </div>
                            </div>
                        </div>
                        <div class="card-body p-4">
                            <div class="row g-4">
                                <div class="col-lg-8">
                                    <div id="semantic-search-results" class="d-flex flex-column gap-3 d-none">
                                    </div>

                                    <div id="semantic-search-empty" class="text-center py-5 px-4 rounded-4 border d-none" style="background: var(--bg-main) !important; border-color: var(--border-color) !important;">
                                        <div class="mb-3"><i class="bi bi-search-heart fs-2 text-muted"></i></div>
                                        <h6 class="fw-bold mb-2" style="color: var(--text-main) !important;">@Loc.Get("NoSimilarFound")</h6>
                                        <p class="text-muted small mb-0">@Loc.Get("SimilarityScopeSubtitle")</p>
                                    </div>
                                </div>
                                <div class="col-lg-4">
                                    <div class="p-4 rounded-4 h-100" style="background: var(--bg-main) !important; border: 1px solid var(--border-color) !important;">
                                        <div class="d-flex justify-content-between align-items-center mb-3">
                                            <h6 class="fw-bold mb-0 text-uppercase small" style="color: var(--primary-color) !important; letter-spacing: 0.08em;">@Loc.Get("SearchScope")</h6>
                                            <span class="badge rounded-pill" style="background: rgba(var(--primary-color-rgb),0.1); color: var(--primary-color); border: 1px solid rgba(var(--primary-color-rgb),0.2);">@Loc.Get("Admin")</span>
                                        </div>
                                        <div class="small mb-3" style="color: var(--text-muted) !important; line-height: 1.6;">
                                            @Loc.Get("SearchLogicSubtitle")
                                        </div>
                                        <div class="d-grid gap-3">
                                            <div class="p-3 rounded-3" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color);">
                                                <div class="text-uppercase fw-bold small mb-1" style="font-size: 0.65rem; color: var(--text-muted) !important;">@Loc.Get("Category")</div>
                                                <div class="fw-bold" style="color: var(--text-main) !important;">@(Model.ProductArea ?? Loc.Get("TBD"))</div>
                                            </div>
                                            <div class="p-3 rounded-3" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color);">
                                                <div class="text-uppercase fw-bold small mb-1" style="font-size: 0.65rem; color: var(--text-muted) !important;">@Loc.Get("Environment")</div>
                                                <div class="fw-bold" style="color: var(--text-main) !important;">@(Model.EnvironmentName ?? Loc.Get("TBD"))</div>
                                            </div>
                                            <div class="p-3 rounded-3" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color);">
                                                <div class="text-uppercase fw-bold small mb-1" style="font-size: 0.65rem; color: var(--text-muted) !important;">@Loc.Get("ResolvedPool")</div>
                                                <div id="semantic-pool-size" class="fw-bold" style="color: var(--text-main) !important;">@(ViewBag.TicketCandidateCount ?? "0") @Loc.Get("IndexedTickets")</div>
                                            </div>
                                            <div class="p-3 rounded-3" style="background: rgba(255,255,255,0.03); border: 1px solid var(--border-color);">
                                                <div class="text-uppercase fw-bold small mb-1" style="font-size: 0.65rem; color: var(--text-muted) !important;">@Loc.Get("StatusScope")</div>
                                                <div id="semantic-status-scope" class="fw-bold" style="color: var(--text-main) !important;">@Loc.Get("ResolvedClosedLabel")</div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @* ── 2. AI Analysis Tab (Admin Only) — Accordion Layout ── *@
            @if (ViewBag.IsAdmin == true)
            {
                <div class="tab-pane fade" id="ai-content" role="tabpanel">
                    <div id="ai-main-card" class="card border-0 shadow-sm mb-4 overflow-hidden animate__animated animate__fadeIn" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important; position: relative;">
                        

                        @* ── Header with Controls ── *@
                        <div class="card-header border-0 p-4 bg-transparent" style="background: linear-gradient(90deg, rgba(99,102,241,0.1), transparent) !important;">
                            <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
                                <div class="d-flex align-items-center">
                                    <div class="d-flex align-items-center justify-content-center rounded-4 @(Loc.IsRtl ? "ms-3" : "me-3") shadow-lg" style="width:48px;height:48px;background:linear-gradient(135deg,#6366f1,var(--primary-color));flex-shrink:0;">
                                        <i class="bi bi-robot text-white fs-5"></i>
                                    </div>
                                    <div>
                                        <h5 class="fw-bold mb-0" style="color: var(--text-main) !important;">@Loc.Get("TicketAnalysis")</h5>
                                        <p class="text-muted small mb-0">@Loc.Get("TicketAnalysisOnlyHint") • <span id="ai-run-label" class="fw-bold" style="color: var(--primary-color);">—</span></p>
                                    </div>
                                </div>
                                <div class="d-flex gap-2 align-items-center flex-wrap">
                                    @* Run History Dropdown *@
                                    <div id="ai-history-dropdown" class="dropdown d-none">
                                        <button class="btn btn-sm btn-soft-secondary rounded-pill shadow-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                                            <i class="bi bi-clock-history @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("RunHistory")
                                        </button>
                                        <ul id="ai-history-menu" class="dropdown-menu dropdown-menu-end shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border-color); min-width: 220px;"></ul>
                                    </div>
                                    <button id="btn-run-ai" type="button" class="btn btn-premium d-none" onclick="startAiInvestigation()">
                                        <i class="bi bi-cpu-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i> @Loc.Get("AnalyzeTicket")
                                    </button>
                                    <button id="btn-refresh-ai" type="button" class="btn btn-soft-primary rounded-pill d-none" onclick="startAiRefresh()">
                                        <i class="bi bi-arrow-repeat @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("ReAnalyzeTicket")
                                    </button>
                                    <button id="btn-view-logs" type="button" class="btn btn-sm btn-outline-secondary rounded-pill d-none" onclick="showAnalysisLogs('@Model.Id')">
                                        <i class="bi bi-terminal @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("Logs")
                                    </button>
                                    <button id="btn-run-copilot" type="button" class="btn btn-soft-primary rounded-pill" onclick="runCopilotRecommendation()">
                                        <i class="bi bi-journal-check @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("AskAiWithEvidence")
                                    </button>
                                    <a asp-controller="AiAnalysis" asp-action="Copilot" asp-route-ticketId="@Model.Id" class="btn btn-soft-primary rounded-pill copilot-open-copilot">
                                        <i class="bi bi-chat-square-text @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("CopilotEngine")
                                    </a>
                                </div>
                            </div>
                        </div>

                        @* ── AI Results Body ── *@
                        <div class="card-body p-0" id="ai-results-container">
                            <div class="px-4 pt-4">
                                <div class="p-3 rounded-4 mb-4 card-inner-premium">
