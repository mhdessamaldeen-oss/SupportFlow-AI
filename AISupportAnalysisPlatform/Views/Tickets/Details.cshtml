                                </div>
                            </a>
                        }
                    </div>
                </div>
            </div>
        }

        <div class="card border-0 shadow-sm overflow-hidden" style="background: var(--bg-card) !important; border: 1px solid var(--border-color) !important;">
            <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent border-bottom" style="border-color: var(--border-color) !important;">
                <h6 class="fw-bold mb-3 text-uppercase small text-muted" style="color: var(--text-muted) !important;">@Loc.Get("TicketHistory")</h6>
            </div>
            <div class="list-group list-group-flush">
                @foreach(var h in Model.HistoryRecords.OrderByDescending(x => x.CreatedAt).Take(4))
                {
                    <div class="list-group-item px-4 py-2 bg-transparent" style="border-color: var(--border-color) !important;">
                        <div class="d-flex justify-content-between">
                            <span class="fw-bold small" style="font-size:0.75rem; color: var(--text-main) !important;">@h.Action</span>
                            <span class="text-muted" style="font-size:0.65rem; color: var(--text-muted) !important;">@h.CreatedAt.ToString("MMM dd")</span>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@* ── AI JavaScript Engine ── *@
<script>
    const isRtl = @Loc.IsRtl.ToString().ToLowerInvariant();

    function setSemanticLimit(val) {
        document.getElementById('btn-limit-label').textContent = `@Loc.Get("Top") ${val}`;
        document.getElementById('semantic-result-count').value = val;
    }

    window.runSemanticSearch = function() {
        const btn = document.getElementById('run-semantic-search');
        const results = document.getElementById('semantic-search-results');
        const empty = document.getElementById('semantic-search-empty');
        const resultCount = document.getElementById('semantic-result-count');
        const checkboxes = document.querySelectorAll('.semantic-status-chk:checked');
        
        if (!btn || !results || !empty) return;

        const selectedStatusIds = Array.from(checkboxes).map(chk => chk.value);
        if (selectedStatusIds.length === 0) {
            alert('@Loc.Get("SelectAtLeastOneStatus")');
            return;
        }

        btn.disabled = true;
        btn.innerHTML = '<span class="spinner-border spinner-border-sm @(Loc.IsRtl ? "ms-2" : "me-2")" role="status"></span> @Loc.Get("SearchingSimilar")...';

        results.classList.add('d-none');
        empty.classList.add('d-none');
        
        const query = new URLSearchParams();
        selectedStatusIds.forEach(id => query.append('statusIds', id));
        query.append('count', resultCount?.value || '5');

        fetch(`/Tickets/RunSemanticSearch/@Model.Id?${query.toString()}`, {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''
            }
        })
        .then(async response => {
            if (!response.ok) {
                const text = await response.text();
                throw new Error(text || `HTTP ${response.status}`);
            }
            return response.json();
        })
        .then(result => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-arrow-repeat @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("ReRunSimilarity")';
            const poolSizeEl = document.getElementById('semantic-pool-size');
            const scopeEl = document.getElementById('semantic-status-scope');
            if (poolSizeEl && typeof result.poolSize !== 'undefined') {
                poolSizeEl.textContent = `${result.poolSize} @Loc.Get("IndexedTickets")`;
            }
            if (scopeEl && result.scopeLabel) {
                scopeEl.textContent = result.scopeLabel;
            }

            if (result.success && result.data && result.data.length > 0) {
                results.classList.remove('d-none');
                results.innerHTML = result.data.map(rt => `
                    <a href="/Tickets/Details/${rt.id}" class="text-decoration-none">
                        <div class="p-4 rounded-4 border shadow-sm transition-all hover-lift" style="background: var(--bg-main); border-color: var(--border-color) !important;">
                            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                                <div>
                                    <div class="fw-bold mb-1" style="color: var(--primary-color) !important;">#${rt.ticketNumber}</div>
                                    <div class="fw-semibold" style="color: var(--text-main); text-align: ${isRtl ? 'right' : 'left'};">${rt.title}</div>
                                </div>
                                <div class="d-flex flex-column align-items-end gap-2">
                                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(var(--primary-color-rgb),0.1); color: var(--primary-color); border: 1px solid rgba(var(--primary-color-rgb),0.25);">@Loc.Get("Resolved")</span>
                                    <span class="badge rounded-pill px-3 py-2" style="background: rgba(99,102,241,0.12); color: #6366f1; border: 1px solid rgba(99,102,241,0.22);">${rt.score}% match</span>
                                </div>
                            </div>
                            <div class="small text-muted d-flex align-items-center gap-2">
                                <span><i class="bi bi-calendar3 @(Loc.IsRtl ? "ms-1" : "me-1")"></i>${rt.createdAt}</span>
                            </div>
                        </div>
                    </a>`).join('');
            } else {
                empty.classList.remove('d-none');
                if (!result.success) {
                    empty.innerHTML += `<div class="badge bg-danger-subtle text-danger border border-danger-subtle mt-3 px-3 py-2 rounded-pill small"><i class="bi bi-exclamation-triangle-fill @(Loc.IsRtl ? "ms-2" : "me-2")"></i> ${result.message || '@Loc.Get("EngineOffline")'}</div>`;
                }
            }
        })
        .catch(err => {
            btn.disabled = false;
            btn.innerHTML = '<i class="bi bi-search @(Loc.IsRtl ? "ms-1" : "me-1")"></i> @Loc.Get("RunSimilaritySearch")';
            console.error('Semantic Search Error:', err);
            
            empty.classList.remove('d-none');
            empty.innerHTML += `<div class="badge bg-danger-subtle text-danger border border-danger-subtle mt-3 px-3 py-2 rounded-pill small"><i class="bi bi-wifi-off @(Loc.IsRtl ? "ms-2" : "me-2")"></i> @Loc.Get("ConnectionFail"): ${err.message || '@Loc.Get("CheckEngine")'}</div>`;
        });
    }

    let pollInterval = null;
    const ticketId = '@Model.Id';
    const aiPollIntervalMs = 3000;
    let loadedRunHistoryFor = null;
    let activeAiRunNumber = null;

    document.addEventListener('DOMContentLoaded', function() {
        checkAiStatus();
    });

    // ─── Core Status Check ─────────────────────────────────────────
    async function checkAiStatus() {
        try {
            const response = await fetch(`@Url.Action("GetStatus", "AiAnalysis")/${ticketId}`);
            const data = await response.json();
            
            // Render basic UI states (allows history dropdown and badges to populate)
            renderAiResult(data);
            
            const isPending = data.status === 'Queued' || data.status === 'InProgress';
            
            if (isPending) {
                // Override visibility for active execution inline terminal
                showLoading(true, data);
                if (!pollInterval) pollInterval = setInterval(checkAiStatus, aiPollIntervalMs);
            } else {
                showLoading(false);
                if (pollInterval) { clearInterval(pollInterval); pollInterval = null; }
            }
        } catch (error) {
            console.error('AI status check failed:', error);
        }
    }

    // ─── Load a specific historical run ────────────────────────────
    async function loadRun(runNumber) {
        try {
            const response = await fetch(`@Url.Action("GetRun", "AiAnalysis")?ticketId=${ticketId}&runNumber=${runNumber}`);
            const data = await response.json();
            activeAiRunNumber = runNumber;
            renderAiResult(data);
        } catch (error) {
            console.error('Failed to load run:', error);
        }
    }

    // ─── Load run history dropdown ─────────────────────────────────
    async function loadRunHistory() {
        try {
            const response = await fetch(`@Url.Action("GetRunHistory", "AiAnalysis")?ticketId=${ticketId}`);
            const runs = await response.json();
            
            const wrapper = document.getElementById('ai-history-dropdown');
            const menu = document.getElementById('ai-history-menu');

            if (runs.length > 1) {
                wrapper.classList.remove('d-none');
                menu.innerHTML = runs.map(r => `
                    <li>
                        <a class="dropdown-item d-flex justify-content-between align-items-center py-2 px-3" href="javascript:void(0)" onclick="loadRun(${r.runNumber})" style="color: var(--text-main); font-size: 0.8rem;">
                            <span><i class="bi bi-cpu me-2 opacity-50"></i>Run #${r.runNumber}</span>
                            <span class="d-flex align-items-center gap-2">
                                <span class="badge rounded-pill ${r.analysisStatus === 'Success' ? 'bg-success' : (r.analysisStatus === 'Failed' ? 'bg-danger' : 'bg-warning')}" style="font-size: 0.55rem;">${r.analysisStatus}</span>
                                <span class="text-muted" style="font-size: 0.65rem;">${r.createdOn}</span>
                            </span>
                        </a>
                    </li>
                `).join('');
            } else {
                wrapper.classList.add('d-none');
            }
        } catch (e) { console.error('Failed to load history:', e); }
    }

    // ─── Render AI Result into Accordion ───────────────────────────
    function renderAiResult(data) {
        const hasResult = data.status === 'Success' || data.status === 'Failed' || data.status === 'InProgress' || data.status === 'Queued';
        const isPending = data.status === 'InProgress' || data.status === 'Queued';
        const isFailed = data.status === 'Failed';

        // Button visibility
        document.getElementById('btn-run-ai').classList.toggle('d-none', data.status !== 'NotStarted');
        document.getElementById('btn-refresh-ai').classList.toggle('d-none', data.status === 'NotStarted' || isPending);
        document.getElementById('btn-view-logs').classList.toggle('d-none', !hasResult || data.status === 'NotStarted');

        // Content visibility
        document.getElementById('ai-empty-state').classList.toggle('d-none', hasResult);
        document.getElementById('ai-content-body').classList.toggle('d-none', !hasResult);
        
        const badge = document.getElementById('ai-tab-badge');
        badge.classList.toggle('d-none', data.status !== 'Success' && data.status !== 'Failed');
        badge.textContent = isFailed ? 'FAILED' : 'READY';
        badge.className = `ms-2 badge rounded-pill pulse-badge ${isFailed ? 'bg-danger' : 'bg-primary'}`;

        // Run label
        document.getElementById('ai-run-label').textContent = data.runNumber ? `Run #${data.runNumber}` : '—';
        activeAiRunNumber = data.runNumber || null;

        if (!hasResult) return;

        // ── Section 1: Summary
        const summaryEl = document.getElementById('ai-summary');
        summaryEl.innerText = data.summary || (isPending ? 'Analyzing...' : 'N/A');
        
        if (isFailed) {
            summaryEl.parentElement.style.background = 'rgba(239, 68, 68, 0.05)';
            summaryEl.parentElement.style.borderColor = 'rgba(239, 68, 68, 0.3)';
            summaryEl.style.color = '#ef4444';
        } else {
            summaryEl.parentElement.style.background = 'var(--bg-main)';
            summaryEl.parentElement.style.borderColor = 'var(--border-color)';
            summaryEl.style.color = 'var(--text-main)';
        }

        // ── Section 2: Key Clues
        const cluesContainer = document.getElementById('ai-key-clues');
        const cluesText = data.keyClues || '';
        const cluesList = cluesText.includes(',') ? cluesText.split(',').map(c => c.trim()).filter(c => c) : (cluesText ? [cluesText] : []);
        document.getElementById('ai-clues-count').textContent = cluesList.length;
        cluesContainer.innerHTML = cluesList.length ? cluesList.map(c => `
            <div class="d-flex align-items-start p-3 rounded-3" style="background: rgba(239,68,68,0.03); border: 1px solid rgba(239,68,68,0.08);">
                <i class="bi bi-exclamation-diamond-fill text-danger me-3 mt-1 flex-shrink-0" style="font-size:0.8rem;"></i>
                <span class="small" style="color: var(--text-main); line-height: 1.5;">${c}</span>
            </div>
        `).join('') : '<div class="text-muted small">No clues generated.</div>';

        // ── Section 3: Attachments
        const attachWrapper = document.getElementById('aiSec-attach-wrapper');
        const attachList = document.getElementById('ai-attachments-list');
        const attachments = data.attachments || [];
        if (attachments.length > 0) {
            attachWrapper.classList.remove('d-none');
            document.getElementById('ai-attach-count').textContent = `${attachments.length} files`;
            attachList.innerHTML = attachments.map(a => `
                <div class="p-3 rounded-3 d-flex align-items-start gap-3" style="background: var(--bg-main); border: 1px solid var(--border-color);">
                    <div class="flex-shrink-0 d-flex align-items-center justify-content-center rounded-3" style="width:36px;height:36px;background:rgba(var(--primary-color-rgb),0.1);">
                        <i class="bi bi-file-earmark-text" style="color: var(--primary-color);"></i>
                    </div>
                    <div class="flex-grow-1 min-width-0">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-bold small text-truncate" style="color: var(--text-main);">${a.fileName}</span>
                            <span class="badge rounded-pill ms-2 flex-shrink-0 ${a.relevance === 'High' ? 'bg-danger' : (a.relevance === 'Medium' ? 'bg-warning text-dark' : 'bg-success')}" style="font-size:0.6rem;">${a.relevance}</span>
                        </div>
                        <div class="small" style="color: var(--text-muted); line-height:1.5;">${a.summary}</div>
                    </div>
                </div>
            `).join('');
        } else {
            attachWrapper.classList.add('d-none');
        }

        // ── Section 4: Classification & Priority
        document.getElementById('ai-classification').textContent = data.suggestedClassification || 'Unknown';
        
        const priorityEl = document.getElementById('ai-priority');
        const prio = data.suggestedPriority || 'Medium';
        priorityEl.textContent = prio;
        priorityEl.style.background = prio === 'High' || prio === 'Critical' ? 'rgba(239,68,68,0.1)' : (prio === 'Medium' ? 'rgba(245,158,11,0.1)' : 'rgba(var(--primary-color-rgb),0.1)');
        priorityEl.style.color = prio === 'High' || prio === 'Critical' ? '#ef4444' : (prio === 'Medium' ? '#f59e0b' : getComputedStyle(document.documentElement).getPropertyValue('--primary-color').trim());
        priorityEl.style.border = `1px solid ${prio === 'High' || prio === 'Critical' ? 'rgba(239,68,68,0.2)' : (prio === 'Medium' ? 'rgba(245,158,11,0.2)' : 'rgba(var(--primary-color-rgb),0.2)')}`;

        const sentimentEl = document.getElementById('ai-sentiment');
        const sentiment = data.customerSentiment || 'Neutral';
        sentimentEl.textContent = sentiment;
        sentimentEl.style.background = (sentiment === 'Angry' || sentiment === 'Frustrated' || sentiment === 'Furious') ? 'rgba(239,68,68,0.1)' : 'rgba(56,189,248,0.1)';
        sentimentEl.style.color = (sentiment === 'Angry' || sentiment === 'Frustrated' || sentiment === 'Furious') ? '#ef4444' : '#38bdf8';
        sentimentEl.style.borderColor = (sentiment === 'Angry' || sentiment === 'Frustrated' || sentiment === 'Furious') ? 'rgba(239,68,68,0.2)' : 'rgba(56,189,248,0.2)';

        const reviewEl = document.getElementById('ai-manager-review');
        const needsReview = data.requiresManagerReview === true;
        reviewEl.textContent = needsReview ? 'Yes (Escalated)' : 'No';
        reviewEl.style.background = needsReview ? 'rgba(245,158,11,0.1)' : 'rgba(255,255,255,0.05)';
        reviewEl.style.color = needsReview ? '#f59e0b' : 'var(--text-muted)';
        reviewEl.style.borderColor = needsReview ? 'rgba(245,158,11,0.2)' : 'var(--border-color)';

        const conf = data.confidence || 'Low';
        document.getElementById('ai-duration').textContent = data.duration ? `${data.duration} ms (Conf: ${conf})` : `(Conf: ${conf})`;

        // ── Section 5: Next Step
        document.getElementById('ai-next-step').innerText = data.nextStepSuggestion || (isPending ? 'Synthesizing...' : 'N/A');

        // ── Section 6: Diagnostics
        document.getElementById('ai-status-label').textContent = isFailed ? 'Failed' : data.status;
        document.getElementById('ai-status-label').style.color = isFailed ? '#ef4444' : '';
        document.getElementById('ai-model').textContent = data.model || 'N/A';
        document.getElementById('ai-prompt-size').textContent = data.promptSize ? `${data.promptSize} chars` : '—';
        document.getElementById('ai-run-number').textContent = data.runNumber || '—';
        document.getElementById('ai-created-on').textContent = data.createdOn || '—';
        document.getElementById('ai-context-meta').textContent = data.metadata || 'No context metadata available.';

        if (data.runNumber && loadedRunHistoryFor !== data.runNumber) {
            loadedRunHistoryFor = data.runNumber;
            loadRunHistory();
        }

        // ── UPDATE INTELLIGENCE GLANCE & SIDEBAR
        updateIntelligenceUI(data);
    }

    function updateIntelligenceUI(data) {
        const glance = document.getElementById('ai-quick-glance');
        const sidebar = document.getElementById('ai-sidebar-indicators');
        if (!glance) return;

        if (data.status === 'Success') {
            glance.classList.remove('d-none');
            if (sidebar) sidebar.classList.remove('d-none');

            document.getElementById('ai-glance-summary').textContent = data.summary;
            
            const sentBadge = document.getElementById('glance-sentiment-badge');
            const sideSent = document.getElementById('sidebar-sentiment');
            const sentiment = data.customerSentiment || 'Neutral';
            const isNegative = ['Angry', 'Frustrated', 'Furious', 'Negative'].includes(sentiment);
            
            [sentBadge, sideSent].forEach(el => {
                if (!el) return;
                el.textContent = sentiment;
                el.className = `badge rounded-pill ${isNegative ? 'bg-danger-subtle text-danger' : 'bg-info-subtle text-info'} border ${isNegative ? 'border-danger-subtle' : 'border-info-subtle'}`;
            });

            const revBadge = document.getElementById('glance-review-badge');
            const revCard = document.getElementById('sidebar-review-card');
            if (data.requiresManagerReview) {
                revBadge.classList.remove('d-none');
                revBadge.textContent = '@Loc.Get("Attention")';
                revBadge.className = 'badge rounded-pill bg-warning text-dark border border-warning';
                if (revCard) revCard.classList.remove('d-none');
            } else {
                revBadge.classList.add('d-none');
                if (revCard) revCard.classList.add('d-none');
            }
        } else {
            glance.classList.add('d-none');
            if (sidebar) sidebar.classList.add('d-none');
        }
    }

    // ─── Loading Overlay Step-By-Step ───────────────────────────────
    let lastLogCount = 0;
    function showLoading(active, data = null) {
        const activeContainer = document.getElementById('ai-active-state');
        const emptyState = document.getElementById('ai-empty-state');
        const contentBody = document.getElementById('ai-content-body');
        const logsBox = document.getElementById('ai-live-logs-container');
        
        if (active) {
            activeContainer.classList.remove('d-none');
            emptyState.classList.add('d-none');
            contentBody.classList.add('d-none');
            
            document.getElementById('btn-run-ai').classList.add('d-none');
            document.getElementById('btn-refresh-ai').classList.add('d-none');
            
            const liveLog = data?.latestLog || 'Continuing analysis sequence...';
            logsBox.innerHTML = `
                <div class="mb-2" style="font-size: 0.8rem;">
                    <span class="text-info fw-medium">${liveLog}</span>
                </div>
                <div class="d-flex align-items-center mt-3 text-muted" style="font-size: 0.75rem;">
                    <div class="spinner-border spinner-border-sm me-2 text-primary" role="status" style="width:0.8rem;height:0.8rem;"></div>
                    <span class="pulse-text">Run #${data?.runNumber || '—'} is still processing...</span>
                </div>`;
        } else {
            activeContainer.classList.add('d-none');
            lastLogCount = 0; // Reset for next time
        }
    }

    // ─── Actions ───────────────────────────────────────────────────
    async function startAiInvestigation() {
        showLoading(true);
        const response = await fetch(`@Url.Action("RunAnalysis", "AiAnalysis")/${ticketId}`, { 
            method: 'POST',
            headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }
        });
        const result = await response.json();
        if (result.success) {
            setTimeout(checkAiStatus, 800);
        }
    }

    async function startAiRefresh() {
        showLoading(true);
        const response = await fetch(`@Url.Action("RefreshAnalysis", "AiAnalysis")/${ticketId}`, { 
            method: 'POST',
            headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value || '' }
        });
        const result = await response.json();
        if (result.success) {
            setTimeout(checkAiStatus, 800);
        }
    };

    window.runCopilotRecommendation = async function() {
        const button = document.getElementById('btn-run-copilot');
        const emptyState = document.getElementById('copilot-empty-state');
        const loadingState = document.getElementById('copilot-loading-state');
        const content = document.getElementById('copilot-content');

        button.disabled = true;
        loadingState.classList.remove('d-none');
        emptyState.classList.add('d-none');
        content.classList.add('d-none');

        try {
            const response = await fetch(`@Url.Action("GetCopilotRecommendation", "AiAnalysis")/${ticketId}`);
            const data = await response.json();

            if (!response.ok) {
                throw new Error(data?.details || data?.message || 'Copilot recommendation failed.');
            }

            renderCopilotRecommendation(data);
        } catch (error) {
            emptyState.classList.remove('d-none');
            emptyState.innerHTML = `
                <div class="fw-bold mb-2 text-danger">@Loc.Get("CopilotRecommendationFailed")</div>
                <div class="text-muted-custom small">${error.message}</div>`;
        } finally {
            loadingState.classList.add('d-none');
            button.disabled = false;
        }
    };

    function renderCopilotRecommendation(data) {
        const emptyState = document.getElementById('copilot-empty-state');
        const content = document.getElementById('copilot-content');
        const notes = document.getElementById('copilot-notes');
        const strength = document.getElementById('copilot-evidence-strength');

        emptyState.classList.add('d-none');
        content.classList.remove('d-none');

        document.getElementById('copilot-summary').innerText = data.summary || '@Loc.Get("NoAnalysisYet")';
        document.getElementById('copilot-action').innerText = data.recommendedAction || '@Loc.Get("NoAnalysisYet")';

        if (data.generationNotes) {
            notes.classList.remove('d-none');
            notes.textContent = data.generationNotes;
        } else {
            notes.classList.add('d-none');
            notes.textContent = '';
        }

        strength.classList.remove('d-none');
        strength.textContent = `${data.evidenceStrength || 'Weak'} @Loc.Get("EvidenceStrength")`;
        strength.style.background = data.evidenceStrength === 'Strong'
            ? 'rgba(var(--primary-color-rgb),0.12)'
            : data.evidenceStrength === 'Moderate'
                ? 'rgba(245,158,11,0.12)'
                : 'rgba(239,68,68,0.12)';
        strength.style.color = data.evidenceStrength === 'Strong'
            ? getComputedStyle(document.documentElement).getPropertyValue('--primary-color').trim()
            : data.evidenceStrength === 'Moderate'
                ? '#f59e0b'
                : '#ef4444';

        const tickets = data.similarTickets || [];
        document.getElementById('copilot-ticket-count').textContent = tickets.length;
        document.getElementById('copilot-ticket-evidence').innerHTML = tickets.length
            ? tickets.map(t => `
                <a href="@Url.Action("Details", "Tickets")/${t.ticketId}" class="text-decoration-none">
                    <div class="copilot-evidence-item ticket-evidence-item">
                        <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                            <span class="fw-bold text-main">${t.ticketNumber}</span>
                            <span class="badge rounded-pill pill-badge-primary">${t.score}%</span>
                        </div>
                        <div class="small fw-semibold mb-1 text-main">${t.title}</div>
                        <div class="small text-muted-custom" style="line-height: 1.5;">${t.resolutionSummary || ''}</div>
                    </div>
                </a>`)
                .join('')
            : `<div class="text-muted-custom small">@Loc.Get("NoSimilarTicketEvidence")</div>`;

        const docs = data.knowledgeMatches || [];
        document.getElementById('copilot-doc-count').textContent = `${docs.length} / ${data.knowledgeDocumentCount || 0}`;
        document.getElementById('copilot-doc-evidence').innerHTML = docs.length
            ? docs.map(d => `
                <div class="copilot-evidence-item doc-evidence-item">
                    <div class="d-flex justify-content-between align-items-center gap-2 mb-2">
                        <span class="fw-bold text-main">${d.documentName}</span>
                        <span class="badge rounded-pill pill-badge-primary">${d.score}%</span>
                    </div>
                    <div class="small fw-semibold mb-1 text-main">${d.sectionTitle}</div>
                    <div class="small text-muted-custom mb-2" style="line-height: 1.5;">${d.excerpt}</div>
                    <div class="small font-monospace text-muted-custom">${d.sourcePath}</div>
                </div>`)
                .join('')
            : `<div class="text-muted-custom small">@Loc.Get("NoKnowledgeBaseEvidence")</div>`;
    }

    window.showAnalysisLogs = async function(id) {
        const modalEl = document.getElementById('logsModal');
        const container = document.getElementById('logs-container-modal');
        if (!container || !modalEl) return;
        const modal = bootstrap.Modal.getOrCreateInstance(modalEl);
        modal.show();
        container.innerHTML = '<div class="text-center py-5 text-info"><div class="spinner-border spinner-border-sm @(Loc.IsRtl ? "ms-2" : "me-2")"></div> @Loc.Get("LoadingLogs")...</div>';
        try {
            const response = await fetch(`@Url.Action("GetLogs", "AiAnalysis")?ticketId=${id}`);
            const logs = await response.json();
            if (!logs || logs.length === 0) {
                container.innerHTML = `<div class="text-muted-custom p-3 text-center">@Loc.Get("NoLogs")</div>`;
                return;
            }
            container.innerHTML = logs.map(l => `
                <div class="mb-2 border-bottom border-premium pb-1" style="font-size: 0.82rem; text-align: ${"@Loc.IsRtl" === "True" ? 'right' : 'left'};">
                    <span class="text-muted-custom small @(Loc.IsRtl ? "ms-2" : "me-2") opacity-75">${l.time}</span>
                    <span class="${l.level === 'Error' ? 'text-danger fw-bold' : (l.level === 'Warning' ? 'text-warning' : 'text-primary-custom')} fw-medium">${l.message}</span>
                </div>
            `).join('');
        } catch (err) {
            container.innerHTML = `<div class="text-danger p-2">@Loc.Get("LogRetrievalFail"): ${err.message}</div>`;
        }
    };
</script>

@* ── Logs Modal ── *@
<div class="modal fade" id="logsModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content modal-premium">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold text-main"><i class="bi bi-terminal @(Loc.IsRtl ? "ms-2" : "me-2") text-primary-custom"></i>@Loc.Get("ExecutionLogs")</h5>
                <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" style="filter: var(--btn-close-filter); @(Loc.IsRtl ? "margin-left: 0; margin-right: auto;" : "")"></button>
            </div>
            <div class="modal-body">
                <div id="logs-container-modal" class="p-3 rounded-4 log-container-premium"></div>
            </div>
        </div>
    </div>
</div>
