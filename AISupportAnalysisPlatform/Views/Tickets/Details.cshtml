                                        @if (att.ContentType.Contains("image")) { <i class="bi bi-image fs-5"></i> }
                                        else if (att.ContentType.Contains("pdf")) { <i class="bi bi-file-earmark-pdf fs-5 text-danger"></i> }
                                        else { <i class="bi bi-file-earmark-text fs-5"></i> }
                                    </div>
                                    <div class="overflow-hidden">
                                        <div class="text-truncate fw-bold small mb-1">@att.FileName</div>
                                        <span class="badge" style="background: rgba(255,255,255,0.05); color: var(--text-muted); border: 1px solid var(--border-color);">@((att.FileSize / 1024).ToString("N0")) @Loc.Get("KB")</span>
