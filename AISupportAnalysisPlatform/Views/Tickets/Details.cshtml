                <div class="card-header border-0 pb-0 pt-4 px-4 bg-transparent border-bottom" style="border-color: var(--border-color) !important;">
                    <h6 class="fw-bold mb-3 text-uppercase small text-muted" style="color: var(--text-muted) !important;">
                        @Loc.Get("Attachments") <span class="badge rounded-pill @(Loc.IsRtl ? "me-2" : "ms-2")" style="background: rgba(99,102,241,0.1); color: #818cf8;">@Model.Attachments.Count</span>
                    </h6>
                </div>
                <div class="card-body p-4 pt-3">
                    <div class="d-flex flex-column gap-3">
