@model AISupportAnalysisPlatform.Models.Entity

@{
    ViewData["Title"] = Loc.Get("CreateEntity");
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card border-0 shadow-sm mt-4">
            <div class="card-header bg-white border-0 pt-4 px-4 pb-0">
                <h4 class="fw-bold mb-0 text-primary"><i class="bi bi-building-add @(Loc.IsRtl ? "ms-2" : "me-2")"></i>@Loc.Get("ProvisionNewEntity")</h4>
                <p class="text-muted small mt-1">@Loc.Get("ProvisionEntityDesc")</p>
            </div>
            <div class="card-body p-4">
                <form asp-action="Create">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    
                    <div class="mb-4">
                        <label asp-for="Name" class="form-label fw-bold">@Loc.Get("OfficialEntityDesignation")</label>
                        <input asp-for="Name" class="form-control form-control-lg bg-light border-0 shadow-none" placeholder="@Loc.Get("EntityNameHint")" />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch p-4 bg-light rounded-3 border border-light">
                            <input class="form-check-input @(Loc.IsRtl ? "me-0 ms-3" : "ms-0 me-3")" type="checkbox" asp-for="IsActive" checked style="transform: scale(1.3);">
                            <label class="form-check-label fw-bold" asp-for="IsActive">@Loc.Get("EnableEntityScope")</label>
                            <div class="form-text mt-1 text-muted">@Loc.Get("EntityScopeDesc")</div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end mt-5">
                        <button type="submit" class="btn btn-primary shadow-sm px-5 fw-bold">
                            @Loc.Get("CommitEntity") <i class="bi bi-check-lg @(Loc.IsRtl ? "me-2" : "ms-2")"></i>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
